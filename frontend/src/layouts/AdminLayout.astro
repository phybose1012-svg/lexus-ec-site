---
import "../styles/global.css";
import "../styles/admin.css";

interface Props {
  title: string;
  description?: string;
  active?: "dashboard" | "content" | "reports";
}

const {
  title,
  description = "レクサスE.C.のページ更新、SEO監査、ステージング確認を扱う管理画面です。",
  active = "dashboard",
} = Astro.props;

const navItems = [
  { id: "dashboard", label: "Overview", href: "/admin/" },
  { id: "content", label: "Content", href: "/admin/content/" },
  { id: "reports", label: "Reports", href: "/admin/reports/" },
] as const;
---

<!doctype html>
<html lang="ja" class="admin-document">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="admin-body">
    <a class="skip-link" href="#admin-content">コンテンツにスキップ</a>
    <div class="admin-shell">
      <header class="admin-header">
        <a class="admin-brand" href="/admin/" aria-label="管理画面トップへ">
          <span class="admin-brand-mark">L</span>
          <span>
            <strong>LEXUS E.C. Admin</strong>
            <small>content and SEO operations</small>
          </span>
        </a>
        <nav class="admin-nav" aria-label="管理画面メニュー">
          {
            navItems.map((item) => (
              <a class:list={["admin-nav-link", { "is-active": active === item.id }]} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main id="admin-content" class="admin-main">
        <slot />
      </main>
    </div>
  </body>
</html>
