---
import SectionHeading from "../components/SectionHeading.astro";
import SuccessCard from "../components/SuccessCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  acceptedUniversities,
  achievementStats,
  assets,
  comparisonRows,
  courses,
  growthItems,
  headerActions,
  heroActions,
  latestPosts,
  methodPillars,
  navGroups,
  parentVoices,
  quickLinks,
  representativeMessages,
  seo,
  successCards,
  supportItems,
  supportMetrics,
} from "../data/home";

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  name: "医学部予備校 レクサス E.C.",
  alternateName: "レクサス教育センター",
  url: "https://lexus-ec.com/",
  logo: seo.ogImage,
  description: seo.description,
  address: {
    "@type": "PostalAddress",
    streetAddress: "東京都渋谷区桜丘町29-7",
    addressLocality: "渋谷区",
    addressRegion: "東京都",
    postalCode: "150-0031",
    addressCountry: "JP",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "03-3477-1306",
    contactType: "customer service",
    areaServed: "JP",
    availableLanguage: ["ja"],
  },
};

const buttonClass = (tone = "red") => `button button--${tone}`;
const navLinkAttrs = (link: { target?: string; rel?: string }) => ({
  target: link.target,
  rel: link.rel ?? (link.target === "_blank" ? "noopener" : undefined),
});
const featuredSuccessCards = successCards.slice(0, 3);
const mobilePrimaryActions = headerActions.slice(0, 2);
const mobileSecondaryActions = headerActions.slice(2);
const headerNavGroups = navGroups;
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
  </Fragment>

  <header class="site-header">
    <div class="top-header">
      <a class="brand" href="/" aria-label="医学部予備校 レクサス E.C.">
        <img src={assets.logo} alt="医学部予備校 LEXUS レクサス教育センター" width="1181" height="380" fetchpriority="high" decoding="async" />
      </a>
      <div class="header-copy" aria-label="校舎の特徴">
        <span>「渋谷駅」徒歩5分</span>
        <span>寮と一体型の校舎</span>
        <span>自由に質問可能</span>
      </div>
      <div class="header-actions" aria-label="固定ショートカット">
        {headerActions.map((action) => (
          <a class={`header-action header-action--${action.tone}`} href={action.href}>
            <img src={action.icon} alt="" width="96" height="96" decoding="async" />
            <span>{action.label}</span>
          </a>
        ))}
      </div>
    </div>
  </header>

  <div class="mobile-fixed-nav-wrap">
    <div class="mobile-fixed-nav" aria-label="固定ショートカット">
      {mobilePrimaryActions.map((action) => (
        <a class={`mobile-shortcut mobile-shortcut--${action.tone}`} href={action.href}>
          <img src={action.icon} alt="" width="96" height="96" decoding="async" />
          <span>{action.label}</span>
        </a>
      ))}
      <button class="mobile-menu-button" type="button" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-menu-panel" data-mobile-menu-toggle>
        <span class="mobile-menu-button__box" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="mobile-menu-button__label">menu</span>
      </button>
      {mobileSecondaryActions.map((action) => (
        <a class={`mobile-shortcut mobile-shortcut--${action.tone}`} href={action.href}>
          <img src={action.icon} alt="" width="96" height="96" decoding="async" />
          <span>{action.label}</span>
        </a>
      ))}
    </div>

    <div class="mobile-menu-panel" id="mobile-menu-panel" hidden>
      <nav class="mobile-menu-panel__inner" aria-label="スマートフォンメニュー">
          {headerNavGroups.map((group) => (
            <section class="mobile-menu-group">
            <p class="mobile-menu-group__label">{group.label}</p>
            <ul>
              {group.links.map((link) => (
                <li><a href={link.href} {...navLinkAttrs(link)}>{link.label}</a></li>
              ))}
            </ul>
          </section>
        ))}
      </nav>
    </div>
  </div>

  <nav class="mega-nav" aria-label="主要ナビゲーション">
    <ul>
        {headerNavGroups.map((group) => (
          <li class={group.links.length === 1 ? "mega-nav__item--single" : undefined}>
          <a class={`mega-nav__label${group.links.length === 1 ? " mega-nav__label--single" : ""}`} href={group.links[0].href} {...navLinkAttrs(group.links[0])}>{group.label}</a>
          {group.links.length > 1 && (
            <div class="mega-panel">
              {group.links.map((link) => <a href={link.href} {...navLinkAttrs(link)}>{link.label}</a>)}
            </div>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <script is:inline>
    (() => {
      const toggle = document.querySelector("[data-mobile-menu-toggle]");
      const panel = document.getElementById("mobile-menu-panel");
      if (!toggle || !panel) return;

      const setOpen = (open) => {
        panel.hidden = !open;
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "メニューを閉じる" : "メニューを開く");
        document.documentElement.classList.toggle("mobile-menu-open", open);
      };

      toggle.addEventListener("click", () => setOpen(panel.hidden));
      panel.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement) setOpen(false);
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });
    })();
  </script>

  <main>
    <section class="premium-hero" aria-labelledby="premium-hero-title">
      <img class="premium-hero__bg" src={assets.heroPaper} alt="" width="1440" height="734" fetchpriority="high" decoding="async" />
      <div class="premium-hero__inner">
        <p class="premium-hero__year">2026年度</p>
        <p class="premium-hero__sub">最高級の医学部受験指導</p>
        <h2 id="premium-hero-title">覚悟が決まったら<br />レクサス・プレミア本科へ<br />（開講中）</h2>
        <p class="premium-hero__target">
          対象：既卒生（年齢制限なし）<br />
          欠員が出た場合、6月入学可能。<br />
          <span>※お問合せ下さい。</span>
        </p>
        <div class="hero-actions">
          {heroActions.map((action) => <a class={buttonClass(action.tone)} href={action.href}>{action.label}</a>)}
        </div>
        <img class="jewel-strip" src={assets.jewelPattern} alt="" width="800" height="58" decoding="async" />
      </div>
      <p class="hero-oni-words" aria-hidden="true"><span>鬼監理</span><span class="about__mark-x">×</span><span>鬼特訓</span></p>
    </section>

    <section class="intro-section" aria-labelledby="home-title">
      <div class="content-narrow">
        <h1 id="home-title">
          医学部受験 なら、<br />
          実績35年の レクサス教育センター（レクサス E.C.）にお任せください。
        </h1>
        <p>
          偏差値50台からの合格率は88%。「緻密な“鬼特訓”メニュー」と「1日13時間の厳しい管理体制 (＝“鬼監理”)」で、医学部受験生を合格へ導きます。校舎は寮と一体型で、渋谷（東京）にあります。レクサスは日本全国の浪人生や現役生の医師への思いに応えます。
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="achievements">
      <div class="content">
        <SectionHeading id="achievements" label="ACHIEVEMENTS" title="合格実績" subtitle="〜 一年で合格する割合 〜" />

        <div class="achievement-stats">
          {achievementStats.map((stat) => (
            <article class={`stat-card stat-card--${stat.tone}`}>
              <p>{stat.label}</p>
              <strong>{stat.value}</strong>
            </article>
          ))}
        </div>

        <h3 class="university-list__title">合格した大学一覧(医学部医学科のみ)</h3>
        <div class="university-list" aria-label="医学部入試過去6年分の最終合格者データ">
          {acceptedUniversities.map((column) => (
            <ul>
              {column.map((result) => (
                <li>
                  <span>{result.name}</span>
                  <strong>{result.count}</strong>
                </li>
              ))}
            </ul>
          ))}
        </div>
        <p class="note">医学部入試過去6年分（2020〜2025年度）の最終合格者データです。</p>
      </div>
    </section>

    <section class="section section--soft" aria-labelledby="voices">
      <div class="content">
        <SectionHeading
          id="voices"
          label="VOICE"
          title={"医学部合格者の\nインタビュー動画"}
          subtitle="レクサスで合格した生徒たちの声"
        />
        <div class="success-grid">
          {featuredSuccessCards.map((card) => <SuccessCard card={card} />)}
        </div>
        <div class="center-actions success-more">
          <a class="button button--red" href="/top/voice/">合格体験記をもっと見る</a>
        </div>
      </div>
    </section>

    <section class="section other-voices" aria-label="その他動画、インタビュー記事">
      <div class="content">
        <h2>その他動画、インタビュー記事</h2>
        <a class="voice-banner" href="/voice/" aria-label="インタビューを全て見る">
          <img src={assets.voiceBanner} alt="合格者の声" width="1200" height="628" loading="lazy" decoding="async" />
          <span>インタビューを全て見る</span>
        </a>

        <h3>「保護者様の声」も公開中！</h3>
        <div class="parent-voice-grid">
          {parentVoices.map((voice) => (
            <article class="parent-voice-card">
              <h4>{voice.title}</h4>
              <p>{voice.body}</p>
              <a href={voice.href}>{voice.cta}</a>
            </article>
          ))}
        </div>
        <div class="quick-links">
          {quickLinks.map((link) => <a class={buttonClass(link.tone)} href={link.href}>{link.label}</a>)}
        </div>
      </div>
    </section>

    <section class="section section--selection" aria-labelledby="selection">
      <div class="content">
        <SectionHeading id="selection" label="SELECTION" title="特待生募集中" />
        <a class="selection-poster" href="/test-entry/">
          <img src={assets.selection} alt="特待生選抜テストのお知らせ" width="1024" height="1024" loading="lazy" decoding="async" />
        </a>
        <div class="center-actions">
          <a class="button button--blue" href="/test-entry/">選抜の詳細へ</a>
        </div>
      </div>
    </section>

    <section class="section representative" aria-labelledby="representative-title">
      <div class="content">
        <header class="section-heading">
          <img src={assets.jewelPattern} alt="" width="800" height="58" loading="lazy" decoding="async" />
          <p>代表よりメッセージ</p>
        </header>
        <div class="representative__grid">
          <div class="representative__portrait">
            <p>医学部合格に自信あり！</p>
            <img src={assets.representative} alt="レクサス教育センター 代表取締役 島内義仁" width="435" height="533" loading="lazy" decoding="async" />
            <strong>レクサスE.C. 代表　島内 義仁</strong>
          </div>
          <div class="representative__message">
            <h2 id="representative-title">レクサスは1992年創立、1000人以上の医学部生を輩出している医学部受験の専門塾です。</h2>
            <p>
              レクサスは、医学部受験に必要な厳しさを日々の学習に落とし込みます。授業、課題、質問、確認、生活リズムまでを途切れさせず、受験生の一年を合格へ向けて使い切ります。
            </p>
            <div class="message-list">
              {representativeMessages.map((message, i) => (
                <details class="message-item" name="representative-message" open={i === 0}>
                  <summary class="message-item__summary">
                    <h3>{message.title}</h3>
                    <span class="message-item__icon" aria-hidden="true"></span>
                  </summary>
                  <div class="message-item__body">
                    {message.body.map((para) => <p>{para}</p>)}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section pickup" aria-labelledby="pickup">
      <div class="content">
        <SectionHeading id="pickup" label="PICK UP" title="動画コンテンツ" subtitle="＼ 必ず役立つ！ ／" />
        <ul class="pickup-tags" aria-label="動画コンテンツの種類">
          <li>科目別解説</li>
          <li>医学部情報</li>
          <li>息抜き動画</li>
        </ul>
        <a class="video-poster" href="/penguin-geometry/">
          <img src={assets.penguinVideo} alt="動画視聴ページへ" width="1024" height="512" loading="lazy" decoding="async" />
          <span>動画視聴はコチラ</span>
        </a>
      </div>
    </section>

    <section class="line-support" aria-labelledby="line-support-title">
      <div class="content line-support__inner">
        <p>＼ 大好評の神サポート！ ／</p>
        <h2 id="line-support-title">↓ 無料でLINE質問対応 ↓</h2>
        <h3>英語・数学・物理・化学・生物<br />の質問に答えます。</h3>
        <a href="/top/line/" class="line-support__image">
          <img src={assets.lineSupport} alt="オンライン質問室のイメージ画像01" width="500" height="500" loading="lazy" decoding="async" />
        </a>
        <a class="button button--green" href="/top/line/">詳しくはコチラ</a>
      </div>
    </section>

    <section class="section section--soft" aria-labelledby="latest-posts">
      <div class="content">
        <SectionHeading id="latest-posts" label="NEW" title="最新投稿記事" />
        <div class="post-grid">
          {latestPosts.map((post) => <a href={post.href}>{post.label}</a>)}
        </div>
      </div>
    </section>

    <section class="section about" aria-labelledby="about">
      <div class="content content-narrow">
        <SectionHeading id="about" label="ABOUT" title={"「レクサス」は類の無い\n医学部専門予備校です"} />
        <p class="about__lead">偶然や奇跡に頼らない逆転劇。</p>
        <p class="about__mark" aria-label="鬼監理×鬼特訓">
          <span>鬼監理</span><span class="about__mark-x" aria-hidden="true">×</span><span>鬼特訓</span>
        </p>
        <p class="about__lead">の先にある、絶対の合格へ有無を言わさず連れていく。</p>
        <picture>
          <source media="(max-width: 700px)" srcset={assets.trainingTall} />
          <img class="about__hero" src={assets.trainingWide} alt="年末年始医学部必勝「鬼特訓」イメージ" width="1024" height="511" loading="lazy" decoding="async" />
        </picture>
      </div>
    </section>

    <section class="section reason" id="reason" aria-labelledby="reason-title">
      <div class="content">
        <img class="reason__divider" src={assets.jewelPattern} alt="" width="800" height="58" loading="lazy" decoding="async" />
        <p class="section-label">REASON</p>
        <h2 id="reason-title">レクサスは他と何が違うのか？</h2>

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th></th>
                <th>レクサス</th>
                <th>他の医専</th>
                <th>大手予備校</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr>
                  <th>{row.item}</th>
                  <td class="target-col">{row.lexus}</td>
                  <td>{row.medical}</td>
                  <td>{row.major}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="pillar-grid">
          {methodPillars.map((pillar) => (
            <article class="pillar-card">
              <div class="pillar-card__head">
                <img src={pillar.image} alt={pillar.imageAlt} width="234" height="260" loading="lazy" decoding="async" />
                <h3 class="pillar-card__title">{pillar.title}</h3>
              </div>
              <p class="pillar-card__subtitle">
                {pillar.subtitle.split("×").map((part, i) => (
                  <Fragment>
                    {i > 0 && <span class="pillar-card__times" aria-hidden="true">×</span>}
                    <span>{part.trim()}</span>
                  </Fragment>
                ))}
              </p>
              <p class="pillar-card__body">{pillar.body}</p>
              <p class="pillar-card__cue" aria-hidden="true">↓ 詳しくはコチラ ↓</p>
              <div class="pillar-card__actions">
                {pillar.links.map((link) => <a class="pillar-card__button" href={link.href}>{link.label}</a>)}
              </div>
            </article>
          ))}
        </div>

        <section class="growth-box" aria-labelledby="growth-title">
          <h3 id="growth-title">レクサスで芽生える力</h3>
          <ul>
            {growthItems.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      </div>
    </section>

    <section class="become-oni" aria-label="勉強の鬼になれ">
      <div class="content">
        <p>“勉強の鬼”になれ</p>
        <img src={assets.oniMascot} alt="年末年始医学部必勝「鬼特訓」イメージ" width="1024" height="687" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="section method" aria-labelledby="method">
      <div class="content">
        <SectionHeading id="method" label="METHOD" title="医学部合格メソッド" />
        <div class="method-lead">
          <h3>「厳しさ」が最短合格の絶対条件！</h3>
          <p>レクサス教育センターでは、情熱と実力を兼ね備えた講師達があなたの学習を厳しく管理し、独自の医学部専門カリキュラムで合格へ導きます。講師の指示通りに課題をこなせば、医学部に合格する実力が必ず身につきます。</p>
        </div>

        <section class="support-box" aria-labelledby="support-title">
          <h3 id="support-title">● 万全のサポート内容 ●</h3>
          <ul>
            {supportItems.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <div class="teacher-strip">
          <img src={assets.teacherMath} alt="数学科講師 小田" width="803" height="1024" loading="lazy" decoding="async" />
          <div>
            <p>思い切りやろう</p>
            <strong>2026年度 生徒募集中！<br />ぼくらの授業を体験しよう ☆</strong>
            <a class="button button--blue" href="/top/teacher/">講師紹介を見る</a>
          </div>
          <img src={assets.teacherChemistry} alt="化学/数学講師 藤橋幹夫" width="777" height="1024" loading="lazy" decoding="async" />
        </div>

        <img class="quantity-divider" src={assets.jewelPattern} alt="" width="800" height="58" loading="lazy" decoding="async" />
        <section class="quantity-box" aria-labelledby="quantity-title">
          <h3 id="quantity-title">業界トップの「質」と「量」</h3>
          <div class="metric-grid">
            {supportMetrics.map((metric) => (
              <article>
                <p>{metric.label}</p>
                <strong>{metric.value}</strong>
              </article>
            ))}
          </div>
          <div class="center-actions">
            <a class="button button--red" href="/top/results/">合格メソッドを詳しく見る</a>
          </div>
        </section>
      </div>
    </section>

    <section class="section section--courses" id="courses" aria-labelledby="courses-title">
      <div class="content">
        <SectionHeading id="courses-title" label="COURSE" title={"老舗の医学部予備校\nだから成せる\n「コース」と「カリキュラム」"} />
        <p class="courses__lead">ご自身のタイプに合った「コース選択」が合格への第一歩。</p>
        <div class="course-grid">
          {courses.map((course) => (
            <article class="course-card" style={`--card-accent: ${course.accent}`}>
              <p class="course-card__target">{course.target}</p>
              <div class="course-card__body">
                <svg class="course-card__gem" viewBox="0 0 576 512" aria-hidden="true">
                  <path d="M485.5 0L576 160H474.9L405.7 0h79.8zm-128 0l69.2 160H149.3L218.5 0h139zm-267 0h79.8l-69.2 160H0L90.5 0zM0 192h100.7l123 251.7c1.5 3.1-2.7 5.9-5 3.3L0 192zm148.2 0h279.6l-137 318.2c-1 2.4-4.5 2.4-5.5 0L148.2 192zm204.1 251.7l123-251.7H576L357.3 446.9c-2.3 2.7-6.5-.1-5-3.2z" />
                </svg>
                <h4 class="course-card__name"><a href={course.href}>{course.name}</a></h4>
                <p class="course-card__en">{course.english}</p>
                <span class="course-card__rule" aria-hidden="true"></span>
                <p class="course-card__note">{course.note}</p>
                <a class="course-card__button" href={course.href}>コースの内容を見る</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section strictness" aria-labelledby="strictness-title">
      <div class="content content-narrow">
        <SectionHeading id="strictness-title" label="STRICT" title={"厳しいレクサスだから\n最短合格を実現できます"} />
        <h3>「厳しさ」 とは？</h3>
        <p>「厳しさ」といえば、少し怖いイメージでしょうか？大丈夫！怖くありません。レクサスでは、「厳しさ」＝「成功をつかむために必要な事を与え続ける姿勢」として、医学部受験を全面的にサポートしています。</p>
        <ol>
          <li>不要な知識はそぎ落とし、分かりやすくシンプルに伝える。</li>
          <li>疑問が生じたら、その場で解決させる。</li>
          <li>できるようになるまで何度も練習させて、できるようになるところを見届ける。</li>
        </ol>
