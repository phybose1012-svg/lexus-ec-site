    left: 6%;
    top: 11%;
  }

  .lo-data-node--judge {
    right: 5%;
    top: 13%;
    animation-delay: -1.2s;
  }

  .lo-data-node--instruct {
    right: 7%;
    bottom: 10%;
    animation-delay: -2.4s;
  }

  .lo-data-node--improve {
    left: 7%;
    bottom: 10%;
    animation-delay: -3.6s;
  }

  .lo-packet {
    position: absolute;
    z-index: 5;
    width: 14px;
    height: 14px;
    border: 1px solid rgb(255 255 255 / 82%);
    background: var(--lo-red);
