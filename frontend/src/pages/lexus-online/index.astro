    margin: 0;
    color: var(--lo-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.2vw, 3.2rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.28;
  }

  .lo-system-visual {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    width: min(100%, 640px);
    min-width: 0;
    margin: 34px auto 0;
    perspective: 1200px;
    transform: rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
    transform-style: preserve-3d;
    transition: transform 180ms ease;
  }

  .lo-system-scene {
    position: relative;
    width: min(100%, 560px);
    aspect-ratio: 1;
    margin-inline: auto;
    overflow: hidden;
    border: 1px solid rgb(17 17 17 / 11%);
    background:
      linear-gradient(135deg, rgb(255 255 255 / 82%), rgb(255 253 248 / 70%)),
      repeating-linear-gradient(90deg, rgb(196 154 45 / 8%) 0 1px, transparent 1px 34px),
      repeating-linear-gradient(0deg, rgb(17 17 17 / 4%) 0 1px, transparent 1px 34px);
    box-shadow: 0 22px 64px rgb(57 38 12 / 13%);
  }

  .lo-system-scene::before,
  .lo-system-scene::after {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgb(196 154 45 / 28%);
    pointer-events: none;
  }

  .lo-system-scene::after {
    inset: 38px;
    border-color: rgb(143 29 29 / 16%);
  }

  .lo-system-frame {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 66%;
