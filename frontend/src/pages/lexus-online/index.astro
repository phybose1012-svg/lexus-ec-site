  .lo-system-core span,
  .lo-data-node span,
  .lo-console-panel span {
    color: var(--lo-gold-dark);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .lo-system-core strong {
    color: var(--lo-red);
