  }

  .lo-packet--three {
    background: #17110f;
    box-shadow: 0 0 22px rgb(17 17 17 / 28%);
    animation-delay: -5.2s;
  }

  .lo-console-panel {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 22px;
    z-index: 6;
    display: grid;
    grid-template-columns: 130px 1fr 0.7fr 0.48fr;
    gap: 10px;
    align-items: center;
    min-height: 44px;
    border: 1px solid rgb(17 17 17 / 12%);
    background: rgb(255 255 255 / 86%);
    padding: 11px 14px;
  }

  .lo-console-panel i {
    position: relative;
    display: block;
    height: 8px;
    overflow: hidden;
    background: rgb(17 17 17 / 8%);
  }

  .lo-console-panel i::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--lo-gold), var(--lo-red));
    animation: loConsoleScan 3.2s ease-in-out infinite;
  }

  .lo-console-panel i:nth-child(3)::before {
    animation-delay: -1s;
  }

  .lo-console-panel i:nth-child(4)::before {
    animation-delay: -1.8s;
  }

  .lo-operation-map {
    position: relative;
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    width: 100%;
    margin-top: 0;
    border: 1px solid rgb(17 17 17 / 14%);
    background: #fff;
    overflow: hidden;
  }

  .lo-operation-map::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    z-index: 0;
    width: 22%;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--lo-gold), var(--lo-red), transparent);
    animation: loFlowSweep 6s ease-in-out infinite;
