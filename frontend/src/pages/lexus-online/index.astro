    animation: loFrameRotate 28s linear infinite;
  }

  .lo-system-frame--two {
    width: 48%;
    border-color: rgb(143 29 29 / 22%);
    animation: loFrameCounterRotate 22s linear infinite;
  }

  .lo-system-axis {
    position: absolute;
    background: linear-gradient(90deg, transparent, rgb(196 154 45 / 44%), transparent);
    pointer-events: none;
  }

  .lo-system-axis--x {
    left: 12%;
    right: 12%;
    top: 50%;
    height: 1px;
  }

  .lo-system-axis--y {
    left: 50%;
    top: 12%;
    bottom: 12%;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgb(143 29 29 / 34%), transparent);
  }

  .lo-system-core {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 4;
    display: grid;
    width: 40%;
    aspect-ratio: 1;
    place-content: center;
    gap: 8px;
    padding: 28px;
    border: 1px solid rgb(196 154 45 / 54%);
    background: rgb(255 255 255 / 92%);
    box-shadow:
      0 22px 54px rgb(196 154 45 / 18%),
      inset 0 0 0 10px rgb(246 242 234 / 70%);
