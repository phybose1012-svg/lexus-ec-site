  .lo-data-node {
    position: absolute;
    z-index: 3;
    display: grid;
    gap: 5px;
    width: 146px;
    min-height: 94px;
    padding: 14px 16px;
    border: 1px solid rgb(17 17 17 / 12%);
    background: rgb(255 255 255 / 88%);
    box-shadow: 0 16px 38px rgb(57 38 12 / 11%);
    animation: loNodeFloat 6.2s ease-in-out infinite;
  }

  .lo-data-node::before {
    content: "";
    position: absolute;
    left: 14px;
    top: -5px;
    width: 10px;
    height: 10px;
    background: var(--lo-gold);
    transform: rotate(45deg);
