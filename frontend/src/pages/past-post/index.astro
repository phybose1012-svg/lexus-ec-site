  { name: "広島大学", kana: "ひろしま", type: "kokuritsu" },
  { name: "福井大学", kana: "ふくい", type: "kokuritsu" },
  { name: "福島県立医科大学", kana: "ふくしまけんりついか", type: "kokuritsu" },
  { name: "北海道大学", kana: "ほっかいどう", type: "kokuritsu" },
  { name: "三重大学", kana: "みえ", type: "kokuritsu" },
  { name: "宮崎大学", kana: "みやざき", type: "kokuritsu" },
  { name: "山形大学", kana: "やまがた", type: "kokuritsu" },
  { name: "山口大学", kana: "やまぐち", type: "kokuritsu" },
  { name: "山梨大学", kana: "やまなし", type: "kokuritsu" },
  { name: "横浜市立大学", kana: "よこはましりつ", type: "kokuritsu" },
  { name: "琉球大学", kana: "りゅうきゅう", type: "kokuritsu" },
  { name: "和歌山県立医科大学", kana: "わかやまけんりついか", type: "kokuritsu" },
];

const ROWS = [
  { label: "ア行", re: /^[あ-おゔ]/ },
  { label: "カ行", re: /^[か-ごゕゖ]/ },
  { label: "サ行", re: /^[さ-ぞ]/ },
  { label: "タ行", re: /^[た-ど]/ },
  { label: "ナ行", re: /^[な-の]/ },
  { label: "ハ行", re: /^[は-ぽ]/ },
  { label: "マ行", re: /^[ま-も]/ },
  { label: "ヤ・ラ・ワ行", re: /^[や-ん]/ },
];
const rowFor = (kana: string) => ROWS.find((r) => r.re.test(kana))?.label ?? "ヤ・ラ・ワ行";

// タイトル中の大学名で記事を割り当てる（長い別名から先に照合）。
const matchers = UNIS.flatMap((u) => [u.name, ...(u.aliases ?? [])].map((a) => ({ alias: a, uni: u }))).sort(
  (a, b) => b.alias.length - a.alias.length,
);
const uniFor = (title: string) => matchers.find((m) => title.includes(m.alias))?.uni ?? null;

// 旧サイトにのみ残っている未移行記事（リンク切れ防止のため絶対URLで温存）。
const EXTERNAL: { uni: string | null; title: string; url: string }[] = [
  { uni: "埼玉医科大学", title: "埼玉医科大学(後期)補欠の繰り上げは何番まで？過去10年のデータと対策", url: "https://lexus-ec.com/saitama-med-late-waitlist/" },
  { uni: "埼玉医科大学", title: "埼玉医科大学 医学部の繰り上げ合格【2026年度版】｜いつ連絡が来る？何位まで回る？", url: "https://lexus-ec.com/saitama-med-waitlist-guide/" },
  { uni: "日本大学", title: "日大医学部の補欠繰り上げはいつまで？過去データから見る合格ライン", url: "https://lexus-ec.com/nihonn-waitlist-guide/" },
  { uni: "金沢医科大学", title: "金沢医科大学の補欠合格・繰り上げ順位の推移｜2026年入試の動向分析", url: "https://lexus-ec.com/kanazawa-med-waitlist-guide/" },
  { uni: "杏林大学", title: "杏林大学 医学部の繰り上げ合格【2026年度版】｜補欠順位は何位まで回る？過去10年データ", url: "https://lexus-ec.com/kyorin-medical-waiting-list-success/" },
  { uni: "東京医科大学", title: "東京医科大学 医学部の繰り上げ合格【2026年度版】｜補欠何番まで回る？", url: "https://lexus-ec.com/tokyo-med-waitlist-status_2026/" },
  { uni: "北里大学", title: "北里大学 医学部の繰り上げ合格【2026年度版】｜補欠順位は何位まで回る？過去10年データ", url: "https://lexus-ec.com/kitasato-medicine-waitlist-success/" },
  { uni: "岩手医科大学", title: "岩手医科大学｜2025年度入試｜英語の過去問分析｜合格を掴む時間配分と対策法", url: "https://lexus-ec.com/iwate-med-english-2025-analysis/" },
  { uni: "岩手医科大学", title: "岩手医科大学｜2025年度入試｜数学の過去問分析｜合格を掴む時間配分と対策法", url: "https://lexus-ec.com/iwate-med-math-2025-analysis/" },
  { uni: "岩手医科大学", title: "岩手医科大学｜2025年度入試｜化学の過去問分析｜合格を掴む時間配分と対策法", url: "https://lexus-ec.com/iwate-med-chemi-2025-analysis/" },
  { uni: "岩手医科大学", title: "岩手医科大学｜2025年度入試｜物理の過去問分析｜合格を掴む時間配分と対策法", url: "https://lexus-ec.com/iwate-med-physic-2025-analysis/" },
  { uni: "岩手医科大学", title: "岩手医科大学｜2025年度入試｜生物の過去問分析｜合格を掴む時間配分と対策法", url: "https://lexus-ec.com/iwate-med-biology-2025-analysis/" },
  { uni: null, title: "【医学部受験】「不合格」に沈む我が子へ。親が今夜掛けるべき言葉と、やってはいけないNG行動", url: "https://lexus-ec.com/oya-to-kodomo/" },
  { uni: null, title: "【医学部受験】逆転合格への予備校選び｜もう一年を無駄にしないために。", url: "https://lexus-ec.com/yobikou-change/" },
];

type Entry = { title: string; href: string; date: string; external?: boolean };
const displayTitle = (t: string) => t.replace(/｜医学部受験で役立つ情報$/, "").trim();

const byUni = new Map<string, Entry[]>();
const columns: Entry[] = [];
for (const p of migratedPosts) {
  const entry: Entry = { title: displayTitle(p.title), href: p.path, date: (p.date || "").slice(0, 10) };
  const uni = uniFor(p.title);
  if (uni) {
    if (!byUni.has(uni.name)) byUni.set(uni.name, []);
    byUni.get(uni.name)!.push(entry);
  } else {
    columns.push(entry);
  }
}
for (const e of EXTERNAL) {
  const entry: Entry = { title: e.title, href: e.url, date: "", external: true };
  if (e.uni) {
    if (!byUni.has(e.uni)) byUni.set(e.uni, []);
    byUni.get(e.uni)!.push(entry);
  } else {
    columns.push(entry);
  }
}
byUni.forEach((list) => list.sort((a, b) => (a.date < b.date ? 1 : -1)));
columns.sort((a, b) => (a.date < b.date ? 1 : -1));

const collator = new Intl.Collator("ja");
const groupTabs = (type: "shiritsu" | "kokuritsu") => {
  const unis = UNIS.filter((u) => u.type === type && byUni.has(u.name)).sort((a, b) => collator.compare(a.kana, b.kana));
  return ROWS.map((row) => ({
    row: row.label,
    unis: unis.filter((u) => rowFor(u.kana) === row.label).map((u) => ({ name: u.name, posts: byUni.get(u.name)! })),
  })).filter((g) => g.unis.length > 0);
};
const shiritsuTabs = groupTabs("shiritsu");
const kokuritsuTabs = groupTabs("kokuritsu");
const totalCount = migratedPosts.length + EXTERNAL.length;

const guideImage = "/assets/legacy/wp-content/uploads/2025/11/PR用見本2026-1024x1024.jpg";
const logoStrip = "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png";
---

<BaseLayout
  title="投稿記事一覧｜医学部受験情報｜国公立＋私立医学部 - 医学部予備校 レクサス E.C."
  description={`国公立・私立 全国の医学部入試情報アーカイブ。二次試験・共通テストの傾向、面接対策、繰り上げ合格情報など${totalCount}本の記事を大学別・五十音順に整理しています。`}
  canonical="https://lexus-ec.com/past-post/"
  ogImage={seo.ogImage}
>
  <SiteHeader />
  <main class="legacy-article-page">
    <section class="legacy-article-hero">
      <img class="page-head__strip" src={logoStrip} alt="" width="800" height="58" decoding="async" />
      <p class="page-head__label">ARCHIVE</p>
      <h1 class="page-head__title">国公立＋私立 全国の医学部入試情報</h1>
      <span class="page-head__rule" aria-hidden="true"></span>
      <p class="ppa-lead">
        二次試験・共通テストの傾向と対策、面接・志望理由のヒント、繰り上げ合格情報など、全{totalCount}本の記事を大学別に整理しました。
      </p>
    </section>

    <section class="fixed-page fixed-page--unstack fixed-page--directory legacy-article-section">
      <div class="content fixed-source legacy-article-body">
        {[
          { key: "shiritsu", label: "PRIVATE", heading: "私立医学部の記事一覧", tabs: shiritsuTabs, tone: "lap-sec--a" },
          { key: "kokuritsu", label: "NATIONAL", heading: "国公立医学部の記事一覧", tabs: kokuritsuTabs, tone: "lap-sec--b" },
        ].map((sec, i) => (
          <section class={`lap-sec ${sec.tone}`}>
            <div class="lap-sechead">
              {i > 0 && <img class="lap-sechead__strip" src={logoStrip} alt="" aria-hidden="true" />}
              <p class="lap-sechead__label">{sec.label}</p>
            </div>
            <h2>{sec.heading}</h2>
            <div class="dir-tabs" role="tablist">
              {sec.tabs.map((g, j) => (
                <button type="button" class={`dir-tab${j === 0 ? " is-active" : ""}`} role="tab" aria-selected={j === 0 ? "true" : "false"} data-tab={`${sec.key}-${j}`}>
                  {g.row}
                </button>
              ))}
            </div>
            <div class="dir-tab-panels">
              {sec.tabs.map((g, j) => (
                <div class="dir-tab-panel ppa-panel" data-panel={`${sec.key}-${j}`} hidden={j !== 0}>
                  {g.unis.map((u) => (
                    <div class="ppa-uni">
                      <h3 class="ppa-uni__name">{u.name}</h3>
                      <ul class="lap-news ppa-list">
                        {u.posts.map((p) => (
                          <li>
                            <a href={p.href} rel={p.external ? "noopener" : undefined}>{p.title}</a>
                            {p.date && <time>{p.date}</time>}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </section>
        ))}

        <section class="lap-sec lap-sec--a">
          <div class="lap-sechead">
            <img class="lap-sechead__strip" src={logoStrip} alt="" aria-hidden="true" />
            <p class="lap-sechead__label">COLUMN</p>
          </div>
          <h2>医学部受験コラム・全般情報</h2>
          <ul class="lap-news ppa-list">
            {columns.map((p) => (
              <li>
                <a href={p.href} rel={p.external ? "noopener" : undefined}>{p.title}</a>
                {p.date && <time>{p.date}</time>}
              </li>
            ))}
          </ul>
        </section>
      </div>
    </section>

    <section class="access-guide legacy-guide">
      <div class="content access-guide__grid">
        <img src={guideImage} alt="医学部合格読本 2026" width="800" height="800" loading="lazy" decoding="async" />
        <div>
          <h3>資料請求した方へプレゼント</h3>
          <h2>レクサスのプロ講師と、 レクサスの卒業生が、共同で作りました。</h2>
          <p>医学部入試の情報と、レクサスの学習環境を確認したい方は資料請求または個別相談をご利用ください。</p>
          <div class="fixed-hero__actions">
            <a class="button button--red" href="/request-documents/">資料請求</a>
            <a class="button button--blue" href="/reservation/">個別相談</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />

  <script is:inline>
    document.querySelectorAll(".dir-tabs").forEach((bar) => {
      bar.querySelectorAll(".dir-tab").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.getAttribute("data-tab");
          bar.querySelectorAll(".dir-tab").forEach((b) => {
            b.classList.toggle("is-active", b === btn);
            b.setAttribute("aria-selected", b === btn ? "true" : "false");
          });
          const wrap = bar.nextElementSibling;
          if (!wrap) return;
          wrap.querySelectorAll(".dir-tab-panel").forEach((p) => {
            p.hidden = p.getAttribute("data-panel") !== key;
          });
        });
      });
    });
  </script>
</BaseLayout>
