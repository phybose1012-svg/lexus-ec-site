---
import SiteLayout from "../../layouts/SiteLayout.astro";

const title = "医学部英語の長文読解｜「丁寧さ」が「速さ」を生む“鬼特訓”カリキュラム - 医学部予備校｜LEXUS E.C.（レクサス教育センター）";
const description =
  "医学部合格への英語力は「再現と確認」で決まる。レクサス教育センターの英語「鬼特訓」は、予習・授業・夜間課題・翌朝テストの徹底サイクルで、短期記憶を入試で使える長期記憶へ昇華させます。「分かったつもり」を許さない指導の詳細はこちら。";
const canonical = "https://lexus-ec.com/medical-english-training/";

const assets = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  oniTraining: "/illustrations/characters/yuki-sensei-cheer.png",
  oniKanri: "/assets/legacy/wp-content/uploads/2026/01/鬼-指示出し-e1768024719806.png",
  flowReading: "/assets/legacy/wp-content/uploads/2026/01/英語-鬼特訓の流れ長文-1536x1172.jpg",
  flowGrammar: "/assets/legacy/wp-content/uploads/2026/01/英語-鬼特訓の流れ文法-1536x1134.jpg",
  teacher: "/assets/legacy/wp-content/uploads/2025/02/英語-青野Ｔ-e1739986833667-774x1024.jpg",
};

const readingSteps = [
  {
    title: "予習：限界まで考え抜く",
    body: "「何が分からないか」を明確にします。安易に質問するのではなく、自分の力で限界まで悩み抜く時間が、読解力を強化します。",
  },
  {
    title: "授業：あいまいな点を解決",
    body: "分からない部分は当然として、「分かったつもり」でいた箇所も正確に理解し直します。",
  },
  {
    title: "夜間トレーニング：復習課題",
    body: "授業で扱った長文をすべて作り変えた問題に取り組みます。理解した内容を「再現」できるか確認し、疑問点はその場で即質問します。",
  },
  {
    title: "毎日テスト",
    body: "次回の授業日の朝、理解した内容をテストで「再現」します。合格点を取るまで徹底的に繰り返します。",
  },
];

const grammarSteps = [
  {
    title: "予習：分からない問題の選別",
    body: "文法では、授業前に調べる・質問する必要はありません。分かる問題と分からない問題をはっきりさせ、授業で解決するための準備に集中します。",
  },
  {
    title: "授業：完全解決と修正",
    body: "予習で不明だった点を完全に解決します。「分かったつもり」でいた知識も修正し、正確な文法知識を入れ直します。",
  },
  {
    title: "夜間トレーニング：類題演習",
    body: "学習した内容の類題に取り組み、理解を確実なものにします。疑問はその場ですぐ質問し、翌日に残しません。",
  },
  {
    title: "毎日テスト：再現確認",
    body: "理解した内容をきちんと再現できるか、翌朝のテストでチェックします。",
  },
  {
    title: "不合格なら呼び出し再指導",
    body: "合格点に達しない場合は、確実に自分のものにするまで指導します。再テストは同じ問題ではなく、注目すべき点を確認できるよう作り変えます。",
    alert: true,
  },
];
---

<SiteLayout title={title} description={description} canonical={canonical} ogImage={assets.oniTraining}>
  <main class="english-training">
    <section class="eng-page-head" aria-labelledby="english-training-title">
      <img class="eng-logo-strip" src={assets.logoStrip} alt="" width="800" height="58" fetchpriority="high" decoding="async" />
      <p class="eng-page-head__label">ABOUT</p>
      <h1 id="english-training-title">医学部英語を完全攻略する<br />「再現と確認」の鬼特訓</h1>
      <span class="eng-rule" aria-hidden="true"></span>
    </section>

    <section class="eng-mascot" aria-label="英語 鬼特訓">
      <img src={assets.oniTraining} alt="鬼特訓イメージキャラクター" width="234" height="260" fetchpriority="high" decoding="async" />
    </section>

    <section class="eng-system" aria-labelledby="eng-system-title">
      <p class="eng-system__sub">記憶を昇華させるシステム</p>
      <h2 id="eng-system-title">英語 “鬼特訓”</h2>
      <span class="eng-rule eng-rule--short" aria-hidden="true"></span>
      <div class="eng-intro-panel">
        <p>
          英語学習の鍵は、<strong>「再現と確認」</strong>にあります。<br />
          授業で理解した内容を、形を変えた問題で自力で再現する。<br />
          この繰り返しにより、短期記憶を中期、そして入試で使える長期記憶へと昇華させます。
        </p>
      </div>
    </section>

    <section class="eng-block" aria-labelledby="reading-steps-title">
      <h2 class="eng-section-label" id="reading-steps-title">長文読解<br />6ステップ</h2>
      <div class="eng-step-list">
        {readingSteps.slice(0, 3).map((step, index) => (
          <article class="eng-step">
            <span class="eng-step__number">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="eng-correction" aria-label="添削ステップ">
        <article class="eng-correction__card eng-correction__card--red">
          <span>04</span>
          <h3>自己添削（赤ペン）</h3>
          <p>解答を見ながら、まずは自分でチェック。自分の答案を客観視します。</p>
        </article>
        <article class="eng-correction__card eng-correction__card--blue">
          <span>05</span>
          <h3>講師添削（青ペン）</h3>
          <p>生徒のチェックをさらに講師が監理。「本当に理解できているか」を口頭指導と共に青ペンで添削します。</p>
        </article>
      </div>

      <article class="eng-step">
        <span class="eng-step__number">06</span>
        <div>
          <h3>{readingSteps[3].title}</h3>
          <p>{readingSteps[3].body}</p>
        </div>
      </article>
    </section>

    <section class="eng-image-section" aria-labelledby="reading-flow-title">
      <img class="eng-logo-strip" src={assets.logoStrip} alt="" width="800" height="58" loading="lazy" decoding="async" />
      <h2 id="reading-flow-title">学習の流れ（長文読解）</h2>
      <a href="/assets/legacy/wp-content/uploads/2026/01/英語-鬼特訓の流れ長文.jpg" aria-label="英語 長文読解 鬼特訓の流れを拡大表示">
        <img src={assets.flowReading} alt="英語（長文）鬼特訓の流れ" width="1536" height="1172" loading="lazy" decoding="async" />
      </a>
    </section>

    <section class="eng-message" aria-labelledby="teacher-message-title">
      <img class="eng-logo-strip" src={assets.logoStrip} alt="" width="800" height="58" loading="lazy" decoding="async" />
      <h2 id="teacher-message-title">講師からメッセージ</h2>
      <div class="eng-message__grid">
        <article class="eng-philosophy">
          <h3>急がば回れ。それが速読の鍵。</h3>
          <p>
            入試問題の大半を読解問題が占めます。短い時間で大量の文章を読む必要があるため、「速読力を身につけるコツ」を多くの受験生が求めています。そして、多くの受験生が「速く読む」ことができずに、「ザツに読む」習慣を身につけてしまっています。
          </p>
          <p>
            レクサスの授業では、ゆっくり丁寧に読む方法をまず教えます。復習課題で自力で丁寧に解けるようにし、テストでさらに丁寧さを求めます。「速さ」とは「丁寧さ」を追求したその先にある「慣れ」として身につく能力です。
          </p>
        </article>
        <figure class="eng-teacher">
          <img src={assets.teacher} alt="英語講師 青野圭一" width="774" height="1024" loading="lazy" decoding="async" />
          <figcaption>レクサスE.C. 英語講師<br />青野 圭一</figcaption>
        </figure>
      </div>
      <nav class="eng-link-row" aria-label="関連ページ">
        <a class="button button--blue" href="/top/teacher/">講師紹介</a>
        <a class="button button--green" href="/top/voice/">合格体験記</a>
        <a class="button button--red" href="/top/history/">理念と沿革</a>
      </nav>
    </section>

    <section class="eng-block" aria-labelledby="grammar-steps-title">
      <img class="eng-side-mascot" src={assets.oniKanri} alt="鬼監理イメージキャラクター" width="219" height="251" loading="lazy" decoding="async" />
      <h2 class="eng-section-label" id="grammar-steps-title">文法理解<br />5ステップ</h2>
      <div class="eng-step-list">
        {grammarSteps.map((step, index) => (
          <article class={`eng-step${step.alert ? " eng-step--alert" : ""}`}>
            <span class="eng-step__number">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </article>
        ))}
      </div>

      <h2 class="eng-section-label eng-section-label--flow">記憶の定着フロー</h2>
      <div class="eng-intro-panel eng-intro-panel--navy">
        <p>
          <strong>単語・熟語も徹底フォロー</strong><br />
          毎週出題範囲を定めたテストを実施。「覚える量」と「時間」を管理し、合格点に達しない場合は再テストを行います。
        </p>
      </div>
      <div class="eng-memory-flow" aria-label="記憶の定着フロー">
        <div><span>授業・毎日テスト</span><strong>短期記憶</strong></div>
        <b aria-hidden="true">▶</b>
        <div><span>週一テスト（土曜）</span><strong>中期記憶</strong></div>
        <b aria-hidden="true">▶</b>
        <div><span>月一テスト・模試</span><strong>長期記憶</strong></div>
      </div>
      <p class="eng-note">※週一テストでは、入試に出題されるパターンに特化した実践的な問題（長文・文法）を解きます。</p>
    </section>

    <section class="eng-image-section" aria-labelledby="grammar-flow-title">
      <img class="eng-logo-strip" src={assets.logoStrip} alt="" width="800" height="58" loading="lazy" decoding="async" />
      <h2 id="grammar-flow-title">学習の流れ（文法）</h2>
      <a href="/assets/legacy/wp-content/uploads/2026/01/英語-鬼特訓の流れ文法.jpg" aria-label="英語 文法 鬼特訓の流れを拡大表示">
        <img src={assets.flowGrammar} alt="英語（文法）鬼特訓の流れ" width="1536" height="1134" loading="lazy" decoding="async" />
      </a>
    </section>

    <section class="eng-related" aria-label="鬼監理と鬼特訓">
      <article>
        <img src={assets.oniKanri} alt="" width="219" height="251" loading="lazy" decoding="async" />
        <p class="eng-related__title">鬼監理</p>
        <p class="eng-related__catch">プロ講師の眼力<br />×<br />医学部専門AIのデータ分析</p>
        <p>副代表クラスのトップ講師陣が担任となり、学習進捗、得意不得意、成長速度を監理。学習から「無駄」と「甘え」を排除します。</p>
        <a class="button button--blue" href="/study-support-system/">“鬼監理”を詳しく見る</a>
      </article>
      <article>
        <img src={assets.oniTraining} alt="" width="234" height="260" loading="lazy" decoding="async" />
        <p class="eng-related__title">鬼特訓</p>
        <p class="eng-related__catch">プロ講師の質問対応<br />×<br />課題の具体化</p>
        <p>授業後の自習時間を濃厚な特訓時間へ。課題提示、即時添削、追加課題で、夕方以降の学習密度を高めます。</p>
        <a class="button button--red" href="/medical-math-training/">数学の“鬼特訓”も詳しく見る</a>
      </article>
    </section>

    <section class="eng-contact" aria-labelledby="eng-contact-title">
      <img class="eng-logo-strip" src={assets.logoStrip} alt="" width="800" height="58" loading="lazy" decoding="async" />
      <h2 id="eng-contact-title">まずは、お問合せください。</h2>
      <p>医学部英語をどう伸ばすべきか、現在地から具体的に整理します。</p>
      <div class="eng-link-row">
        <a class="button button--red" href="/request-documents/">資料請求</a>
        <a class="button button--blue" href="/reservation/">個別説明会</a>
        <a class="button button--light" href="/top/contact/">お問い合わせ</a>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .english-training {
    --eng-bg: #f9f8f6;
    --eng-text: #2c2c2c;
    --eng-navy: #182638;
    --eng-gold: #a88d57;
    --eng-red: #7f1d1d;
    --eng-blue: #1e3a8a;
    background: var(--eng-bg);
    color: var(--eng-text);
  }

  .eng-page-head,
  .eng-system,
  .eng-block,
  .eng-image-section,
  .eng-message,
  .eng-related,
  .eng-contact {
    width: min(1000px, calc(100% - 40px));
    margin-inline: auto;
  }

  .eng-page-head {
    display: grid;
    justify-items: center;
    padding-block: 32px 6px;
    text-align: center;
  }

  .eng-logo-strip {
    width: min(800px, 100%);
    height: auto;
    margin-inline: auto;
    opacity: 0.95;
  }

  .eng-page-head__label {
    margin: 20px 0 14px;
    color: var(--eng-gold);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
  }

  .eng-page-head h1 {
    margin: 0;
    color: #1e1a18;
    font-family: var(--font-serif);
    font-size: 2.35rem;
    font-weight: 700;
    line-height: 1.55;
    text-align: center;
  }

  .eng-rule {
    display: block;
    width: min(620px, 86%);
    height: 1px;
    margin-top: 22px;
    background: var(--eng-gold);
  }

  .eng-rule--short {
    width: 60px;
    height: 3px;
    margin: 12px auto 28px;
  }

  .eng-mascot {
    display: grid;
    justify-items: center;
    width: min(1000px, calc(100% - 40px));
    margin: 8px auto 24px;
  }

  .eng-mascot img {
    width: 234px;
    height: auto;
  }

  .eng-system {
    padding-block: 8px 28px;
    text-align: center;
  }

  .eng-system__sub {
    margin: 0 0 6px;
    color: var(--eng-red);
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 800;
  }

  .eng-system h2,
  .eng-image-section h2,
  .eng-message h2,
  .eng-contact h2 {
    margin: 0;
    color: var(--eng-navy);
    font-family: var(--font-serif);
    font-size: 2.15rem;
    font-weight: 800;
    line-height: 1.45;
    text-align: center;
  }

  .eng-intro-panel {
    border-left: 5px solid var(--eng-gold);
    background: #fff;
    padding: 28px 30px;
    box-shadow: 0 5px 20px rgb(0 0 0 / 3%);
    text-align: center;
  }

  .eng-intro-panel--navy {
    border-left-color: var(--eng-navy);
  }

  .eng-intro-panel p,
  .eng-note {
    margin: 0;
    font-size: 1rem;
    line-height: 1.9;
  }

  .eng-intro-panel strong {
    color: var(--eng-gold);
  }

  .eng-block {
    padding-block: 24px 44px;
  }

  .eng-section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin: 34px 0 34px;
    border-radius: 4px;
    background: #fff;
    padding: 15px 22px;
    color: var(--eng-navy);
    font-family: var(--font-serif);
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1.45;
    text-align: center;
    box-shadow: 0 2px 10px rgb(0 0 0 / 2%);
  }

  .eng-section-label::before,
  .eng-section-label::after {
    content: "";
    width: 40px;
    height: 1px;
    background: var(--eng-gold);
  }

  .eng-section-label--flow {
    margin-top: 58px;
  }

  .eng-step-list {
    display: grid;
    gap: 20px;
  }

  .eng-step {
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr);
    overflow: hidden;
    border-left: 5px solid var(--eng-navy);
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 5px 15px rgb(0 0 0 / 5%);
  }

  .eng-step--alert {
    border-left-color: var(--eng-red);
    background: #fffafb;
  }

  .eng-step__number {
    display: grid;
    place-items: center;
    background: var(--eng-navy);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.45rem;
    font-weight: 800;
  }

  .eng-step--alert .eng-step__number {
    background: var(--eng-red);
  }

  .eng-step div {
    padding: 20px 25px;
  }

  .eng-step h3,
  .eng-correction h3,
  .eng-philosophy h3 {
    margin: 0 0 10px;
    color: var(--eng-navy);
    font-size: 1.18rem;
    font-weight: 800;
    line-height: 1.55;
  }

  .eng-step--alert h3,
  .eng-correction__card--red h3 {
    color: var(--eng-red);
  }

  .eng-step p,
  .eng-correction p,
  .eng-philosophy p,
  .eng-related p,
  .eng-contact p {
    margin: 0;
    color: #444;
    font-size: 0.96rem;
    line-height: 1.9;
  }

  .eng-correction {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-block: 22px;
  }

  .eng-correction__card {
    border-top: 4px solid var(--eng-red);
    border-radius: 4px;
    background: #fff;
    padding: 24px;
    text-align: center;
    box-shadow: 0 5px 15px rgb(0 0 0 / 5%);
  }

  .eng-correction__card--blue {
    border-top-color: var(--eng-blue);
  }

  .eng-correction__card span {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    margin: 0 auto 12px;
    border-radius: 4px;
    background: var(--eng-red);
    color: #fff;
    font-family: var(--font-serif);
    font-weight: 800;
  }

  .eng-correction__card--blue span {
    background: var(--eng-blue);
  }

  .eng-correction__card--blue h3 {
    color: var(--eng-blue);
  }

  .eng-image-section,
  .eng-message,
  .eng-contact {
    display: grid;
    justify-items: center;
    gap: 26px;
    padding-block: 36px 48px;
  }

  .eng-image-section a {
    display: block;
    width: 100%;
  }

  .eng-image-section a img {
    display: block;
    width: min(920px, 100%);
    height: auto;
    margin-inline: auto;
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 14px 34px rgb(55 41 20 / 11%);
  }

  .eng-message__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 250px;
    gap: 30px;
    align-items: start;
    width: 100%;
  }

  .eng-philosophy {
    border-top: 4px solid var(--eng-gold);
    background: #fff;
    padding: 36px 38px;
  }

  .eng-philosophy p + p {
    margin-top: 16px;
  }

  .eng-teacher {
    margin: 0;
    text-align: center;
  }

  .eng-teacher img {
    width: min(230px, 100%);
    height: auto;
    border-radius: 4px;
    background: #fff;
  }

  .eng-teacher figcaption {
    margin-top: 12px;
    color: #3b3530;
    font-weight: 800;
    line-height: 1.7;
  }

  .eng-link-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    width: 100%;
  }

  .eng-link-row .button,
  .eng-related .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--site-button-min-width);
    min-height: var(--site-button-min-height);
    border: var(--site-button-border);
    border-radius: var(--site-button-radius);
    padding: var(--site-button-padding);
    font-size: var(--site-button-font-size);
    font-weight: var(--site-button-font-weight);
    line-height: var(--site-button-line-height);
    text-decoration: none;
  }

  .eng-side-mascot {
    display: block;
    width: 170px;
    height: auto;
    margin: 0 auto -10px;
  }

  .eng-memory-flow {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 10px;
    align-items: center;
    margin-top: 22px;
    border: 1px solid rgb(0 0 0 / 5%);
