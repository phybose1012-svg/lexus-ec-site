---
import admissionInfoPosts from "../../data/generated/admissionInfoPosts.json";
import interviewPrepPosts from "../../data/generated/interviewPrepPosts.json";
import universityStrategyPosts from "../../data/generated/universityStrategyPosts.json";
import voiceInterviewPosts from "../../data/generated/voiceInterviewPosts.json";
import {
  displayPostTitle,
  getTaxonomyStats,
  groupArticlesForDirectory,
} from "../../data/articleTaxonomy.js";
import {
  buildArticleDirectoryImageIndex,
  resolveArticleDirectoryImage,
} from "../../data/articleDirectoryImages.js";
import SiteLayout from "../../layouts/SiteLayout.astro";

type Post = {
  path: string;
  title: string;
  displayTitle?: string;
  displayTitleLines?: string[];
  description?: string;
  date?: string;
  modified?: string;
  categories?: string[];
  tags?: string[];
  template: string;
  heroImage?: { src?: string; alt?: string } | null;
};

const allPosts = [
  ...(admissionInfoPosts as Post[]),
  ...(universityStrategyPosts as Post[]),
  ...(interviewPrepPosts as Post[]),
  ...(voiceInterviewPosts as Post[]),
].sort((a, b) => (b.date || "").localeCompare(a.date || ""));

const idFor = (value: string) =>
  value
    .normalize("NFKC")
    .toLowerCase()
    .replace(/\s+/g, "-")
    .replace(/[^\p{Letter}\p{Number}-]+/gu, "")
    .replace(/^-|-$/g, "") || "category";

const directoryGroups = groupArticlesForDirectory(allPosts);
const taxonomyStats = getTaxonomyStats(allPosts);
const directoryImageIndex = buildArticleDirectoryImageIndex(allPosts);
const totalCount = allPosts.length;
const canonical = "https://lexus-ec.com/article-directory/";
---

<SiteLayout
  title="投稿記事一覧｜LEXUS E.C."
  description="LEXUS E.C. の投稿記事を、大学別入試情報・大学別対策・面接対策・合格者インタビューなどの新しい分類で確認できます。"
  canonical={canonical}
>
  <main class="article-directory">
    <section class="article-directory__hero">
      <div class="article-directory__container">
        <p class="article-directory__eyebrow">POST DIRECTORY</p>
        <h1>投稿記事一覧</h1>
        <p>
          既存URLを保ったまま、記事の役割が見えるように再分類しました。
          大分類・小分類・年度・地域・試験区分から、必要な記事へ直接移動できます。
        </p>
        <dl class="article-directory__summary">
          <div>
            <dt>総記事数</dt>
            <dd>{totalCount}</dd>
          </div>
          {directoryGroups.map((group) => (
            <div>
              <dt>{group.label}</dt>
              <dd>{group.posts.length}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <nav class="article-directory__nav" aria-label="記事分類">
      <div class="article-directory__container article-directory__nav-inner">
        {directoryGroups.map((group) => (
          <a href={`#${group.id}`}>
            <span>{group.label}</span>
            <strong>{group.posts.length}</strong>
          </a>
        ))}
      </div>
    </nav>

    <section class="article-directory__facets" aria-label="分類サマリー">
      <div class="article-directory__container article-directory__facet-grid">
        <div>
          <h2>地域別</h2>
          <ul>
            {Object.entries(taxonomyStats.countByRegion).map(([label, count]) => (
              <li>
                <span>{label}</span>
                <strong>{count}</strong>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2>試験・記事種別</h2>
          <ul>
            {Object.entries(taxonomyStats.countByExamType).map(([label, count]) => (
              <li>
                <span>{label}</span>
                <strong>{count}</strong>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <div class="article-directory__container article-directory__body">
      {directoryGroups.map((group) => (
        <section id={group.id} class="article-directory__section">
          <div class="article-directory__section-head">
            <p>{group.posts.length} articles</p>
            <h2>{group.label}</h2>
            <span>{group.description}</span>
          </div>

          {group.subCategories.map((categoryGroup) => (
            <section id={`${group.id}-${idFor(categoryGroup.name)}`} class="article-directory__category">
              <h3>
                <span>{categoryGroup.name}</span>
                <strong>{categoryGroup.posts.length}</strong>
              </h3>
              <div class="article-directory__grid">
                {categoryGroup.posts.map((post: any) => {
                  const directoryImage = resolveArticleDirectoryImage(post, directoryImageIndex);

                  return (
                    <article class="article-directory__card">
                      {directoryImage?.src && (
                        <img
                          src={directoryImage.src}
                          alt={directoryImage.alt || `${post.taxonomy.facets.universityName}のアイキャッチ画像`}
                          width="168"
                          height="112"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <div>
                        <a href={post.path}>{displayPostTitle(post)}</a>
                        <p>{post.description || post.title}</p>
                        <ul class="article-directory__card-tags">
                          <li>{post.taxonomy.facets.year}</li>
                          <li>{post.taxonomy.facets.universityType}</li>
                          <li>{post.taxonomy.facets.region}</li>
                          <li>{post.taxonomy.facets.examType}</li>
                          {post.taxonomy.facets.storyTags?.slice(0, 2).map((tag: string) => <li>{tag}</li>)}
                          {post.taxonomy.facets.subjects?.slice(0, 2).map((tag: string) => <li>{tag}</li>)}
                        </ul>
                        <small>{post.modified || post.date || ""}</small>
                      </div>
                    </article>
                  );
                })}
              </div>
            </section>
          ))}
        </section>
      ))}
    </div>
  </main>
</SiteLayout>

<style>
  .article-directory {
    background: #fffdf8;
    color: var(--ink);
  }

  .article-directory__container {
    width: min(1120px, calc(100% - 40px));
    margin-inline: auto;
  }

  .article-directory__hero {
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 94%), rgb(255 250 239 / 98%)),
      repeating-linear-gradient(90deg, rgb(139 0 0 / 5%) 0 1px, transparent 1px 46px);
    padding: 70px 0 46px;
    text-align: center;
  }

  .article-directory__eyebrow {
    margin: 0 0 10px;
    color: var(--red);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0;
  }

  .article-directory h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 1.5rem + 2.2vw, 4rem);
    line-height: 1.15;
  }

  .article-directory__hero > div > p:not(.article-directory__eyebrow) {
    max-width: 760px;
    margin: 18px auto 0;
    color: #3c3833;
    font-size: 1rem;
    line-height: 1.9;
  }

  .article-directory__summary {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 10px;
    margin: 28px 0 0;
  }

  .article-directory__summary div,
  .article-directory__nav a,
  .article-directory__facet-grid > div,
  .article-directory__card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 8px 20px rgb(57 38 12 / 5%);
  }

  .article-directory__summary div {
    padding: 14px 10px;
  }

  .article-directory__summary dt {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .article-directory__summary dd {
    margin: 4px 0 0;
    color: var(--red);
    font-family: var(--font-serif);
    font-size: 1.74rem;
    font-weight: 900;
    line-height: 1;
  }

  .article-directory__nav {
    position: sticky;
    top: 0;
    z-index: 5;
    border-bottom: 1px solid var(--line);
    background: rgb(255 253 248 / 94%);
    backdrop-filter: blur(10px);
    padding: 12px 0;
  }

  .article-directory__nav-inner {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
  }

  .article-directory__nav a {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: center;
    padding: 12px 14px;
    color: #2b241f;
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .article-directory__nav strong {
    color: var(--red);
    font-family: var(--font-serif);
  }

  .article-directory__facets {
    border-bottom: 1px solid var(--line);
    background: #faf5ec;
    padding: 28px 0;
  }

  .article-directory__facet-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .article-directory__facet-grid > div {
    padding: 18px;
  }

  .article-directory__facet-grid h2 {
    margin: 0 0 12px;
    color: #2a211b;
    font-size: 1rem;
    font-weight: 900;
  }

  .article-directory__facet-grid ul,
  .article-directory__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-directory__facet-grid li {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    border-radius: 999px;
    background: #f7f2ea;
    padding: 5px 10px;
    color: #4d4037;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .article-directory__facet-grid li strong {
    color: var(--red);
    font-family: var(--font-serif);
  }

  .article-directory__body {
    display: grid;
    gap: 54px;
    padding: 56px 0 90px;
  }

  .article-directory__section {
    scroll-margin-top: 96px;
  }

  .article-directory__section-head {
    border-left: 6px solid var(--red);
    padding-left: 18px;
    margin-bottom: 24px;
  }

  .article-directory__section-head p {
    margin: 0 0 4px;
    color: var(--red);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .article-directory__section-head h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 1.35rem + 1vw, 2.5rem);
    line-height: 1.25;
  }

  .article-directory__section-head span {
    display: block;
    max-width: 780px;
    margin-top: 8px;
    color: #5a5149;
    font-size: 0.92rem;
    line-height: 1.75;
  }

  .article-directory__category {
    margin-top: 30px;
    scroll-margin-top: 106px;
  }

  .article-directory__category h3 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin: 0 0 14px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 10px;
    font-size: 1.08rem;
    font-weight: 900;
  }

  .article-directory__category h3 strong {
    display: inline-grid;
    place-items: center;
    min-width: 38px;
    min-height: 28px;
    border-radius: 999px;
    background: #f7f2ea;
    color: var(--red);
    font-family: var(--font-serif);
    font-size: 1rem;
  }

  .article-directory__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .article-directory__card {
    display: grid;
    grid-template-columns: 124px minmax(0, 1fr);
    gap: 14px;
    padding: 14px;
  }

  .article-directory__card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 6px;
    object-fit: cover;
    background: #f7f2ea;
  }

  .article-directory__card img[src*="/illustrations/characters/"] {
    object-fit: contain;
    padding: 8px;
  }

  .article-directory__card div {
    min-width: 0;
  }

  .article-directory__card a {
    color: #231d19;
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.5;
    text-decoration-color: rgb(139 0 0 / 26%);
    text-underline-offset: 0.2em;
  }

  .article-directory__card p {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    margin: 8px 0 0;
    color: #5a5149;
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .article-directory__card-tags {
    margin-top: 10px;
  }

  .article-directory__card-tags li {
    border: 1px solid rgb(139 0 0 / 14%);
    border-radius: 999px;
    background: #fff8f4;
    color: #60231d;
    padding: 2px 8px;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.5;
  }

  .article-directory__card small {
    display: block;
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 800;
  }

  @media (max-width: 1020px) {
    .article-directory__summary,
    .article-directory__nav-inner {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .article-directory__facet-grid,
    .article-directory__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .article-directory__container {
      width: min(100% - 28px, 1120px);
    }

    .article-directory__hero {
      padding: 42px 0 32px;
    }

    .article-directory__summary,
    .article-directory__nav-inner {
      grid-template-columns: 1fr;
    }

    .article-directory__nav {
      position: static;
    }

    .article-directory__card {
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 12px;
      padding: 12px;
    }
  }
</style>
