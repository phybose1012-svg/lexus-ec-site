---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "医学部対策のフルコース | 「レクサス プレミア本科」- 医学部予備校 レクサス E.C.【全国対応】";
const description =
  "医学部予備校 高卒生向けコース「レクサスプレミア本科」では、戦略的カリキュラム×完全管理体制で医学部合格を目指す。コース内には6種類の合格プランが用意されており、専用寮も利用できます。日本全国のあらゆるニーズに対応することができます。無料体験受付中。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/02/レクサスガーデン-1-04.jpg",
};

const recommend = [
  "とにかく受験勉強に集中したい。",
  "勉強のやり方を細かく指示して欲しい。",
  "課題をたくさん出してほしい。",
  "自分がサボらないような環境をつくりたい。",
  "長期間にモチベーションを保つ自信がない。",
];

const supports = ["取りこぼしフォロー", "学習マネージメント", "受験校選定サポート"];

const curricula = [
  {
    title: "特別選抜SSプラン",
    rows: ["【目標大学】 東大、慶應など、医学部のトップ", "【入学時の学力】 偏差値65相当 (目安)", "【料金 】 ¥1,478,000～"],
    href: "/top/course/lexus-premiere-course/ss/",
  },
  {
    title: "選抜SAプラン",
    rows: ["【目標大学】 国公立、慈恵、順天など、難関医学部", "【入学時の学力】 偏差値60相当 (目安)", "【料金 】 ¥2,204,000～"],
    href: "/top/course/lexus-premiere-course/sa/",
  },
  {
    title: "Advancedプラン",
    rows: ["【目標大学】 昭和、東医など上位の私立医学部", "【入学時の学力】 偏差値55相当 (目安)", "【料金 】 ¥2,902,000～"],
    href: "/top/course/lexus-premiere-course/advanced/",
  },
  {
    title: "Basic α プラン",
    rows: ["【目標大学】 都内の私立医学部など", "【入学時の学力】 偏差値50相当 (目安)", "【料金 】 ¥3,452,000～"],
    href: "/top/course/lexus-premiere-course/basic-α/",
  },
  {
    title: "Basic β プラン",
    rows: ["【目標大学】 地方の私大医学部など", "【入学時の学力】 偏差値40台 (目安)", "【料金 】 ¥3,452,000～"],
    href: "/top/course/lexus-premiere-course/basic-β/",
  },
  {
    title: "Introductionプラン",
    rows: ["【目標大学】 地方の私大医学部など", "【入学時の学力】 未習科目あり", "【料金 】 ¥4,256,000～"],
    heading: "h2",
    href: "/top/course/lexus-premiere-course/introduction/",
  },
];

const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];

const otherCourses = [
  {
    category: "◆ 高2・高3 対象コース ◆",
    title: "ハイレベル現役合格コース",
    en: "High-level GENEKI Course",
    body: "慶應、慈恵、順天、日医をはじめとする都内の医学部に現役合格するためのコースです。",
    href: "/top/course/high-level-geneki-course/",
  },
  {
    category: "◆ 既卒・再受験・高1～3 対象コース ◆",
    title: "オーダーメード演習 コース",
    en: "Custom-made Course",
    body: "自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。",
    href: "/top/course/custom-made-course/",
  },
  {
    category: "◆ 高1・高2 対象コース ◆",
    title: "メディカル準備コース (高等部)",
    en: "Medical Prep Course",
    body: "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。",
    href: "/top/course/medical-prep/",
  },
  {
    category: "◆ 中学生 対象コース ◆",
    title: "メディカル準備コース (中等部)",
    en: "Medical Prep Course",
    body: "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。",
    href: "/top/course/medical-prep-junior/",
  },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/lexus-premiere-course/" ogImage={seo.ogImage}>
  <main class="course-detail-page course-detail-page--premier">
    <section class="course-detail-hero course-detail-hero--premier">
      <div class="content course-detail-hero__intro course-detail-hero__intro--premier">
        <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
        <h1>一日13時間 完全管理体制の<br />医学部特化“オールインワン”コース</h1>
        <div class="course-title-card course-title-card--premier">
          <p class="course-title-card__jp">レクサス プレミア 本科</p>
          <p class="course-title-card__en">Premier Main Course</p>
          <p class="course-title-card__lead">医学部受験を全面的にサポートする高卒生専用のコースです。目標別のプランあり。</p>
        </div>
      </div>
    </section>

    <section class="course-detail-recommend course-detail-recommend--premier" aria-labelledby="course-recommend-title-premier">
      <div class="content course-detail-recommend__inner">
        <h2 id="course-recommend-title-premier">こんな受験生にオススメです！</h2>
        <div class="course-detail-recommend__grid">
          <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          <ul>{recommend.map((item) => <li>{item}</li>)}</ul>
        </div>
      </div>
    </section>

    <section class="course-detail-hero">
      <div class="content course-detail-hero__grid">
        <div>
          <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <p class="course-detail-hero__tagline">一日13時間 完全管理体制の<br />医学部特化“オールインワン”コース</p>
          <h2>レクサス プレミア 本科</h2>
          <p>Premier Main Course</p>
        </div>
        <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
      </div>
    </section>

    <section class="course-detail-recommend" aria-labelledby="course-recommend-title">
      <div class="content course-detail-two-column">
        <div>
          <h3 id="course-recommend-title">こんな受験生にオススメです！</h3>
          <ul>
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <p>医学部受験を全面的にサポートする高卒生専用のコースです。目標別のプランあり。</p>
      </div>
    </section>

    <section class="course-detail-overview" aria-labelledby="course-overview-title">
      <div class="content">
        <h2 id="course-overview-title">コース概要</h2>
        <div class="course-detail-overview-grid">
          <article>
            <h3>● プレミア本科 とは？ ●</h3>
            <p>医学部対策サポートの全てを受けられるコースです。これ以上の準備は不要です。</p>
            <p>「少人数クラス」 × 「個別指導」 × 「厳しい課題管理」</p>
          </article>
          <article>
            <h3>● 万全のサポート内容 ●</h3>
            <p>レクサス独自の合格プランで、段階的に成長。合格まで立ち止まらせません！</p>
            <div class="course-detail-supports">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="course-detail-curriculum" aria-labelledby="course-curriculum-title">
      <div class="content">
        <h2 id="course-curriculum-title">「カリキュラム」 一覧</h2>
        <p>まずはご希望の「カリキュラム 」を選択して下さい。カリキュラムは全部で6種類です。</p>
        <div class="course-detail-plan-grid">
          {curricula.map((plan) => (
            <article>
              {plan.heading === "h2" ? <h2>{plan.title}</h2> : <h4>{plan.title}</h4>}
              <ul>{plan.rows.map((row) => <li>{row}</li>)}</ul>
              <a class="button button--blue" href={plan.href}>詳しくはコチラ</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="course-detail-message" aria-labelledby="course-message-title">
      <div class="content course-detail-message__grid">
        <div>
          <h2 id="course-message-title">“合格したい気持ち”なら 誰にも負けない。</h2>
          <p>その想いがあるなら、あとは正しい戦略を持つだけ。レクサスは、“今”から本気になるあなたを全力でサポートします。</p>
          <h3>↓ 入学までの流れ ↓</h3>
          <p>※ 「無料面談」の前に、「無料体験 （体験授業）」を受けることも可能です。</p>
          <div class="fixed-hero__actions">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-garden" aria-labelledby="course-garden-title">
      <div class="content course-detail-garden__grid">
        <div>
          <h2 id="course-garden-title">生徒専用寮のご案内 『LEXUS GARDEN』</h2>
          <p>寮と一体の校舎で、生活リズムと学習量を守りながら医学部合格へ向かいます。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
        <img src={images.garden} alt="レクサスガーデン外観" width="788" height="518" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-other" aria-labelledby="course-other-title">
      <div class="content">
        <h2 id="course-other-title">他のコース一覧</h2>
        <div class="course-detail-other-grid">
          {otherCourses.map((course) => (
            <article>
              <h3>{course.category}</h3>
              <h4>{course.title}</h4>
              <p class="course-detail-other__en">{course.en}</p>
              <p>{course.body}</p>
              <a class="button button--blue" href={course.href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
