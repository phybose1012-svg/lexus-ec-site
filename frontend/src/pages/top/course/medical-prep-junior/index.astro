---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "メディカル準備コース (中等部) - 医学部予備校 レクサス E.C.";
const description =
  "中学生から始める医学部受験対策「メディカル準備コース」。中高一貫校のカリキュラムに対応し、高1までに高3範囲を修了する先取り学習も可能です。プロ講師による完全個別指導で、医学部合格に必要な基礎学力と学習習慣を確立します。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
};

const recommend = ["将来、絶対医者になりたい。", "中高一貫校に通っている。", "早くから大学受験の準備を始めたい。", "国公立の医学部に行きたい。", "内部進学や推薦で医学部に行きたい。"];
const plans = [
  { title: "トップレベル先取りプラン", rows: ["【プラン概要】 高1の9月までに高3の全範囲修了", "【入学時の学力】 偏差値65相当 (目安)", "【月額料金 】 ¥28,000〜"] },
  { title: "ハイレベル先取りプラン", rows: ["【プラン概要】 高2の4月までに高3の範囲修了", "【入学時の学力】 偏差値60相当 (目安)", "【月額料金 】 ¥28,000〜"] },
  { title: "標準レベル先取りプラン", rows: ["【プラン概要】 高2の9月までに高3の範囲修了", "【入学時の学力】 偏差値55相当 (目安)", "【月額料金】 ¥44,000〜"] },
];
const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];
const quickLinks = [
  { label: "講師紹介", href: "/top/teacher/", tone: "blue" },
  { label: "合格体験記", href: "/top/voice/", tone: "green" },
  { label: "理念と沿革", href: "/top/history/", tone: "red" },
];
const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/medical-prep-junior/" ogImage={seo.ogImage}>
  <main class="course-detail-page">
    <section class="course-detail-hero course-detail-hero--junior">
      <div class="content course-detail-hero__intro">
        <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
        <p class="course-detail-hero__kicker">【オンライン対応可】</p>
        <h1>中学から始まる医学部合格への道</h1>
        <div class="course-title-card course-title-card--junior">
          <p class="course-title-card__jp">メディカル準備コース（中等部）</p>
          <p class="course-title-card__en">Medical Prep Course</p>
          <p class="course-title-card__lead">先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。</p>
        </div>
        <div class="course-detail-hero__actions">
          <a class="button button--red" href="/test-entry/">体験授業はコチラ</a>
          <a class="button button--blue" href="/reservation/">個別相談はコチラ</a>
        </div>
      </div>
    </section>

    <section class="course-detail-recommend course-detail-recommend--junior">
      <div class="content course-detail-recommend__inner">
        <h2>こんな中学生にオススメです！</h2>
        <div class="course-detail-recommend__grid">
          <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          <ul>
            <li>将来、絶対医者になりたい。</li>
            <li>中高一貫校に通っている。</li>
            <li>早くから大学受験の準備を始めたい。</li>
            <li>国公立の医学部に行きたい。</li>
            <li>内部進学や推薦で医学部に行きたい。</li>
          </ul>
        </div>
        <p>先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。</p>
      </div>
    </section>

    <section class="course-detail-hero">
      <div class="content course-detail-hero__grid">
        <div>
          <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <h2 class="course-detail-subhero-title">【オンライン対応可】<br />中学から始まる医学部合格への道</h2>
          <p class="course-detail-course-name">メディカル準備コース (中等部)</p>
          <p>Medical Prep Course</p>
          <div class="fixed-hero__actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
          <div class="course-detail-quick-actions">
            {quickLinks.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
      </div>
    </section>

    <section class="course-detail-recommend">
      <div class="content course-detail-two-column">
        <div>
          <h3>こんな中学生にオススメです！</h3>
          <ul>{recommend.map((item) => <li>{item}</li>)}</ul>
        </div>
        <p>先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。</p>
      </div>
    </section>

    <section class="course-detail-overview">
      <div class="content">
        <h2>コース概要</h2>
        <div class="course-detail-overview-grid">
          <article>
            <h3>● メディカル準備コース とは？ ●</h3>
            <p>医学部対策サポートの全てを受けられるコースです。これ以上の準備は不要です。</p>
            <p>「パーソナル授業」 × 「厳しい課題管理」 × 「効果測定」</p>
          </article>
          <article>
            <h3>● 万全のサポート内容 ●</h3>
            <p>レクサス独自のプランで、合格するための学力と勉強習慣が身に付きます！</p>
          </article>
        </div>
      </div>
    </section>

    <section class="course-detail-curriculum">
      <div class="content">
        <h2>「カリキュラム」 一覧</h2>
        <p>まずはご希望の「カリキュラム 」を選択して下さい。カリキュラムは全部で6種類です。</p>
        <div class="course-detail-plan-grid">
          {plans.map((plan) => (
            <article>
              <h3>{plan.title}</h3>
              <ul>{plan.rows.map((row) => <li>{row}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="course-detail-message">
      <div class="content course-detail-message__grid">
        <div>
          <h2>夢を叶えるため、 先手を打ちたい！</h2>
          <p>その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「メディカル準備コース」は、“今”から本気になるあなたを、全力で支えるコースです。</p>
          <h3>↓ 入学までの流れ ↓</h3>
          <p>※ 「無料面談」の前に、「無料体験 （体験授業）」を受けることも可能です。</p>
          <div class="fixed-hero__actions">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
      </div>
    </section>
  </main>
</SiteLayout>
