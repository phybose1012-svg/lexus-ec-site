---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";
import "../../../../styles/medical-prep-course.css";

const title = "メディカル準備コース（中等部） - 医学部予備校 レクサス E.C.";
const description =
  "中学生から医学部受験を見据えて先取り学習を始めるメディカル準備コース（中等部）。中高一貫校の進度に合わせ、高校範囲への接続、学習習慣、基礎学力を早期から整えます。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
};

const recommend = [
  "将来、絶対医者になりたい。",
  "中高一貫校に通っている。",
  "早くから大学受験の準備を始めたい。",
  "国公立の医学部に行きたい。",
  "内部進学や推薦で医学部に行きたい。",
];

const supports = ["中高一貫校対応", "パーソナル授業", "先取り設計", "課題管理", "効果測定", "オンライン対応"];

const pillars = [
  {
    label: "01",
    title: "中学内容を盤石にする",
    body: "先取りの前提になる英数の基礎を、早い段階で丁寧に固めます。穴を残したまま高校範囲へ進ませません。",
  },
  {
    label: "02",
    title: "高校範囲へ自然につなげる",
    body: "中高一貫校の進度に合わせ、必要な単元から高校内容へ接続。医学部受験に必要な範囲を前倒しで扱います。",
  },
  {
    label: "03",
    title: "学習習慣を固定する",
    body: "課題、確認、復習まで管理し、勉強を日常の中へ組み込みます。早期から“続けられる強さ”を作ります。",
  },
];

const plans = [
  {
    title: "トップレベル先取りプラン",
    tag: "最速先取り",
    outline: "高1の9月までに高3の全範囲修了",
    level: "偏差値65相当",
    price: "¥28,000〜",
  },
  {
    title: "ハイレベル先取りプラン",
    tag: "難関医学部へ",
    outline: "高2の4月までに高3の範囲修了",
    level: "偏差値60相当",
    price: "¥28,000〜",
  },
  {
    title: "標準レベル先取りプラン",
    tag: "着実な準備",
    outline: "高2の9月までに高3の範囲修了",
    level: "偏差値55相当",
    price: "¥44,000〜",
  },
];

const planHrefs = [
  "/top/course/medical-prep-junior/top-level/",
  "/top/course/medical-prep-junior/high-level/",
  "/top/course/medical-prep-junior/standard/",
];

const otherCourses = [
  ["◆ 高1・高2 対象コース ◆", "メディカル準備コース（高等部）", "Medical Prep Course", "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。", "/top/course/medical-prep/"],
  ["◆ 既卒・再受験・高1〜3 対象コース ◆", "オーダーメード演習 コース", "Custom-made Course", "自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。", "/top/course/custom-made-course/"],
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/top/course/lexus-premiere-course/"],
];

const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];

const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/medical-prep-junior/" ogImage={seo.ogImage}>
  <main class="prep-course-page prep-course-page--junior">
    <section class="prep-hero" aria-labelledby="medical-prep-junior-title">
      <div class="content prep-hero__inner">
        <div class="prep-hero__copy">
          <img class="prep-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <p class="prep-eyebrow">Medical Prep Course / Junior</p>
          <h1 id="medical-prep-junior-title">
            <span>中学から始まる</span>
            医学部合格への先取り設計
          </h1>
          <p class="prep-hero__lead">
            中高一貫校の強みを活かし、早い時期から高校範囲へ接続。基礎学力と学習習慣を整え、医学部受験のスタートラインを前へ動かします。
          </p>
          <div class="prep-title-card" aria-label="コース名">
            <p class="prep-title-card__jp">メディカル準備コース（中等部）</p>
            <p class="prep-title-card__en">Medical Prep Course</p>
            <p class="prep-title-card__lead">先手必勝。難関医学部を目指す中学生のために、早期から学習設計と習慣化を支えます。</p>
          </div>
          <div class="prep-actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <div class="prep-hero__visual" aria-hidden="true">
          <div class="prep-hero__image-frame">
            <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          </div>
          <div class="prep-hero__note">
            <span>Online OK</span>
            <strong>中高一貫校の進度にも対応</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="prep-fit" aria-labelledby="medical-prep-junior-fit-title">
      <div class="content prep-fit__inner">
        <div class="prep-section-head">
          <p>Recommend</p>
          <h2 id="medical-prep-junior-fit-title">こんな中学生にオススメです</h2>
        </div>
        <div class="prep-fit__grid">
          <ul class="prep-check-list">
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
          <div class="prep-fit__message">
            <p>
              中学生のうちから医学部を意識できるなら、最大の武器は時間です。基礎固めと先取りを同時に設計し、学年が上がるほど余裕が出る状態を作ります。
            </p>
            <div class="prep-support-tags">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="prep-system" aria-labelledby="medical-prep-junior-system-title">
      <div class="content">
        <div class="prep-section-head prep-section-head--center">
          <p>System</p>
          <h2 id="medical-prep-junior-system-title">メディカル準備コースとは？</h2>
          <span>中学内容の定着、高校範囲への接続、学習習慣の固定を一体で進めます。</span>
        </div>
        <div class="prep-pillar-grid">
          {pillars.map((pillar) => (
            <article>
              <p class="prep-pillar__label">{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="prep-plans" aria-labelledby="medical-prep-junior-plans-title">
      <div class="content">
        <div class="prep-section-head">
          <p>Plans</p>
          <h2 id="medical-prep-junior-plans-title">カリキュラム一覧</h2>
          <span>到達時期の目標を明確にし、無理のない先取りペースへ調整します。</span>
        </div>
        <div class="prep-plan-grid">
          {plans.map((plan, index) => (
            <article>
              <span class="prep-plan__tag">{plan.tag}</span>
              <h3>{plan.title}</h3>
              <dl>
                <div>
                  <dt>プラン概要</dt>
                  <dd>{plan.outline}</dd>
                </div>
                <div>
                  <dt>入学時の目安</dt>
                  <dd>{plan.level}</dd>
                </div>
                <div>
                  <dt>月額料金</dt>
                  <dd>{plan.price}</dd>
                </div>
              </dl>
              <a class="button button--blue prep-plan__link" href={planHrefs[index]}>詳しく見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="prep-message" aria-labelledby="medical-prep-junior-message-title">
      <div class="content prep-message__grid">
        <div>
          <p class="prep-eyebrow prep-eyebrow--light">Admission Flow</p>
          <h2 id="medical-prep-junior-message-title">夢を叶えるため、先手を打ちたい。</h2>
          <p>
            その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「メディカル準備コース」は、“今”から本気になる中学生を、全力で支えるコースです。
          </p>
          <p class="prep-message__sub">無料面談の前に、無料体験を受けることも可能です。</p>
          <div class="prep-actions prep-actions--left">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <figure>
          <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="prep-other" aria-labelledby="medical-prep-junior-other-title">
      <div class="content">
        <div class="prep-section-head prep-section-head--center">
          <p>Other Courses</p>
          <h2 id="medical-prep-junior-other-title">他のコース一覧</h2>
        </div>
        <div class="prep-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="prep-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
