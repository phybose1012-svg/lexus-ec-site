---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";
import "../../../../styles/medical-prep-course.css";

const title = "メディカル準備コース（高等部） - 医学部予備校 レクサス E.C.";
const description =
  "高校生から医学部現役合格を見据えて先取り学習を進めるメディカル準備コース（高等部）。パーソナル授業、課題管理、効果測定で、内部進学・推薦・一般入試まで段階的に支えます。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/12/Gemini_Generated_Image_h3qlynh3qlynh3ql-e1764922283465-1024x790.jpg",
};

const recommend = [
  "将来、絶対医者になりたい。",
  "中高一貫校に通っている。",
  "なるべく早く準備を始めたい。",
  "国公立の医学部に行きたい。",
  "内部進学や推薦で医学部に行きたい。",
];

const supports = ["パーソナル授業", "厳しい課題管理", "効果測定", "オンライン対応", "内部進学対策", "推薦対策"];

const pillars = [
  {
    label: "01",
    title: "先取り範囲を逆算する",
    body: "学校進度だけに任せず、医学部受験に必要な範囲から逆算して、いつまでに何を終えるかを明確にします。",
  },
  {
    label: "02",
    title: "個別授業で理解を固める",
    body: "苦手単元を放置せず、パーソナル授業で理解の穴を埋めます。早い時期から科目ごとの得点源を作ります。",
  },
  {
    label: "03",
    title: "課題管理で継続させる",
    body: "先取りは継続が命です。毎週の課題、確認テスト、復習指示まで管理し、勉強量を安定させます。",
  },
];

const plans = [
  {
    title: "トップレベル先取りプラン",
    tag: "最難関医学部",
    target: "東大、慶應など、医学部のトップ",
    level: "偏差値65相当",
    price: "¥28,000〜",
  },
  {
    title: "ハイレベル先取りプラン",
    tag: "難関医学部",
    target: "国公立、慈恵、順天など、難関医学部",
    level: "偏差値60相当",
    price: "¥28,000〜",
  },
  {
    title: "標準レベル先取りプラン",
    tag: "上位私立医学部",
    target: "昭和、東医など上位の私立医学部",
    level: "偏差値55相当",
    price: "¥44,000〜",
  },
  {
    title: "基礎レベル先取りプラン",
    tag: "校内上位へ",
    target: "定期試験で校内上位の成績",
    level: "偏差値50相当",
    price: "¥44,000〜",
  },
  {
    title: "慶應内部進学プラン",
    tag: "内部進学",
    target: "慶應義塾大学 医学部",
    level: "特に制限なし",
    price: "¥28,000〜",
  },
  {
    title: "日大内部進学プラン",
    tag: "内部進学",
    target: "日本大学 医学部",
    level: "特に制限なし",
    price: "¥28,000〜",
  },
];

const planHrefs = [
  "/top/course/medical-prep/top-level/",
  "/top/course/medical-prep/high-level/",
  "/top/course/medical-prep/standard/",
  "/top/course/medical-prep/basic/",
  "/top/course/medical-prep/keio-internal/",
  "/top/course/medical-prep/nichidai-internal/",
];

const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/lexus-premier/"],
  ["◆ 既卒・再受験・高1〜3 対象コース ◆", "オーダーメード演習 コース", "Custom-made Course", "自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。", "/top/course/custom-made-course/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース（中等部）", "Medical Prep Course", "先手必勝。難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];

const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];

const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/medical-prep/" ogImage={seo.ogImage}>
  <main class="prep-course-page prep-course-page--senior">
    <section class="prep-hero" aria-labelledby="medical-prep-title">
      <div class="content prep-hero__inner">
        <div class="prep-hero__copy">
          <img class="prep-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <p class="prep-eyebrow">Medical Prep Course / High School</p>
          <h1 id="medical-prep-title">
            <span>医学部受験で優位に立つ</span>
            高校生のための先取りコース
          </h1>
          <p class="prep-hero__lead">
            高1・高2のうちに、医学部受験で差がつく範囲へ先回り。一般入試だけでなく、内部進学や推薦まで見据えて、学習計画を早期から整えます。
          </p>
          <div class="prep-title-card" aria-label="コース名">
            <p class="prep-title-card__jp">メディカル準備コース（高等部）</p>
            <p class="prep-title-card__en">Medical Prep Course</p>
            <p class="prep-title-card__lead">先取り授業・課題管理・効果測定を組み合わせ、医学部現役合格へ向けた準備を前倒しします。</p>
          </div>
          <div class="prep-actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <div class="prep-hero__visual" aria-hidden="true">
          <div class="prep-hero__image-frame">
            <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          </div>
          <div class="prep-hero__note">
            <span>Online OK</span>
            <strong>内部進学・推薦対策にも対応</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="prep-fit" aria-labelledby="medical-prep-fit-title">
      <div class="content prep-fit__inner">
        <div class="prep-section-head">
          <p>Recommend</p>
          <h2 id="medical-prep-fit-title">こんな高1・高2生にオススメです</h2>
        </div>
        <div class="prep-fit__grid">
          <ul class="prep-check-list">
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
          <div class="prep-fit__message">
            <p>
              医学部受験は、早く始めた分だけ有利になります。ただし、闇雲な先取りではなく、目標校・学校進度・現在の理解度に合わせた設計が必要です。
            </p>
            <div class="prep-support-tags">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="prep-system" aria-labelledby="medical-prep-system-title">
      <div class="content">
        <div class="prep-section-head prep-section-head--center">
          <p>System</p>
          <h2 id="medical-prep-system-title">メディカル準備コースとは？</h2>
          <span>パーソナル授業 × 厳しい課題管理 × 効果測定で、早期準備を合格戦略に変えます。</span>
        </div>
        <div class="prep-pillar-grid">
          {pillars.map((pillar) => (
            <article>
              <p class="prep-pillar__label">{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="prep-plans" aria-labelledby="medical-prep-plans-title">
      <div class="content">
        <div class="prep-section-head">
          <p>Plans</p>
          <h2 id="medical-prep-plans-title">合格プラン一覧</h2>
          <span>現在の学力・志望校・内部進学の有無に合わせて、学習量とサポート密度を調整します。</span>
        </div>
        <div class="prep-plan-grid">
          {plans.map((plan, index) => (
            <article>
              <span class="prep-plan__tag">{plan.tag}</span>
              <h3>{plan.title}</h3>
              <dl>
                <div>
                  <dt>目標</dt>
                  <dd>{plan.target}</dd>
                </div>
                <div>
                  <dt>入学時の目安</dt>
                  <dd>{plan.level}</dd>
                </div>
                <div>
                  <dt>月額料金</dt>
                  <dd>{plan.price}</dd>
                </div>
              </dl>
              <a class="button button--blue prep-plan__link" href={planHrefs[index]}>詳しく見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="prep-message" aria-labelledby="medical-prep-message-title">
      <div class="content prep-message__grid">
        <div>
          <p class="prep-eyebrow prep-eyebrow--light">Admission Flow</p>
          <h2 id="medical-prep-message-title">夢を叶えるため、先手を打ちたい。</h2>
          <p>
            その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「メディカル準備コース」は、“今”から本気になる高校生を、全力で支えるコースです。
          </p>
          <p class="prep-message__sub">無料面談の前に、無料体験を受けることも可能です。</p>
          <div class="prep-actions prep-actions--left">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <figure>
          <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="prep-garden" aria-labelledby="medical-prep-garden-title">
      <div class="content prep-garden__grid">
        <figure>
          <img src={images.garden} alt="生徒専用寮外観" width="800" height="617" loading="lazy" decoding="async" />
        </figure>
        <div>
          <p class="prep-eyebrow">Lexus Garden</p>
          <h2 id="medical-prep-garden-title">生徒専用寮のご案内『LEXUS GARDEN』</h2>
          <p>長期休み中の利用など、最短3日間から利用可能です。生活時間を学習時間へ変え、先取りのペースを安定させたい方にも適しています。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
      </div>
    </section>

    <section class="prep-other" aria-labelledby="medical-prep-other-title">
      <div class="content">
        <div class="prep-section-head prep-section-head--center">
          <p>Other Courses</p>
          <h2 id="medical-prep-other-title">他のコース一覧</h2>
        </div>
        <div class="prep-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="prep-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
