---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "メディカル準備コース（高等部） - 医学部予備校 レクサス E.C.";
const description =
  "「メディカル準備コース（高等部）」は、受験に向けて早めに準備を進めたい高校生が医学部現役合格を達成するための特別プログラム。個別最適化されたカリキュラムと徹底したサポートで、基礎から実戦力まで段階的に育成します。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/12/Gemini_Generated_Image_h3qlynh3qlynh3ql-e1764922283465-1024x790.jpg",
};

const recommend = ["将来、絶対医者になりたい。", "中高一貫校に通っている。", "なるべく早く準備を始めたい。", "国公立の医学部に行きたい。", "内部進学や推薦で医学部に行きたい。"];
const plans = [
  { title: "トップレベル先取りプラン", rows: ["【目標大学】 東大、慶應など、医学部のトップ", "【入学時の学力】 偏差値65相当 (目安)", "【月額料金 】 ¥28,000〜"] },
  { title: "ハイレベル先取りプラン", rows: ["【目標大学】 国公立、慈恵、順天など、難関医学部", "【入学時の学力】 偏差値60相当 (目安)", "【月額料金 】 ¥28,000〜"] },
  { title: "標準レベル先取りプラン", rows: ["【目標大学】 昭和、東医など上位の私立医学部", "【入学時の学力】 偏差値55相当 (目安)", "【月額料金 】 ¥44,000〜"] },
  { title: "基礎レベル先取りプラン", rows: ["【目標】 定期試験で校内上位の成績", "【入学時の学力】 偏差値50相当 (目安)", "【月額料金 】 ¥44,000〜"] },
  { title: "慶應内部進学プラン", rows: ["【目標大学】 慶應義塾大学 医学部", "【入学時の学力】 特に制限なし", "【月額料金 】 ¥28,000〜"] },
  { title: "日大内部進学プラン", rows: ["【目標大学】 日本大学 医学部", "【入学時の学力】 特に制限なし", "【月額料金 】 ¥28,000〜"], heading: "h2" },
];
const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/top/course/lexus-premiere-course/"],
  ["◆ 高2・高3 対象コース ◆", "ハイレベル現役合格コース", "High-level GENEKI Course", "慶應、慈恵、順天、日医をはじめとする都内の医学部に現役合格するためのコースです。", "/top/course/high-level-geneki-course/"],
  ["◆ 既卒・再受験・高1～3 対象コース ◆", "オーダーメード演習 コース", "Custom-made Course", "自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。", "/top/course/custom-made-course/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース (中等部)", "Medical Prep Course", "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];
const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];
const quickLinks = [
  { label: "講師紹介", href: "/top/teacher/", tone: "blue" },
  { label: "合格体験記", href: "/top/voice/", tone: "green" },
  { label: "理念と沿革", href: "/top/history/", tone: "red" },
];
const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/medical-prep/" ogImage={seo.ogImage}>
  <main class="course-detail-page">
    <section class="course-detail-hero course-detail-hero--medical-prep">
      <div class="content course-detail-hero__intro course-detail-hero__intro--medical-prep">
        <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
        <p class="course-detail-hero__kicker">【オンライン対応】</p>
        <h1>医学部受験で優位に立つ先取りコース</h1>
        <div class="course-title-card course-title-card--medical-prep">
          <p class="course-title-card__jp">メディカル準備コース（高等部）</p>
          <p class="course-title-card__en">Medical Prep Course</p>
          <p class="course-title-card__lead">医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。</p>
        </div>
        <div class="course-detail-hero__actions">
          <a class="button button--red" href="/test-entry/">体験授業はコチラ</a>
          <a class="button button--blue" href="/reservation/">個別相談はコチラ</a>
        </div>
      </div>
    </section>

    <section class="course-detail-recommend course-detail-recommend--medical-prep">
      <div class="content course-detail-recommend__inner">
        <h2>こんな高1・高2生にオススメです！</h2>
        <div class="course-detail-recommend__grid">
          <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          <ul>
            <li>将来、絶対医者になりたい。</li>
            <li>中高一貫校に通っている。</li>
            <li>なるべく早く準備を始めたい。</li>
            <li>国公立の医学部に行きたい。</li>
            <li>内部進学や推薦で医学部に行きたい。</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="course-detail-hero">
      <div class="content course-detail-hero__grid">
        <div>
          <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <h2 class="course-detail-subhero-title">【オンライン対応】<br />医学部受験で優位に立つ先取りコース</h2>
          <p class="course-detail-course-name">メディカル準備コース (高等部)</p>
          <p>Medical Prep Course</p>
          <div class="fixed-hero__actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
          <div class="course-detail-quick-actions">
            {quickLinks.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
      </div>
    </section>

    <section class="course-detail-recommend">
      <div class="content course-detail-two-column">
        <div>
          <h3>こんな高1・高2生にオススメです！</h3>
          <ul>{recommend.map((item) => <li>{item}</li>)}</ul>
        </div>
        <p>医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。</p>
      </div>
    </section>

    <section class="course-detail-overview">
      <div class="content">
        <h2>コース概要</h2>
        <div class="course-detail-overview-grid">
          <article>
            <h3>● メディカル準備コース とは？ ●</h3>
            <p>医学部対策サポートの全てを受けられるコースです。これ以上の準備は不要です。</p>
            <p>「パーソナル授業」 × 「厳しい課題管理」 × 「効果測定」</p>
          </article>
          <article>
            <h3>● 万全のサポート内容 ●</h3>
            <p>レクサス独自のプランで、ライバルに圧倒的な差をつけてリードできます！</p>
          </article>
        </div>
      </div>
    </section>

    <section class="course-detail-curriculum">
      <div class="content">
        <h2>「合格プラン」 一覧</h2>
        <p>まずはご希望の「カリキュラム 」を選択して下さい。カリキュラムは全部で6種類です。</p>
        <div class="course-detail-plan-grid">
          {plans.map((plan) => (
            <article>
              <h3>{plan.title}</h3>
              <ul>{plan.rows.map((row) => <li>{row}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="course-detail-message">
      <div class="content course-detail-message__grid">
        <div>
          <h2>夢を叶えるため、 先手を打ちたい！</h2>
          <p>その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「メディカル準備コース」は、“今”から本気になるあなたを、全力で支えるコースです。</p>
          <h3>↓ 入学までの流れ ↓</h3>
          <p>※ 「無料面談」の前に、「無料体験 （体験授業）」を受けることも可能です。</p>
          <div class="fixed-hero__actions">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-garden">
      <div class="content course-detail-garden__grid">
        <div>
          <h2>生徒専用寮のご案内 『LEXUS GARDEN』</h2>
          <p>長期休み中の利用など、最短3日間～の利用が可能です。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
        <img src={images.garden} alt="生徒専用寮外観" width="800" height="617" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-other">
      <div class="content">
        <h2>コース 一覧</h2>
        <div class="course-detail-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="course-detail-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
        <div class="course-detail-quick-actions course-detail-quick-actions--bottom">
          {quickLinks.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
