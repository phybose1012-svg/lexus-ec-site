---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "医学部専門 オーダーメード演習コース｜すべてのレベルに対応可能な医学部受験攻略コース";
const description =
  "自学力で医学部合格を狙う、自習特化型コース誕生。参考書ルート・学習計画・進捗管理まで徹底サポート。武田塾式を進化させた、自分で学び切る医学部対策。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/12/Gemini_Generated_Image_h3qlynh3qlynh3ql-e1764922283465-1024x790.jpg",
};

const recommend = [
  "初歩的なレベルを一気に終わらせたい。",
  "反復練習が足りないとよく言われる。",
  "自分好みのハイペースで学習したい。",
  "授業はあまり必要ない。",
  "たくさん過去問を解きたい。",
];

const pillars = [
  {
    label: "01",
    title: "演習量を、合格ルートに変える",
    body: "参考書や過去問をただ増やすのではなく、目標校と現在地から逆算して、毎週の演習量と復習順を設計します。",
  },
  {
    label: "02",
    title: "課題管理で、自走を止めない",
    body: "やるべき教材、提出ペース、解き直しまでを管理。自習中心でも迷いが出ないように、学習の優先順位を明確にします。",
  },
  {
    label: "03",
    title: "必要な授業だけを足す",
    body: "授業を増やしすぎず、詰まった単元や得点源にしたい科目だけを個別授業で補強できます。",
  },
];

const supports = ["個別カリキュラム", "課題管理", "質問し放題", "効果測定", "個別授業を追加可能", "受験校選定サポート"];

const plans = [
  {
    title: "トップレベル演習プラン",
    target: "東大、慶應など、医学部のトップ",
    level: "偏差値65相当",
    price: "¥18,000～ / 科目",
  },
  {
    title: "ハイレベル演習プラン",
    target: "国公立、慈恵、順天など、難関医学部",
    level: "偏差値60相当",
    price: "¥22,500～ / 科目",
  },
  {
    title: "標準レベル演習プラン",
    target: "昭和、東医など上位の私立医学部",
    level: "偏差値55相当",
    price: "¥28,000～ / 科目",
  },
  {
    title: "基礎レベル演習プラン",
    target: "都内の私立医学部など",
    level: "偏差値50相当",
    price: "¥30,000～ / 科目",
  },
  {
    title: "初歩レベル演習プラン",
    target: "高校教科書レベルの知識修得",
    level: "偏差値40台",
    price: "¥30,000～ / 科目",
  },
  {
    title: "前提レベル演習プラン",
    target: "高校入試レベルの知識習得",
    level: "未習科目あり",
    price: "¥30,000～ / 科目",
  },
];

const planHrefs = [
  "/top/course/custom-made-course/top-level/",
  "/top/course/custom-made-course/high-level/",
  "/top/course/custom-made-course/standard/",
  "/top/course/custom-made-course/basic/",
  "/top/course/custom-made-course/beginner/",
  "/top/course/custom-made-course/foundation/",
];

const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/lexus-premier/"],
  ["◆ 高1・高2 対象コース ◆", "メディカル準備コース (高等部)", "Medical Prep Course", "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。", "/top/course/medical-prep/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース (中等部)", "Medical Prep Course", "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];

const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];

const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/custom-made-course/" ogImage={seo.ogImage}>
  <main class="course-detail-page custom-made-page">
    <section class="custom-made-hero" aria-labelledby="custom-made-title">
      <div class="content custom-made-hero__inner">
        <div class="custom-made-hero__copy">
          <img class="custom-made-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <p class="custom-made-eyebrow">Custom-made Course</p>
          <h1 id="custom-made-title">
            <span>授業は最小限に。</span>
            演習中心の学習で急成長するコース
          </h1>
          <p class="custom-made-hero__lead">
            自分のレベルに合った演習ベースのカリキュラムで、医学部合格までの学習量と復習精度を引き上げます。
          </p>
          <div class="custom-made-title-card" aria-label="コース名">
            <p class="custom-made-title-card__jp">オーダーメード演習コース</p>
            <p class="custom-made-title-card__en">Custom-made Course</p>
            <p class="custom-made-title-card__lead">課題管理・質問対応・効果測定を組み合わせた、自走型の医学部受験対策です。</p>
          </div>
          <div class="custom-made-actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <div class="custom-made-hero__visual" aria-hidden="true">
          <div class="custom-made-hero__image-frame">
            <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          </div>
          <div class="custom-made-hero__note">
            <span>授業を増やす前に</span>
            <strong>演習と復習を設計する</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-fit" aria-labelledby="custom-made-fit-title">
      <div class="content custom-made-fit__inner">
        <div class="custom-made-section-head">
          <p>Recommend</p>
          <h2 id="custom-made-fit-title">こんな受験生にオススメです</h2>
        </div>
        <div class="custom-made-fit__grid">
          <ul class="custom-made-check-list">
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
          <div class="custom-made-fit__message">
            <p>
              「授業を受けたのに点が伸びない」状態から抜けるには、問題演習と解き直しの設計が必要です。必要な授業だけを足し、学習の大半を得点につながる演習へ寄せます。
            </p>
            <div class="custom-made-support-tags">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-system" aria-labelledby="custom-made-system-title">
      <div class="content">
        <div class="custom-made-section-head custom-made-section-head--center">
          <p>System</p>
          <h2 id="custom-made-system-title">オーダーメード演習とは？</h2>
          <span>厳しい課題管理 × 質問し放題 × 効果測定 × 必要に応じた個別授業</span>
        </div>
        <div class="custom-made-pillar-grid">
          {pillars.map((pillar) => (
            <article>
              <p class="custom-made-pillar__label">{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="custom-made-plans" aria-labelledby="custom-made-plans-title">
      <div class="content">
        <div class="custom-made-section-head">
          <p>Plans</p>
          <h2 id="custom-made-plans-title">「合格プラン」一覧</h2>
          <span>現在の学力と目標校から、演習量・復習量・サポート密度を調整します。</span>
        </div>
        <div class="custom-made-plan-grid">
          {plans.map((plan, index) => (
            <article>
              <h3>{plan.title}</h3>
              <dl>
                <div>
                  <dt>目標</dt>
                  <dd>{plan.target}</dd>
                </div>
                <div>
                  <dt>入学時の目安</dt>
                  <dd>{plan.level}</dd>
                </div>
                <div>
                  <dt>月額料金</dt>
                  <dd>{plan.price}</dd>
                </div>
              </dl>
              <a class="button button--blue custom-made-plan__link" href={planHrefs[index]}>詳しく見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="custom-made-message" aria-labelledby="custom-made-message-title">
      <div class="content custom-made-message__grid">
        <div>
          <p class="custom-made-eyebrow custom-made-eyebrow--light">Admission Flow</p>
          <h2 id="custom-made-message-title">今は未熟でも、 “自分の医学道”を全力で走りたい。</h2>
          <p>
            その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「オーダーメード演習コース」は、“今”から本気になるあなたを、全力で支えるプランです。
          </p>
          <p class="custom-made-message__sub">無料面談の前に、無料体験を受けることも可能です。</p>
          <div class="custom-made-actions custom-made-actions--left">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <figure>
          <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="custom-made-garden" aria-labelledby="custom-made-garden-title">
      <div class="content custom-made-garden__grid">
        <figure>
          <img src={images.garden} alt="生徒専用寮外観" width="800" height="617" loading="lazy" decoding="async" />
        </figure>
        <div>
          <p class="custom-made-eyebrow">Lexus Garden</p>
          <h2 id="custom-made-garden-title">生徒専用寮のご案内 『LEXUS GARDEN』</h2>
          <p>長期休み中の利用など、最短3日間から利用可能です。学習時間を生活の中に組み込み、演習量を安定させたい方にも適しています。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
      </div>
    </section>

    <section class="custom-made-other" aria-labelledby="custom-made-other-title">
      <div class="content">
        <div class="custom-made-section-head custom-made-section-head--center">
          <p>Other Courses</p>
          <h2 id="custom-made-other-title">他のコース一覧</h2>
        </div>
        <div class="custom-made-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="custom-made-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .custom-made-page {
    --custom-blue: #12356a;
    --custom-blue-dark: #0d2549;
    --custom-gold: #b9983f;
    --custom-green: #0b5b25;
    --custom-cream: #fff8ea;
    --custom-paper: #fffdf8;
    --custom-ink: #211a14;
    background: var(--custom-paper);
    color: var(--custom-ink);
  }

  .custom-made-page :global(.content) {
    width: min(1160px, calc(100% - 48px));
  }

  .custom-made-hero {
    position: relative;
    overflow: hidden;
    margin-top: -35px;
    background:
      linear-gradient(112deg, rgb(13 37 73 / 96%) 0%, rgb(18 53 106 / 94%) 61%, rgb(255 253 248 / 100%) 61%, rgb(248 240 226 / 100%) 100%);
    padding-block: 44px 56px;
  }

  .custom-made-hero::before {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgb(185 152 63 / 28%) 0 1px, transparent 1px 100%),
      linear-gradient(180deg, rgb(185 152 63 / 18%) 0 1px, transparent 1px 100%);
    background-size: 80px 80px;
    content: "";
    opacity: 0.34;
  }

  .custom-made-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.72fr);
    gap: 42px;
    align-items: center;
  }

  .custom-made-hero__copy {
    display: grid;
    gap: 18px;
    color: #fffdf8;
  }

  .custom-made-logo-strip {
    width: min(620px, 100%);
    height: auto;
    background: rgb(255 253 248 / 86%);
  }

  .custom-made-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: var(--custom-gold);
    font-size: 0.88rem;
    font-weight: 900;
    line-height: 1.4;
  }

  .custom-made-eyebrow::before {
    display: inline-block;
    width: 34px;
    height: 1px;
    background: currentcolor;
    content: "";
  }

  .custom-made-eyebrow--light {
    color: #e6c968;
  }

  .custom-made-hero h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.72rem;
    font-weight: 700;
    line-height: 1.22;
  }

  .custom-made-hero h1 span {
    display: block;
    color: #f1d77a;
  }

  .custom-made-hero__lead {
    width: min(580px, 100%);
    margin: 0;
    color: rgb(255 253 248 / 88%);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.9;
  }

  .custom-made-title-card {
    display: grid;
    gap: 8px;
    width: min(600px, 100%);
    border: 1px solid rgb(233 202 108 / 76%);
    border-left: 6px solid var(--custom-gold);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgb(255 253 248 / 96%), rgb(248 240 226 / 92%)),
      var(--custom-paper);
    padding: 20px 22px;
    color: var(--custom-ink);
    box-shadow: 0 22px 52px rgb(0 0 0 / 22%);
  }

  .custom-made-title-card p {
    margin: 0;
  }

  .custom-made-title-card__jp {
    color: var(--custom-blue);
    font-size: 1.25rem;
    font-weight: 900;
  }

  .custom-made-title-card__en {
    border-bottom: 1px solid rgb(185 152 63 / 52%);
    padding-bottom: 8px;
    color: #7d1712;
    font-family: var(--font-serif);
    font-size: 1.95rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .custom-made-title-card__lead {
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.75;
  }

  .custom-made-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .custom-made-actions :global(.button) {
    min-width: 210px;
  }

  .custom-made-actions--left {
    justify-content: flex-start;
    margin-top: 10px;
  }

  .custom-made-hero__visual {
    position: relative;
    display: grid;
    justify-items: center;
    align-self: stretch;
    min-height: 450px;
  }

  .custom-made-hero__image-frame {
    align-self: center;
    width: min(340px, 100%);
    border: 1px solid rgb(185 152 63 / 48%);
    border-radius: 8px;
    background: linear-gradient(180deg, #fffdf8, #f1e5cf);
    padding: 18px;
    box-shadow: 0 28px 58px rgb(58 42 18 / 18%);
  }

  .custom-made-hero__image-frame img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  .custom-made-hero__note {
    position: absolute;
    right: 0;
    bottom: 20px;
    display: grid;
    gap: 3px;
    max-width: 260px;
    border-left: 5px solid var(--custom-gold);
    border-radius: 8px;
    background: #fffdf8;
    padding: 16px 18px;
    box-shadow: 0 20px 42px rgb(58 42 18 / 16%);
  }

  .custom-made-hero__note span {
    color: #7d1712;
    font-size: 0.86rem;
    font-weight: 900;
  }

  .custom-made-hero__note strong {
    color: var(--custom-blue);
    font-size: 1.06rem;
    line-height: 1.45;
  }

  .custom-made-fit,
  .custom-made-system,
  .custom-made-plans,
  .custom-made-message,
  .custom-made-garden,
  .custom-made-other {
    padding-block: 84px;
  }

  .custom-made-fit {
    background: #fffdf8;
  }

  .custom-made-fit__inner,
  .custom-made-fit__grid {
    display: grid;
    gap: 28px;
  }

  .custom-made-fit__grid {
    grid-template-columns: minmax(320px, 0.86fr) minmax(0, 1.14fr);
    align-items: stretch;
  }

  .custom-made-section-head {
    display: grid;
    gap: 8px;
  }

  .custom-made-section-head--center {
    justify-items: center;
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }

  .custom-made-section-head p,
  .custom-made-section-head span {
    margin: 0;
  }

  .custom-made-section-head p {
    color: var(--custom-gold);
    font-size: 0.88rem;
    font-weight: 900;
    line-height: 1.5;
  }

  .custom-made-section-head h2 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .custom-made-section-head span {
    color: #4a3b2a;
    font-weight: 800;
    line-height: 1.8;
  }

  .custom-made-check-list {
    display: grid;
    gap: 12px;
    margin: 0;
    border: 1px solid #e1d3bc;
    border-radius: 8px;
    background: #f8f0e2;
    padding: 24px;
    list-style: none;
  }

  .custom-made-check-list li {
    position: relative;
    margin: 0;
    border-bottom: 1px solid rgb(185 152 63 / 26%);
    padding: 0 0 12px 34px;
    font-size: 1.05rem;
    font-weight: 900;
    line-height: 1.65;
  }

  .custom-made-check-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .custom-made-check-list li::before {
    position: absolute;
    top: 0.38em;
    left: 0;
    display: grid;
    width: 22px;
    height: 22px;
    place-items: center;
    border-radius: 999px;
    background: var(--custom-green);
    color: #fff;
    content: "✓";
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
  }

  .custom-made-fit__message {
    display: grid;
    align-content: center;
    gap: 24px;
    border: 1px solid rgb(18 53 106 / 18%);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgb(18 53 106 / 8%), transparent 44%),
      #fff;
    padding: 30px;
  }

  .custom-made-fit__message p {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.95;
  }

  .custom-made-support-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .custom-made-support-tags span {
    border: 1px solid rgb(185 152 63 / 44%);
    border-radius: 999px;
    background: #fff8ea;
    padding: 8px 13px;
    color: var(--custom-blue);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .custom-made-system {
    background: #f7f1e4;
  }

  .custom-made-pillar-grid,
  .custom-made-plan-grid,
  .custom-made-other-grid {
    display: grid;
    gap: 20px;
    margin-top: 34px;
  }

  .custom-made-pillar-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .custom-made-pillar-grid article,
  .custom-made-plan-grid article,
  .custom-made-other-grid article {
    border: 1px solid #e1d3bc;
    border-radius: 8px;
    background: #fffdf8;
    padding: 24px;
    box-shadow: 0 12px 26px rgb(58 42 18 / 10%);
  }

  .custom-made-pillar-grid article {
    position: relative;
    overflow: hidden;
  }

  .custom-made-pillar-grid article::before {
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: linear-gradient(90deg, var(--custom-blue), var(--custom-gold));
    content: "";
  }

  .custom-made-pillar__label {
    margin: 0 0 24px;
