---
import SectionHeading from "../../../../components/SectionHeading.astro";
import CurriculumPlanner from "../../../../components/course/CurriculumPlanner.astro";
import { customMadePlanLevels } from "../../../../data/customMadeCurriculum";
import { assets, seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "医学部専門 オーダーメード演習コース｜すべてのレベルに対応可能な医学部受験攻略コース";
const description =
  "自学力で医学部合格を狙う、自習特化型コース誕生。参考書ルート・学習計画・進捗管理まで徹底サポート。武田塾式を進化させた、自分で学び切る医学部対策。";

const recommend = [
  "初歩的なレベルを一気に終わらせたい。",
  "反復練習が足りないとよく言われる。",
  "自分好みのハイペースで学習したい。",
  "授業はあまり必要ない。",
  "たくさん過去問を解きたい。",
];

const pillars = [
  {
    label: "01",
    title: "分かるまで質問する",
    body: [
      "演習中の疑問は、その場で講師へ。",
      "答えだけでなく、",
      "考え方のつまずきまで整理します。",
      "「分かったつもり」を残しません。",
    ],
  },
  {
    label: "02",
    title: "できるまで手を動かす",
    body: [
      "理解した内容を、問題で使える状態へ。",
      "類題と解き直しを重ね、",
      "解法を自力で再現できるまで、",
      "繰り返し演習します。",
    ],
  },
  {
    label: "03",
    title: "必要な授業だけを足す",
    body: [
      "質問だけでは補いにくい単元は、",
      "1時間単位の個別授業で補強。",
      "予算や学習状況に応じて、",
      "柔軟に増減できます。",
    ],
  },
];

const supports = ["個別カリキュラム", "課題管理", "質問し放題", "効果測定", "個別授業を追加可能", "受験校選定サポート"];

const plans = [
  {
    title: "トップレベル演習プラン",
    target: "東大、慶應など、医学部のトップ",
    level: "偏差値65相当",
    price: customMadePlanLevels.top.priceLabel,
  },
  {
    title: "ハイレベル演習プラン",
    target: "国公立、慈恵、順天など、難関医学部",
    level: "偏差値60相当",
    price: customMadePlanLevels.high.priceLabel,
  },
  {
    title: "標準レベル演習プラン",
    target: "昭和、東医など上位の私立医学部",
    level: "偏差値55相当",
    price: customMadePlanLevels.standard.priceLabel,
  },
  {
    title: "基礎レベル演習プラン",
    target: "都内の私立医学部など",
    level: "偏差値50相当",
    price: customMadePlanLevels.basic.priceLabel,
  },
  {
    title: "初歩レベル演習プラン",
    target: "高校教科書レベルの知識修得",
    level: "偏差値40台",
    price: customMadePlanLevels.beginner.priceLabel,
  },
  {
    title: "前提レベル演習プラン",
    target: "高校入試レベルの知識習得",
    level: "未習科目あり",
    price: customMadePlanLevels.foundation.priceLabel,
  },
];

const planHrefs = [
  "/top/course/custom-made-course/top-level/",
  "/top/course/custom-made-course/high-level/",
  "/top/course/custom-made-course/standard/",
  "/top/course/custom-made-course/basic/",
  "/top/course/custom-made-course/beginner/",
  "/top/course/custom-made-course/foundation/",
];

const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/top/course/lexus-premiere-course/"],
  ["◆ 高1・高2 対象コース ◆", "メディカル準備コース (高等部)", "Medical Prep Course", "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。", "/top/course/medical-prep/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース (中等部)", "Medical Prep Course", "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];

const heroActions = [
  { label: "お問合せはコチラ", href: "/top/contact/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];

const admissionSteps = [
  {
    number: "01",
    label: "PLAN",
    title: "無料面談で学習プランの相談",
    body: "現在の学力、志望校、生活リズムを確認し、演習中心で伸ばすための方向性を整理します。",
  },
  {
    number: "02",
    label: "TRIAL",
    title: "基礎学力テストと無料体験授業",
    body: "弱点や処理速度を見極め、レクサスの授業・演習管理との相性を実際に確認します。",
  },
  {
    number: "03",
    label: "DESIGN",
    title: "学習プランの決定とお見積り",
    body: "必要な科目、演習量、個別授業の有無を決め、無理のない受講プランに落とし込みます。",
  },
  {
    number: "04",
    label: "START",
    title: "入学手続きへ",
    body: "開始時期と通学スタイルを確定し、医学部合格に向けた演習サイクルを始めます。",
  },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/custom-made-course/" ogImage={seo.ogImage}>
  <main class="course-detail-page custom-made-page">
    <section class="custom-made-summer-hero" aria-labelledby="custom-made-title" data-custom-made-summer-hero>
      <video
        class="custom-made-summer-hero__video"
        src="/assets/course/custom-made-course/summer-hero.mp4"
        muted
        loop
        playsinline
        preload="none"
      ></video>
      <div class="custom-made-summer-hero__shade" aria-hidden="true"></div>

      <div class="content custom-made-summer-act custom-made-summer-act--first" aria-hidden="true">
        <div class="custom-made-summer-first">
          <p class="custom-made-summer-first__eyebrow">LEXUS E.C. SUMMER MANIFESTO</p>
          <p class="custom-made-summer-first__headline">
            <span><span>スマホは捨てて、</span></span>
            <span><strong>合格を掴め！</strong></span>
          </p>
          <div class="custom-made-summer-first__rule"></div>
        </div>
      </div>

      <div class="content custom-made-summer-act custom-made-summer-act--second">
        <div class="custom-made-summer-copy">
          <p class="custom-made-summer-kicker">LEXUS E.C. SUMMER TRAINING</p>
          <p class="custom-made-summer-course">オーダーメード演習コース</p>
          <h1 id="custom-made-title">一問に燃える<br /><strong>オーダーメード夏特訓</strong></h1>
          <p class="custom-made-summer-lead">
            この夏は、逃げ道を減らす。目の前の一問に集中できる環境と、医学部合格から逆算した演習計画をつくります。
          </p>
          <p class="custom-made-summer-period">
            <span>特訓期間：</span>
            <strong>8月1日（土）〜8月31日（月）</strong>
          </p>
          <div class="custom-made-actions custom-made-summer-actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
          <div class="custom-made-summer-meta" aria-label="コースの特徴">
            <span>演習特化</span>
            <span>個別設計</span>
            <span>医学部特化</span>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-fit" aria-labelledby="custom-made-fit-title">
      <div class="content custom-made-fit__inner">
        <div class="custom-made-section-head">
          <p>Recommend</p>
          <h2 id="custom-made-fit-title">こんな受験生にオススメです</h2>
        </div>
        <div class="custom-made-fit__grid">
          <ul class="custom-made-check-list">
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
          <div class="custom-made-fit__message">
            <p>
              「授業を受けたのに点が伸びない」状態から抜けるには、問題演習と解き直しの設計が必要です。必要な授業だけを足し、学習の大半を得点につながる演習へ寄せます。
            </p>
            <div class="custom-made-support-tags">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="premier-ideal custom-made-ideal" aria-labelledby="custom-made-system-title">
      <div class="content premier-ideal__content">
        <div class="premier-ideal__panel">
          <div class="premier-ideal__mark" aria-hidden="true">CUSTOM</div>
          <div class="premier-ideal__copy">
            <p class="premier-ideal__eyebrow">PERSONALIZED PRACTICE SYSTEM</p>
            <h2 id="custom-made-system-title" class="premier-ideal__title" aria-label="オーダーメード演習とは。">
              <span><span>オーダーメード</span></span>
              <span><span>演習とは。</span></span>
            </h2>
            <div class="premier-ideal__rule" aria-hidden="true"></div>
            <p class="premier-ideal__lead">
              週1回（月曜〜土曜から選択）、17時〜21時の4時間をひとつの学習単位に。自習室での演習、課題提示、採点・添削、質問対応を組み合わせ、志望校と現在の学力に合わせた学習サイクルをつくります。
            </p>
            <ul class="premier-ideal__chips" aria-label="オーダーメード演習コースの基本サポート">
              <li>4時間の演習環境</li>
              <li>課題提示・採点添削</li>
              <li>質問対応</li>
              <li>個別授業を追加可能</li>
            </ul>
          </div>
          <div class="premier-ideal-grid">
            {pillars.map((pillar, index) => (
              <article class:list={["premier-ideal-card", { "premier-ideal-card--primary": index === 0 }]}>
                <span class="premier-ideal-card__number">{pillar.label}</span>
                <h3>{pillar.title}</h3>
                <p>{pillar.body.map((line) => <span>{line}</span>)}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <CurriculumPlanner />

    <section class="custom-made-plans" aria-labelledby="custom-made-plans-title">
      <div class="content">
        <div class="custom-made-section-head">
          <p>Plans</p>
          <h2 id="custom-made-plans-title">「合格プラン」一覧</h2>
          <span>現在の学力と目標校から、演習量・復習量・サポート密度を調整します。</span>
        </div>
        <div class="custom-made-plan-grid">
          {plans.map((plan, index) => (
            <article>
              <h3>{plan.title}</h3>
              <dl>
                <div>
                  <dt>目標</dt>
                  <dd>{plan.target}</dd>
                </div>
                <div>
                  <dt>入学時の目安</dt>
                  <dd>{plan.level}</dd>
                </div>
                <div>
                  <dt>月額料金</dt>
                  <dd>{plan.price}</dd>
                </div>
              </dl>
              <a class="button button--blue custom-made-plan__link" href={planHrefs[index]}>詳しく見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="custom-made-message" aria-labelledby="custom-made-message-title">
      <div class="content custom-made-message__grid">
        <div>
          <p class="custom-made-eyebrow custom-made-eyebrow--light">Admission Flow</p>
          <h2 id="custom-made-message-title">今は未熟でも、 “自分の医学道”を全力で走りたい。</h2>
          <p>
            その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「オーダーメード演習コース」は、“今”から本気になるあなたを、全力で支えるプランです。
          </p>
          <p class="custom-made-message__sub">まずは個別相談またはお問い合わせから、現在地に合わせた進め方をご相談ください。</p>
          <div class="custom-made-actions custom-made-actions--left">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <div class="custom-made-flow-card" aria-label="入学までの流れ">
          <div class="custom-made-flow-card__head">
            <p>Admission Steps</p>
            <h3>入学までの流れ</h3>
          </div>
          <ol class="custom-made-flow-steps">
            {admissionSteps.map((step) => (
              <li>
                <span class="custom-made-flow-steps__number">{step.number}</span>
                <div>
                  <small>{step.label}</small>
                  <h4>{step.title}</h4>
                  <p>{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="section location defer-render" aria-labelledby="location-title">
      <div class="content">
        <SectionHeading id="location-title" label="LOCATION" title="東京（渋谷）のレクサスには日本全国から医学部志願者が集まります！" />
        <div class="dorm-layout">
          <div>
            <h3>生徒専用寮のご案内『LEXUS GARDEN』</h3>
            <ul class="dorm-tags">
              <li>渋谷駅 徒歩5分</li>
              <li>校舎直結</li>
              <li>オートロック</li>
              <li>地下自習室完備</li>
              <li>食事あり</li>
              <li>プロ講師常駐</li>
            </ul>
            <p>東京都渋谷の閑静な住宅街にたたずむ医学部受験に集中できる快適空間。校舎と寮が近いから、通学・質問・復習・生活管理まで途切れずに回せます。</p>
          </div>
          <div class="dorm-media">
            <a class="dorm-media__image" href="/top/lexus-garden/">
              <img src={assets.dorm} alt="寮と一体型の校舎 レクサス専用寮外観" width="1024" height="651" loading="lazy" decoding="async" />
            </a>
            <a class="button button--blue" href="/top/lexus-garden/">生徒専用寮を見る</a>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-other" aria-labelledby="custom-made-other-title">
      <div class="content">
        <div class="custom-made-section-head custom-made-section-head--center">
          <p>Other Courses</p>
          <h2 id="custom-made-other-title">他のコース一覧</h2>
        </div>
        <div class="custom-made-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="custom-made-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .custom-made-page {
    --custom-blue: #12356a;
    --custom-blue-dark: #0d2549;
    --custom-gold: #b9983f;
    --custom-green: #0b5b25;
    --custom-cream: #fff8ea;
    --custom-paper: #fffdf8;
    --custom-ink: #211a14;
    background: var(--custom-paper);
    color: var(--custom-ink);
  }

  :global(html.custom-made-summer-page .site-header),
  :global(html.custom-made-summer-page .mega-nav-heading) {
    display: none;
  }

  :global(html.custom-made-summer-page .mega-nav),
  :global(html.custom-made-summer-page .mobile-fixed-nav-wrap) {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    inset: 0 0 auto;
    z-index: 210;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-110%);
    transition:
      transform 520ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 220ms ease;
  }

  :global(html.custom-made-summer-page .mega-nav) {
    background: #fff;
    background: rgb(255 255 255 / 96%);
    box-shadow: 0 18px 42px rgb(17 14 10 / 14%);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
  }

  :global(html.custom-made-summer-nav-visible.custom-made-summer-page .mega-nav),
  :global(html.custom-made-summer-nav-visible.custom-made-summer-page .mobile-fixed-nav-wrap) {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .custom-made-page :global(.content) {
    width: min(1160px, calc(100% - 48px));
  }

  .custom-made-summer-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 720px;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    margin-top: 0;
    background: #250604;
    background:
      radial-gradient(circle at 74% 18%, rgb(255 205 80 / 32%), transparent 30%),
      linear-gradient(140deg, #6d0704, #170705 52%, #06172a);
    color: #fff8e8;
  }

  .custom-made-summer-hero::before,
  .custom-made-summer-hero::after,
  .custom-made-summer-hero__video,
  .custom-made-summer-hero__shade {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    inset: 0;
  }

  .custom-made-summer-hero::before,
  .custom-made-summer-hero::after {
    z-index: 0;
    pointer-events: none;
    content: "";
  }

  .custom-made-summer-hero::before {
    background:
      repeating-linear-gradient(90deg, rgb(255 230 161 / 8%) 0 1px, transparent 1px 84px),
      linear-gradient(180deg, rgb(0 0 0 / 8%), transparent 34%, rgb(0 0 0 / 54%));
  }

  .custom-made-summer-hero::after {
    top: 24px;
    right: 24px;
    bottom: 24px;
    left: 24px;
    inset: clamp(18px, 2.5vw, 34px);
    border: 1px solid rgb(255 232 166 / 34%);
  }

  .custom-made-summer-hero__video {
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.78;
    filter: saturate(1.08) contrast(1.1) brightness(0.78);
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero__video {
    opacity: 0;
    transition: opacity 480ms ease;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-video-ready .custom-made-summer-hero__video {
    opacity: 0.78;
  }

  .custom-made-summer-hero__shade {
    z-index: -1;
    background:
      linear-gradient(180deg, rgb(0 0 0 / 18%) 0%, rgb(0 0 0 / 18%) 40%, rgb(0 0 0 / 76%) 100%),
      linear-gradient(90deg, rgb(23 5 3 / 58%), transparent 50%, rgb(15 3 2 / 42%));
  }

  .custom-made-summer-act {
    position: relative;
    z-index: 2;
    min-height: 720px;
    min-height: 100vh;
    min-height: 100svh;
    padding-top: 104px;
    padding-bottom: 78px;
  }

  .custom-made-summer-act--first {
    display: none;
  }

  .custom-made-summer-act--second {
    display: grid;
    align-items: end;
  }

  .custom-made-summer-copy {
    display: grid;
    justify-items: center;
    width: 100%;
    text-align: center;
  }

  .custom-made-summer-kicker,
  .custom-made-summer-first__eyebrow {
    display: inline-flex;
    width: auto;
    max-width: 100%;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 0 0 14px;
    color: #ffe6a1;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1.4;
  }

  .custom-made-summer-kicker::before,
  .custom-made-summer-first__eyebrow::before {
    display: block;
    width: 52px;
    height: 1px;
    background: #d8b85f;
    content: "";
  }

  .custom-made-summer-course {
    margin: 0 0 16px;
    color: rgb(255 248 232 / 88%);
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.5;
  }

  .custom-made-summer-hero h1 {
    max-width: 1060px;
    margin: 0;
    font-family: var(--font-serif);
    font-size: 4rem;
    font-size: clamp(2.8rem, 8.4vw, 6.4rem);
    font-weight: 700;
    line-height: 1.03;
    text-shadow: 0 18px 44px rgb(0 0 0 / 68%);
  }

  .custom-made-summer-hero h1 strong {
    display: inline-block;
    color: #ffe6a1;
    font-weight: 700;
    white-space: nowrap;
  }

  .custom-made-summer-lead {
    width: 690px;
    max-width: 100%;
    width: min(690px, 100%);
    margin: 24px auto 0;
    color: rgb(255 248 232 / 92%);
    font-size: 1rem;
    font-size: clamp(0.98rem, 1.45vw, 1.16rem);
    font-weight: 800;
    line-height: 1.9;
    text-shadow: 0 10px 28px rgb(0 0 0 / 62%);
  }

  .custom-made-summer-period {
    display: flex;
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 4px 12px;
