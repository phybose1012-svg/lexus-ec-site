---
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "医学部専門 オーダーメード演習コース｜すべてのレベルに対応可能な医学部受験攻略コース";
const description =
  "自学力で医学部合格を狙う、自習特化型コース誕生。参考書ルート・学習計画・進捗管理まで徹底サポート。武田塾式を進化させた、自分で学び切る医学部対策。";

const images = {
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/12/Gemini_Generated_Image_h3qlynh3qlynh3ql-e1764922283465-1024x790.jpg",
};

const recommend = [
  "初歩的なレベルを一気に終わらせたい。",
  "反復練習が足りないとよく言われる。",
  "自分好みのハイペースで学習したい。",
  "授業はあまり必要ない。",
  "たくさん過去問を解きたい。",
];

const pillars = [
  {
    label: "01",
    title: "演習量を、合格ルートに変える",
    body: "参考書や過去問をただ増やすのではなく、目標校と現在地から逆算して、毎週の演習量と復習順を設計します。",
  },
  {
    label: "02",
    title: "課題管理で、自走を止めない",
    body: "やるべき教材、提出ペース、解き直しまでを管理。自習中心でも迷いが出ないように、学習の優先順位を明確にします。",
  },
  {
    label: "03",
    title: "必要な授業だけを足す",
    body: "授業を増やしすぎず、詰まった単元や得点源にしたい科目だけを個別授業で補強できます。",
  },
];

const supports = ["個別カリキュラム", "課題管理", "質問し放題", "効果測定", "個別授業を追加可能", "受験校選定サポート"];

const plans = [
  {
    title: "トップレベル演習プラン",
    target: "東大、慶應など、医学部のトップ",
    level: "偏差値65相当",
    price: "¥18,000～ / 科目",
  },
  {
    title: "ハイレベル演習プラン",
    target: "国公立、慈恵、順天など、難関医学部",
    level: "偏差値60相当",
    price: "¥22,500～ / 科目",
  },
  {
    title: "標準レベル演習プラン",
    target: "昭和、東医など上位の私立医学部",
    level: "偏差値55相当",
    price: "¥28,000～ / 科目",
  },
  {
    title: "基礎レベル演習プラン",
    target: "都内の私立医学部など",
    level: "偏差値50相当",
    price: "¥30,000～ / 科目",
  },
  {
    title: "初歩レベル演習プラン",
    target: "高校教科書レベルの知識修得",
    level: "偏差値40台",
    price: "¥30,000～ / 科目",
  },
  {
    title: "前提レベル演習プラン",
    target: "高校入試レベルの知識習得",
    level: "未習科目あり",
    price: "¥30,000～ / 科目",
  },
];

const planHrefs = [
  "/top/course/custom-made-course/top-level/",
  "/top/course/custom-made-course/high-level/",
  "/top/course/custom-made-course/standard/",
  "/top/course/custom-made-course/basic/",
  "/top/course/custom-made-course/beginner/",
  "/top/course/custom-made-course/foundation/",
];

const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/top/course/lexus-premiere-course/"],
  ["◆ 高1・高2 対象コース ◆", "メディカル準備コース (高等部)", "Medical Prep Course", "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。", "/top/course/medical-prep/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース (中等部)", "Medical Prep Course", "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];

const heroActions = [
  { label: "体験授業はコチラ", href: "/test-entry/", tone: "red" },
  { label: "個別相談はコチラ", href: "/reservation/", tone: "blue" },
];

const flowActions = [
  { label: "無料面談はコチラ", href: "/reservation/", tone: "blue" },
  { label: "無料体験はコチラ", href: "/test-entry/", tone: "red" },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/custom-made-course/" ogImage={seo.ogImage}>
  <main class="course-detail-page custom-made-page">
    <section class="custom-made-summer-hero" aria-labelledby="custom-made-title" data-custom-made-summer-hero>
      <video
        class="custom-made-summer-hero__video"
        src="/assets/course/custom-made-course/summer-hero.mp4"
        muted
        loop
        playsinline
        preload="none"
      ></video>
      <div class="custom-made-summer-hero__shade" aria-hidden="true"></div>

      <div class="content custom-made-summer-act custom-made-summer-act--first" aria-hidden="true">
        <div class="custom-made-summer-first">
          <p class="custom-made-summer-first__eyebrow">LEXUS E.C. SUMMER MANIFESTO</p>
          <p class="custom-made-summer-first__headline">
            <span><span>スマホは捨てて、</span></span>
            <span><strong>合格を掴め！</strong></span>
          </p>
          <div class="custom-made-summer-first__rule"></div>
        </div>
      </div>

      <div class="content custom-made-summer-act custom-made-summer-act--second">
        <div class="custom-made-summer-copy">
          <p class="custom-made-summer-kicker">LEXUS E.C. SUMMER TRAINING</p>
          <p class="custom-made-summer-course">オーダーメード演習コース</p>
          <h1 id="custom-made-title">逃げ道を消して、<br /><strong>一問に燃える夏特訓。</strong></h1>
          <p class="custom-made-summer-lead">
            この夏は、逃げ道を減らす。目の前の一問に集中できる環境と、医学部合格から逆算した演習計画をつくります。
          </p>
          <div class="custom-made-actions custom-made-summer-actions">
            {heroActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
          <div class="custom-made-summer-meta" aria-label="コースの特徴">
            <span>演習特化</span>
            <span>個別設計</span>
            <span>医学部受験</span>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-fit" aria-labelledby="custom-made-fit-title">
      <div class="content custom-made-fit__inner">
        <div class="custom-made-section-head">
          <p>Recommend</p>
          <h2 id="custom-made-fit-title">こんな受験生にオススメです</h2>
        </div>
        <div class="custom-made-fit__grid">
          <ul class="custom-made-check-list">
            {recommend.map((item) => <li>{item}</li>)}
          </ul>
          <div class="custom-made-fit__message">
            <p>
              「授業を受けたのに点が伸びない」状態から抜けるには、問題演習と解き直しの設計が必要です。必要な授業だけを足し、学習の大半を得点につながる演習へ寄せます。
            </p>
            <div class="custom-made-support-tags">
              {supports.map((support) => <span>{support}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="custom-made-system" aria-labelledby="custom-made-system-title">
      <div class="content">
        <div class="custom-made-section-head custom-made-section-head--center">
          <p>System</p>
          <h2 id="custom-made-system-title">オーダーメード演習とは？</h2>
          <span>厳しい課題管理 × 質問し放題 × 効果測定 × 必要に応じた個別授業</span>
        </div>
        <div class="custom-made-pillar-grid">
          {pillars.map((pillar) => (
            <article>
              <p class="custom-made-pillar__label">{pillar.label}</p>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="custom-made-plans" aria-labelledby="custom-made-plans-title">
      <div class="content">
        <div class="custom-made-section-head">
          <p>Plans</p>
          <h2 id="custom-made-plans-title">「合格プラン」一覧</h2>
          <span>現在の学力と目標校から、演習量・復習量・サポート密度を調整します。</span>
        </div>
        <div class="custom-made-plan-grid">
          {plans.map((plan, index) => (
            <article>
              <h3>{plan.title}</h3>
              <dl>
                <div>
                  <dt>目標</dt>
                  <dd>{plan.target}</dd>
                </div>
                <div>
                  <dt>入学時の目安</dt>
                  <dd>{plan.level}</dd>
                </div>
                <div>
                  <dt>月額料金</dt>
                  <dd>{plan.price}</dd>
                </div>
              </dl>
              <a class="button button--blue custom-made-plan__link" href={planHrefs[index]}>詳しく見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="custom-made-message" aria-labelledby="custom-made-message-title">
      <div class="content custom-made-message__grid">
        <div>
          <p class="custom-made-eyebrow custom-made-eyebrow--light">Admission Flow</p>
          <h2 id="custom-made-message-title">今は未熟でも、 “自分の医学道”を全力で走りたい。</h2>
          <p>
            その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「オーダーメード演習コース」は、“今”から本気になるあなたを、全力で支えるプランです。
          </p>
          <p class="custom-made-message__sub">無料面談の前に、無料体験を受けることも可能です。</p>
          <div class="custom-made-actions custom-made-actions--left">
            {flowActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <figure>
          <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
        </figure>
      </div>
    </section>

    <section class="custom-made-garden" aria-labelledby="custom-made-garden-title">
      <div class="content custom-made-garden__grid">
        <figure>
          <img src={images.garden} alt="生徒専用寮外観" width="800" height="617" loading="lazy" decoding="async" />
        </figure>
        <div>
          <p class="custom-made-eyebrow">Lexus Garden</p>
          <h2 id="custom-made-garden-title">生徒専用寮のご案内 『LEXUS GARDEN』</h2>
          <p>長期休み中の利用など、最短3日間から利用可能です。学習時間を生活の中に組み込み、演習量を安定させたい方にも適しています。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
      </div>
    </section>

    <section class="custom-made-other" aria-labelledby="custom-made-other-title">
      <div class="content">
        <div class="custom-made-section-head custom-made-section-head--center">
          <p>Other Courses</p>
          <h2 id="custom-made-other-title">他のコース一覧</h2>
        </div>
        <div class="custom-made-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="custom-made-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .custom-made-page {
    --custom-blue: #12356a;
    --custom-blue-dark: #0d2549;
    --custom-gold: #b9983f;
    --custom-green: #0b5b25;
    --custom-cream: #fff8ea;
    --custom-paper: #fffdf8;
    --custom-ink: #211a14;
    background: var(--custom-paper);
    color: var(--custom-ink);
  }

  :global(body:has(.custom-made-page) .site-header),
  :global(body:has(.custom-made-page) .mega-nav-heading),
  :global(html.custom-made-summer-page .site-header),
  :global(html.custom-made-summer-page .mega-nav-heading) {
    display: none;
  }

  :global(body:has(.custom-made-page) .mega-nav),
  :global(body:has(.custom-made-page) .mobile-fixed-nav-wrap),
  :global(html.custom-made-summer-page .mega-nav),
  :global(html.custom-made-summer-page .mobile-fixed-nav-wrap) {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    inset: 0 0 auto;
    z-index: 210;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  :global(body:has(.custom-made-page) .mega-nav),
  :global(html.custom-made-summer-page .mega-nav) {
    background: #fff;
    background: rgb(255 255 255 / 96%);
    box-shadow: 0 18px 42px rgb(17 14 10 / 14%);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
  }

  .custom-made-page :global(.content) {
    width: min(1160px, calc(100% - 48px));
  }

  .custom-made-summer-hero {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 720px;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    margin-top: 0;
    background: #250604;
    background:
      radial-gradient(circle at 74% 18%, rgb(255 205 80 / 32%), transparent 30%),
      linear-gradient(140deg, #6d0704, #170705 52%, #06172a);
    color: #fff8e8;
  }

  .custom-made-summer-hero::before,
  .custom-made-summer-hero::after,
  .custom-made-summer-hero__video,
  .custom-made-summer-hero__shade {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    inset: 0;
  }

  .custom-made-summer-hero::before,
  .custom-made-summer-hero::after {
    z-index: 0;
    pointer-events: none;
    content: "";
  }

  .custom-made-summer-hero::before {
    background:
      repeating-linear-gradient(90deg, rgb(255 230 161 / 8%) 0 1px, transparent 1px 84px),
      linear-gradient(180deg, rgb(0 0 0 / 8%), transparent 34%, rgb(0 0 0 / 54%));
  }

  .custom-made-summer-hero::after {
    top: 24px;
    right: 24px;
    bottom: 24px;
    left: 24px;
    inset: clamp(18px, 2.5vw, 34px);
    border: 1px solid rgb(255 232 166 / 34%);
  }

  .custom-made-summer-hero__video {
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.78;
    filter: saturate(1.08) contrast(1.1) brightness(0.78);
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero__video {
    opacity: 0;
    transition: opacity 480ms ease;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-video-ready .custom-made-summer-hero__video {
    opacity: 0.78;
  }

  .custom-made-summer-hero__shade {
    z-index: -1;
    background:
      linear-gradient(180deg, rgb(0 0 0 / 18%) 0%, rgb(0 0 0 / 18%) 40%, rgb(0 0 0 / 76%) 100%),
      linear-gradient(90deg, rgb(23 5 3 / 58%), transparent 50%, rgb(15 3 2 / 42%));
  }

  .custom-made-summer-act {
    position: relative;
    z-index: 2;
    min-height: 720px;
    min-height: 100vh;
    min-height: 100svh;
    padding-top: 104px;
    padding-bottom: 78px;
  }

  .custom-made-summer-act--first {
    display: none;
  }

  .custom-made-summer-act--second {
    display: grid;
    align-items: end;
  }

  .custom-made-summer-copy {
    display: grid;
    justify-items: center;
    width: 100%;
    text-align: center;
  }

  .custom-made-summer-kicker,
  .custom-made-summer-first__eyebrow {
    display: inline-flex;
    width: auto;
    max-width: 100%;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 0 0 14px;
    color: #ffe6a1;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1.4;
  }

  .custom-made-summer-kicker::before,
  .custom-made-summer-first__eyebrow::before {
    display: block;
    width: 52px;
    height: 1px;
    background: #d8b85f;
    content: "";
  }

  .custom-made-summer-course {
    margin: 0 0 16px;
    color: rgb(255 248 232 / 88%);
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.5;
  }

  .custom-made-summer-hero h1 {
    max-width: 1060px;
    margin: 0;
    font-family: var(--font-serif);
    font-size: 4rem;
    font-size: clamp(2.8rem, 8.4vw, 6.4rem);
    font-weight: 700;
    line-height: 1.03;
    text-shadow: 0 18px 44px rgb(0 0 0 / 68%);
  }

  .custom-made-summer-hero h1 strong {
    display: inline-block;
    color: #ffe6a1;
    font-weight: 700;
    white-space: nowrap;
  }

  .custom-made-summer-lead {
    width: 690px;
    max-width: 100%;
    width: min(690px, 100%);
    margin: 24px auto 0;
    color: rgb(255 248 232 / 92%);
    font-size: 1rem;
    font-size: clamp(0.98rem, 1.45vw, 1.16rem);
    font-weight: 800;
    line-height: 1.9;
    text-shadow: 0 10px 28px rgb(0 0 0 / 62%);
  }

  .custom-made-summer-actions {
    justify-content: center;
    margin-top: 28px;
  }

  .custom-made-summer-actions :global(.button) {
    min-width: 190px;
    border: 1px solid rgb(255 232 166 / 66%);
    box-shadow: 0 16px 38px rgb(0 0 0 / 38%);
  }

  .custom-made-summer-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .custom-made-summer-meta span {
    border: 1px solid rgb(255 232 166 / 36%);
    background: rgb(6 4 3 / 44%);
    padding: 6px 11px;
    color: #fff4d6;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .custom-made-summer-first {
    width: 100%;
    max-width: 1060px;
    margin: auto;
    text-align: center;
  }

  .custom-made-summer-first__eyebrow {
    margin-bottom: 22px;
  }

  .custom-made-summer-first__headline {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 4rem;
    font-size: clamp(2.8rem, 8.4vw, 7.5rem);
    font-weight: 700;
    line-height: 1.03;
    text-shadow: 0 18px 46px rgb(0 0 0 / 72%);
  }

  .custom-made-summer-first__headline > span {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
  }

  .custom-made-summer-first__headline > span > span,
  .custom-made-summer-first__headline strong {
    display: block;
  }

  .custom-made-summer-first__headline strong {
    color: #ffe6a1;
  }

  .custom-made-summer-first__rule {
    width: 720px;
    max-width: 100%;
    width: min(720px, 100%);
    height: 2px;
    margin: 26px auto 0;
    background: linear-gradient(90deg, transparent, #ffe6a1, #f36b19, transparent);
    box-shadow: 0 0 26px rgb(243 107 25 / 72%);
    transform-origin: center;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-act--first {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    inset: 0;
    display: grid;
    align-items: center;
    pointer-events: none;
    animation: customMadeFirstAct 3.45s ease both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__eyebrow {
    animation: customMadeFirstDetail 2.85s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__headline > span:first-child > span {
    animation: customMadeFirstLineA 3.05s cubic-bezier(0.16, 1, 0.3, 1) 0.14s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__headline > span:last-child > span {
    animation: customMadeFirstLineB 2.92s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__rule {
    animation: customMadeFirstRule 2.7s cubic-bezier(0.16, 1, 0.3, 1) 0.48s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero .custom-made-summer-act--second {
    opacity: 0;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-act--second {
    animation: customMadeSecondAct 1.05s cubic-bezier(0.12, 0.94, 0.18, 1) 3.08s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-copy h1 {
