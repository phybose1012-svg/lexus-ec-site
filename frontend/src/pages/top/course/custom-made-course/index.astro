---
import { defaultPageActions } from "../../../../data/fixedPages";
import { seo } from "../../../../data/home";
import SiteLayout from "../../../../layouts/SiteLayout.astro";

const title = "医学部専門 オーダーメード演習 コース｜すべてのレベルに対応可能な医学部受験攻略コース";
const description =
  "自学力で医学部合格を狙う、自習特化型コース誕生。参考書ルート・学習計画・進捗管理まで徹底サポート。武田塾式を進化させた、自分で学び切る医学部対策。";

const images = {
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  mascot: "/assets/legacy/wp-content/uploads/2025/05/レクサスくん弓.jpg",
  flow: "/assets/legacy/wp-content/uploads/2025/05/入学までの流れ-1-777x1024.jpg",
  garden: "/assets/legacy/wp-content/uploads/2025/12/Gemini_Generated_Image_h3qlynh3qlynh3ql-e1764922283465-1024x790.jpg",
};

const recommend = ["初歩的なレベルを一気に終わらせたい。", "反復練習が足りないとよく言われる。", "自分好みのハイペースで学習したい。", "授業はあまり必要ない。", "たくさん過去問を解きたい。"];
const plans = [
  { title: "トップレベル演習プラン", rows: ["【目標大学】 東大、慶應など、医学部のトップ", "【入学時の学力】 偏差値65相当 (目安)", "【月額料金 】 ¥18,000～/科目"] },
  { title: "ハイレベル演習プラン", rows: ["【目標大学】 国公立、慈恵、順天など、難関医学部", "【入学時の学力】 偏差値60相当 (目安)", "【月額料金】 ¥22,500～/科目"] },
  { title: "標準レベル演習プラン", rows: ["【目標大学】 昭和、東医など上位の私立医学部", "【入学時の学力】 偏差値55相当 (目安)", "【月額料金 】 ¥28,000～/科目"] },
  { title: "基礎レベル演習プラン", rows: ["【目標大学】 都内の私立医学部など", "【入学時の学力】 偏差値50相当 (目安)", "【月額料金】 ¥30,000～/科目"] },
  { title: "初歩レベル演習プラン", rows: ["【目標】 高校教科書レベルの知識修得", "【入学時の学力】 偏差値40台 (目安)", "【月額料金】 ¥30,000～/科目"] },
  { title: "前提レベル演習プラン", rows: ["【目標】 高校入試レベルの知識習得", "【入学時の学力】 未習科目あり", "【月額料金】 ¥30,000～/科目"], heading: "h2" },
];
const otherCourses = [
  ["◆ 既卒生・再受験生 対象フルコース ◆", "レクサス プレミア 本科", "Premier Main Course", "医学部受験を全面的にサポートする“オールインワン”コースです。各科目クラス分けあり。", "/top/course/lexus-premiere-course/"],
  ["◆ 高2・高3 対象コース ◆", "ハイレベル現役合格コース", "High-level GENEKI Course", "慶應、慈恵、順天、日医をはじめとする都内の医学部に現役合格するためのコースです。", "/top/course/high-level-geneki-course/"],
  ["◆ 高1・高2 対象コース ◆", "メディカル準備コース (高等部)", "Medical Prep Course", "医学部受験で優位に立つ先取り学習コースです。慶應、日大の内部進学対策も承ります。", "/top/course/medical-prep/"],
  ["◆ 中学生 対象コース ◆", "メディカル準備コース (中等部)", "Medical Prep Course", "先手必勝！難関医学部を目指す中高一貫カリキュラムの先取り学習コースです。", "/top/course/medical-prep-junior/"],
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/course/custom-made-course/" ogImage={seo.ogImage}>
  <main class="course-detail-page">
    <section class="course-detail-hero course-detail-hero--custom-made">
      <div class="content course-detail-hero__intro course-detail-hero__intro--custom-made">
        <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
        <h1>授業は最小限に<br />演習中心の学習で急成長コース</h1>
        <div class="course-title-card course-title-card--custom-made">
          <p class="course-title-card__jp">オーダーメード演習 コース</p>
          <p class="course-title-card__en">Custom-made Course</p>
          <p class="course-title-card__lead">自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。</p>
        </div>
        <div class="course-detail-hero__actions course-detail-hero__actions--custom-made">
          <a class="button button--blue" href="/reservation/">個別相談はコチラ</a>
        </div>
      </div>
    </section>

    <section class="course-detail-recommend course-detail-recommend--custom-made">
      <div class="content course-detail-recommend__inner">
        <h2>こんな受験生にオススメです！</h2>
        <div class="course-detail-recommend__grid">
          <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
          <ul>
            <li>初歩的なレベルを一気に終わらせたい。</li>
            <li>反復練習が足りないとよく言われる。</li>
            <li>自分好みのハイペースで学習したい。</li>
            <li>授業はあまり必要ない。</li>
            <li>たくさん過去問を解きたい。</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="course-detail-hero">
      <div class="content course-detail-hero__grid">
        <div>
          <img class="course-detail-logo-strip" src={images.logoStrip} alt="ロゴ" width="800" height="58" decoding="async" />
          <h1>授業は最小限に<br />演習中心の学習で急成長コース</h1>
          <h4>オーダーメード演習 コース</h4>
          <p>Custom-made Course</p>
        </div>
        <img src={images.mascot} alt="" width="670" height="670" decoding="async" />
      </div>
    </section>

    <section class="course-detail-recommend">
      <div class="content course-detail-two-column">
        <div>
          <h3>こんな受験生にオススメです！</h3>
          <ul>{recommend.map((item) => <li>{item}</li>)}</ul>
        </div>
        <p>自分のレベルに合った演習ベースのカリキュラムで倍速学習をするコースです。</p>
      </div>
    </section>

    <section class="course-detail-overview">
      <div class="content">
        <h2>コース概要</h2>
        <div class="course-detail-overview-grid">
          <article>
            <h3>● オーダーメード演習 とは？ ●</h3>
            <p>自分に合った学習スタイルを確立して、自習の質を極限まで高めるコースです。</p>
            <p>「厳しい課題管理」 × 「質問し放題」 × 「効果測定」 × 「必要に応じて個別授業」</p>
          </article>
          <article>
            <h3>● 万全のサポート内容 ●</h3>
            <p>個別カリキュラムによる、倍速学習システムです。</p>
            <div class="course-detail-supports"><span>受験校選定サポート</span></div>
          </article>
        </div>
      </div>
    </section>

    <section class="course-detail-curriculum">
      <div class="content">
        <h2>「合格プラン」 一覧</h2>
        <p>まずはご希望の「合格プラン 」を選択して下さい。プランは全部で6種類です。</p>
        <div class="course-detail-plan-grid">
          {plans.map((plan) => (
            <article>
              {plan.heading === "h2" ? <h2>{plan.title}</h2> : <h4>{plan.title}</h4>}
              <ul>{plan.rows.map((row) => <li>{row}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="course-detail-message">
      <div class="content course-detail-message__grid">
        <div>
          <h2>今は未熟でも、 “自分の医学道”を 全力で走りたい。</h2>
          <p>その想いがあるなら、あとは正しい戦略を持つだけ。レクサス教育センターの「オーダーメード演習 コース」は、“今”から本気になるあなたを、全力で支えるプランです。</p>
          <h3>↓ 入学までの流れ ↓</h3>
          <p>※ 「無料面談」の前に、「無料体験 （体験授業）」を受けることも可能です。</p>
          <div class="fixed-hero__actions">
            {defaultPageActions.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
          </div>
        </div>
        <img src={images.flow} alt="入学までの流れ" width="777" height="1024" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-garden">
      <div class="content course-detail-garden__grid">
        <div>
          <h2>生徒専用寮のご案内 『LEXUS GARDEN』</h2>
          <p>長期休み中の利用など、最短3日間～の利用が可能です。</p>
          <a class="button button--green" href="/top/lexus-garden/">設備や費用を見てみる</a>
        </div>
        <img src={images.garden} alt="生徒専用寮外観" width="800" height="617" loading="lazy" decoding="async" />
      </div>
    </section>

    <section class="course-detail-other">
      <div class="content">
        <h2>他のコース 一覧</h2>
        <div class="course-detail-other-grid">
          {otherCourses.map(([category, courseTitle, en, body, href]) => (
            <article>
              <h3>{category}</h3>
              <h4>{courseTitle}</h4>
              <p class="course-detail-other__en">{en}</p>
              <p>{body}</p>
              <a class="button button--blue" href={href}>コースの内容を見る</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
