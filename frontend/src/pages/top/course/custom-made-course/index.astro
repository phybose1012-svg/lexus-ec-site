  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-act--first {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    inset: 0;
    display: grid;
    align-items: center;
    pointer-events: none;
    animation: customMadeFirstAct 3.45s ease both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__eyebrow {
    animation: customMadeFirstDetail 2.85s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__headline > span:first-child > span {
    animation: customMadeFirstLineA 3.05s cubic-bezier(0.16, 1, 0.3, 1) 0.14s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__headline > span:last-child > span {
    animation: customMadeFirstLineB 2.92s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-first__rule {
    animation: customMadeFirstRule 2.7s cubic-bezier(0.16, 1, 0.3, 1) 0.48s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero .custom-made-summer-act--second {
    opacity: 0;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-act--second {
    animation: customMadeSecondAct 1.05s cubic-bezier(0.12, 0.94, 0.18, 1) 3.08s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-copy h1 {
    animation: customMadeSecondHeadline 1s cubic-bezier(0.12, 0.94, 0.18, 1) 3.18s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-course,
  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-lead,
  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-period {
    animation: customMadeSecondDetail 0.84s ease-out 3.42s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-actions,
  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-meta {
    animation: customMadeSecondDetail 0.84s ease-out 3.58s both;
  }

  :global(html.custom-made-summer-enhanced) .custom-made-summer-hero.is-active .custom-made-summer-hero__video {
    animation: customMadeVideoDrift 9s ease-out both;
  }

  @keyframes customMadeFirstAct {
    0%, 76% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes customMadeFirstDetail {
    0% { opacity: 1; transform: translateY(18px); }
    18%, 82% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-14px); }
  }

  @keyframes customMadeFirstLineA {
    0% { opacity: 1; transform: translateY(18px) skewY(4deg); }
    18%, 82% { opacity: 1; transform: translateY(0) skewY(0); }
    100% { opacity: 0; transform: translateY(-35%) skewY(-2deg); }
  }

  @keyframes customMadeFirstLineB {
    0% { opacity: 1; transform: scale(1.12); }
    20%, 82% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(0.96); }
  }

  @keyframes customMadeFirstRule {
    0% { opacity: 0; transform: scaleX(0); }
    20%, 82% { opacity: 1; transform: scaleX(1); }
    100% { opacity: 0; transform: scaleX(0.72); }
  }

  @keyframes customMadeSecondAct {
    from { opacity: 0; transform: translateY(38px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes customMadeSecondHeadline {
    from { opacity: 0; filter: blur(7px); transform: translateY(30px); }
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }

  @keyframes customMadeSecondDetail {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes customMadeVideoDrift {
    from { transform: scale(1.06); }
    to { transform: scale(1); }
  }

