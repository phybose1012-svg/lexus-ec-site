---
import SectionHeading from "../../../components/SectionHeading.astro";
import { seo } from "../../../data/home";
import SiteLayout from "../../../layouts/SiteLayout.astro";

const title = "医学部合格 - 合格メソッド";
const description =
  "医学部合格 - レクサス教育センター - OB、OGの声 - 元々、勉強習慣はありませんでしたが…気がついたら一日中勉強していました。夜間指導は他の塾とは違って、絶対に夜間残らなきゃいけないっていう強制参加制度でしたから、これはよその予備校とはちがうなと思いました。俺一人でやってるとサボっちゃうほうなので。";

const images = {
  oni: "/illustrations/characters/yuki-sensei-cheer.png",
  logoStrip: "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png",
  representative: "/assets/legacy/wp-content/uploads/2025/02/島内T-e1725539542904.jpg",
  mascot: "/assets/legacy/wp-content/uploads/2025/02/新レクサスくん-指さし-2_20240826143701-899x1024.png",
  garden: "/assets/legacy/wp-content/uploads/2026/01/レクサス専用寮外観-1024x651.jpg",
  guide: "/assets/legacy/wp-content/uploads/2025/11/PR用見本2026-1024x1024.jpg",
  studentSato: "/assets/legacy/wp-content/uploads/2024/09/sato.jpg",
  studentAzukihara: "/assets/legacy/wp-content/uploads/2024/09/2019_18img5-e1730739513538.jpg",
  studentKakizaki: "/assets/legacy/wp-content/uploads/2026/03/柿崎-2024-東北医科薬科など.jpg",
};

const universityResults = [
  ["慶應義塾大学", "1名"],
  ["東京慈恵会医科大学", "5名"],
  ["順天堂大学", "8名"],
  ["日本医科大学", "8名"],
  ["関西医科大学", "4名"],
  ["東京医科大学", "16名"],
  ["東邦大学", "14名"],
  ["昭和医科大学", "23名"],
  ["日本大学", "30名"],
  ["杏林大学", "30名"],
  ["帝京大学", "33名"],
  ["東京女子医科大学", "18名"],
  ["東海大学", "22名"],
  ["聖マリアンナ医科大学", "41名"],
  ["国際医療福祉大学", "4名"],
  ["獨協医科大学", "29名"],
  ["埼玉医科大学", "47名"],
  ["東北医科薬科大学", "12名"],
  ["岩手医科大学", "50名"],
  ["愛知医科大学", "10名"],
  ["金沢医科大学", "45名"],
  ["兵庫医科大学", "3名"],
  ["川崎医科大学", "48名"],
  ["久留米大学", "2名"],
];

const stats = [
  { label: "一年で合格する割合", value: "68%", note: "医学部合格" },
  { label: "偏差値60台スタート", value: "100%", note: "医学部合格" },
  { label: "偏差値50台スタート", value: "88%", note: "医学部合格" },
  { label: "合格者の最高年齢", value: "41歳", note: "年齢制限なし" },
];

const quickLinks = [
  { label: "講師紹介", href: "/top/teacher/", tone: "blue" },
  { label: "合格体験記", href: "/top/voice/", tone: "green" },
  { label: "理念と沿革", href: "/top/history/", tone: "red" },
];

const conditions = [
  {
    label: "【条件 その１】",
    title: "勉強を、楽にする。",
    summary:
      "医学部受験では、勉強量を増やすこと自体が最初の壁になります。レクサスでは一日の流れを校舎側で設計し、質問できる環境まで整えることで、勉強を「気合いで耐えるもの」から「毎日続けられる習慣」に変えていきます。",
    focusTitle: "どうせやるなら、思い切りやる",
    focusBody:
      "中途半端な勉強時間では、苦痛だけが残りがちです。一日の大半を勉強に使う環境へ切り替えることで、迷う時間・サボる余地・質問できない不安を減らします。",
    metrics: [
      { label: "年間学習時間", value: "約3500時間" },
      { label: "1日の学習", value: "約13時間" },
      { label: "質問対応", value: "いつでも可能" },
    ],
    points: [
      {
        title: "POINT 1 勉強量を生活の中心に置く",
        body: "「今日は何時間やるか」を毎朝考える状態では、勉強を始めるだけでも消耗します。校舎で過ごす時間を長く取り、勉強する前提の生活に変えることで、学習量を安定させます。",
      },
      {
        title: "POINT 2 できることが増える実感を作る",
        body: "勉強が習慣になると、知識の抜けが埋まり、処理スピードも上がります。成長が見え始めると、勉強は苦痛だけの作業ではなく、前に進んでいる実感を伴う時間になります。",
      },
      {
        title: "POINT 3 疑問をその場で止めない",
        body: "長時間勉強しても、分からない箇所が積み上がれば手は止まります。いつでも質問できる体制を置くことで、つまずきを早く解消し、長時間学習を継続できる状態にします。",
      },
    ],
    testimonial: {
      image: images.studentSato,
      width: 195,
      height: 226,
      alt: "帝京大学医学部に合格した佐藤正則さん",
      lead: "元々、勉強習慣はありませんでしたが、気がついたら一日中勉強していました。",
      quote:
        "夜間指導は他の塾とは違って、絶対に夜間残らなきゃいけないという強制参加制度でした。自分一人だとサボってしまうほうなので、これはよその予備校とは違うなと思いました。",
      name: "佐藤正則さん",
      school: "帝京大学 医学部",
    },
  },
  {
    label: "【条件 その2】",
    title: "課題を、具体化する。",
    summary:
      "医学部受験では、努力量だけでなく「何を、どの順番で、いつまでにやるか」の精度が合否を分けます。レクサスではプロ講師が生徒の学力・目標・性格を見たうえで、毎日の課題まで具体化します。",
    focusTitle: "プロが指示し、迷う時間を勉強時間に変える",
    focusBody:
      "勉強法や参考書選びで悩み続ける時間は、受験生にとって大きな損失です。必要な課題を細かく切り分け、締め切りと確認テストで実行まで管理します。",
    metrics: [
      { label: "確認テスト", value: "合計432回" },
      { label: "演習課題", value: "合計396セット" },
      { label: "模擬試験", value: "実践形式で15回" },
    ],
    points: [
      {
        title: "POINT 1 人によって最適解は違う",
        body: "良い参考書、良い授業、良い勉強法は、目標大学・現在の学力・性格によって変わります。先輩に合った方法が、今の自分にそのまま合うとは限りません。",
      },
      {
        title: "POINT 2 プロが優先順位を決める",
        body: "科目を分かりやすく教えるだけでなく、合格までに必要な順番を見抜くのがプロ講師の役割です。迷っている時間を減らし、いま解くべき課題へ集中させます。",
      },
      {
        title: "POINT 3 毎日の実行単位まで落とす",
        body: "年間計画はそのままだと大きすぎます。レクサスでは課題・確認テスト・復習を日々の単位に分け、締め切りを置くことで、目の前の一題に集中できる状態を作ります。",
      },
    ],
    testimonial: {
      image: images.studentAzukihara,
      width: 990,
      height: 837,
      alt: "埼玉医科大学医学部に合格した小豆原さん",
      lead: "もう迷う必要なし。復習課題まで指定されるので効率的でした。",
      quote:
        "レクサスでは授業と夜間課題がリンクしていました。その日の授業の類題が課題になっていて、それを解くだけで授業の復習になるので本当に効率的でした。",
      name: "小豆原さん",
      school: "埼玉医科大学 医学部",
    },
  },
  {
    label: "【条件 その3】",
    title: "情報戦で、勝つ。",
    summary:
      "医学部入試は大学ごとに問題形式・難度・面接傾向が大きく異なります。ネット上の断片的な情報に振り回されず、プロ講師が入試情報を整理し、出願校選びから二次試験対策まで合格に必要な情報へ変換します。",
    focusTitle: "過去問・出願・面接まで、勝ち方を決める",
    focusBody:
      "正しい情報を持っていても、使い方を誤れば点数にはつながりません。大学別の過去問分析と面談を通じて、本人に合う戦い方へ落とし込みます。",
    metrics: [
      { label: "過去問指導", value: "50年分以上" },
      { label: "出願・面接", value: "5月から準備開始" },
      { label: "担任面談", value: "合計36回" },
    ],
    points: [
      {
        title: "POINT 1 情報の意味を見誤らない",
        body: "医学部入試の情報には、大学発信の事実、予備校の分析、個人の感想が混在します。不安をあおる情報ではなく、合格判断に使える情報だけを選びます。",
      },
      {
        title: "POINT 2 過去問で大学別の勝ち方を知る",
        body: "同じ医学部入試でも、解答形式・問題の難度・時間の厳しさ・目標点は大学ごとに違います。過去問を通じて、自分が合格点を取るための戦い方を決めます。",
      },
      {
        title: "POINT 3 二次試験を直前任せにしない",
        body: "小論文は落とされない書き方、面接は好感度と説得力が重要です。9月から準備を始めることで、主要科目の勉強時間を削りすぎずに仕上げます。",
      },
    ],
    testimonial: {
      image: images.studentKakizaki,
      width: 1064,
      height: 798,
      alt: "東北医科薬科大学医学部に合格した柿崎さん",
      lead: "面接、小論文も迷わない。医師志望理由は意外と難しいです。",
      quote:
        "正直、自分が医師になりたい理由はフワッとしていましたが、9月からじっくり準備して考えがまとまりました。おかげで説得力のある医師志望理由を言語化できました。",
      name: "柿崎さん",
      school: "東北医科薬科大学 医学部",
    },
  },
];
---

<SiteLayout title={title} description={description} canonical="https://lexus-ec.com/top/results/" ogImage={seo.ogImage}>
  <main class="results-page">
    <section class="results-hero">
      <div class="content results-hero__grid">
        <div>
          <p class="results-hero__lead">
            <span>【全医学部受験生へ】</span>
            <span>密度の高い勉強をしませんか？</span>
          </p>
          <h1>医学部合格を叶えるメソッド</h1>
          <p class="results-hero__copy">
            <span>「鬼監理」と「鬼特訓」が</span>
            <span>あなたを劇的に変えます。</span>
            <span>さあ、“勉強の鬼”と化せ！</span>
          </p>
          <strong>レクサス教育センターは元祖“鬼特訓予備校”です。</strong>
        </div>
        <img src={images.oni} alt="鬼特訓イメージキャラクター" width="234" height="260" decoding="async" />
      </div>
    </section>

    <section class="results-achievement" aria-labelledby="results-achievement-title">
      <div class="content">
        <img class="results-logo-strip" src={images.logoStrip} alt="" width="800" height="58" loading="lazy" decoding="async" />
        <header class="results-section-head">
          <p>ACHIEVEMENTS</p>
          <h2 id="results-achievement-title">合格実績</h2>
          <span>～ 一年で合格する割合 ～</span>
        </header>
        <p class="results-achievement__intro">
          レクサスは、厳しい鬼監理・鬼特訓を30年以上続けてきた医学部専門予備校です。少人数の環境で、勉強時間・課題管理・入試情報をまとめて支えます。
        </p>
        <div class="results-stat-grid">
          {stats.map((stat) => (
            <article>
              <p>{stat.label}</p>
              <strong>{stat.value}</strong>
              <span>{stat.note}</span>
            </article>
          ))}
        </div>
        <p class="results-note">※全コースでの募集定員は72名です。</p>
        <h3>合格した大学一覧 (医学部医学科のみ)</h3>
        <ul class="results-university-grid">
          {universityResults.map(([name, count]) => (
            <li><span>{name}</span><strong>{count}</strong></li>
          ))}
        </ul>
        <p class="results-note">※過去6年分 (2021～2026年度) の最終合格者データ</p>
        <div class="results-achievement__actions" aria-label="合格実績ページの補助導線">
          {quickLinks.map((action) => <a class={`button button--${action.tone}`} href={action.href}>{action.label}</a>)}
        </div>
      </div>
    </section>

    <section class="results-conditions" aria-labelledby="results-conditions-title">
      <div class="content">
        <header class="results-section-head">
          <p>METHOD</p>
          <h2 id="results-conditions-title">「3つの条件」</h2>
          <span>最短合格には秘訣があります。</span>
        </header>
        <div class="results-condition-list">
          {conditions.map((condition) => (
            <article class="results-condition">
              <div class="results-condition__intro">
                <div>
                  <h3>{condition.label}</h3>
                  <p class="results-condition__title">{condition.title}</p>
                  <p class="results-condition__summary">{condition.summary}</p>
                </div>
                <ul>
                  {condition.metrics.map((metric) => (
                    <li>
                      <span>{metric.label}</span>
                      <strong>{metric.value}</strong>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="results-condition__focus">
                <h4>{condition.focusTitle}</h4>
                <p>{condition.focusBody}</p>
              </div>

              <div class="results-point-grid">
                {condition.points.map((point) => (
                  <section>
                    <strong>{point.title}</strong>
                    <p>{point.body}</p>
                  </section>
                ))}
              </div>
              <figure class="results-testimonial">
                <img
                  src={condition.testimonial.image}
                  alt={condition.testimonial.alt}
                  width={condition.testimonial.width}
                  height={condition.testimonial.height}
                  loading="lazy"
                  decoding="async"
                />
                <figcaption>
                  <span>合格者の声</span>
                  <strong>{condition.testimonial.lead}</strong>
                  <blockquote>{condition.testimonial.quote}</blockquote>
                  <p>
                    <b>{condition.testimonial.name}</b>
                    <small>{condition.testimonial.school}</small>
                  </p>
                  <a class="button button--red" href="/top/voice/">合格者の声へ</a>
                </figcaption>
              </figure>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="results-message">
      <div class="content results-message__grid">
        <img src={images.representative} alt="レクサス教育センター 代表取締役 島内義仁" width="435" height="533" loading="lazy" decoding="async" />
        <div>
          <h2>さあ勝ちにいこう ！</h2>
          <h2>条件は満たされた。</h2>
          <p>レクサスでは、毎日「何を、いつ、どのように」を明確にしたプランで学習します。受験勉強の苦痛を取り除き、むしろ楽しいと思える状態を作ることで合格に大きく近づきます。</p>
          <img src={images.mascot} alt="レクサスくん(マスコットキャラクター)" width="800" height="911" loading="lazy" decoding="async" />
        </div>
      </div>
    </section>

    <section class="section location" aria-labelledby="results-garden-title">
      <div class="content">
        <SectionHeading id="results-garden-title" label="LOCATION" title="東京（渋谷）のレクサスには日本全国から医学部志願者が集まります！" />
        <div class="dorm-layout">
          <div>
            <h3>生徒専用寮のご案内『LEXUS GARDEN』</h3>
            <ul class="dorm-tags">
              <li>渋谷駅 徒歩5分</li>
              <li>校舎直結</li>
              <li>オートロック</li>
              <li>地下自習室完備</li>
              <li>食事あり</li>
              <li>プロ講師常駐</li>
            </ul>
            <p>東京都渋谷の閑静な住宅街にたたずむ医学部受験に集中できる快適空間。校舎と寮が近いから、通学・質問・復習・生活管理まで途切れずに回せます。</p>
          </div>
          <div class="dorm-media">
            <a class="dorm-media__image" href="/top/lexus-garden/">
              <img src={images.garden} alt="寮と一体型の校舎 レクサス専用寮外観" width="1024" height="651" loading="lazy" decoding="async" />
            </a>
            <a class="button button--blue" href="/top/lexus-garden/">生徒専用寮を見る</a>
          </div>
        </div>
      </div>
    </section>

    <section class="results-guide">
      <div class="content results-guide__grid">
        <img src={images.guide} alt="医学部合格読本 2026" width="800" height="800" loading="lazy" decoding="async" />
        <div>
          <h3>資料請求した方へプレゼント</h3>
          <h2>レクサスのプロ講師と、 レクサスの卒業生が、共同で作りました。</h2>
          <div class="fixed-hero__actions">
            <a class="button button--red" href="/request-documents/">資料請求</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
