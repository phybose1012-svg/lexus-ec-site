      { year: "2023", values: ["15", "3", "-", "-"] },
      { year: "2022", values: ["番号なし", "10", "-", "-"] },
      { year: "2021", values: ["40番台", "10番台", "-", "-"] },
      { year: "2020", values: ["16", "14", "-", "-"] },
      { year: "2019", values: ["50", "14", "-", "-"] },
      { year: "2018", values: ["30", "-", "-", "-"] },
      { year: "2017", values: ["57", "-", "-", "-"] },
      { year: "2015", values: ["88", "7", "-", "-"] },
    ],
    notes: [
      "2022年度は51人以上繰上がり、番号なし受験生まで回りました。",
      "2016〜2018年度は後期試験を実施せず、2019年より再開しました。",
    ],
  },
];

const pageTitle = "医学部 繰上げ合格のQ&A｜繰上げ合格情報｜医学部予備校レクサス";
const pageDescription =
  "医学部入試の正規合格・補欠・繰上げ合格の違い、繰上げ人数の見方、私立医学部の大学別繰上げ合格データを医学部予備校レクサスが整理して解説します。";
---

<SiteLayout title={pageTitle} description={pageDescription} canonical="https://lexus-ec.com/kuriage-information/" ogImage={seo.ogImage}>
  <main class="kuriage-page">
    <section class="kuriage-hero" aria-labelledby="kuriage-title">
      <div class="content kuriage-hero__inner">
        <img
          class="kuriage-hero__logo-strip"
          src="/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png"
          alt=""
          loading="eager"
        />
        <p class="kuriage-hero__eyebrow">WAITLIST Q&A</p>
        <h1 id="kuriage-title">医学部 繰上げ合格のQ&A</h1>
        <p class="kuriage-hero__lead">
          正規合格、補欠、繰上げ合格の違いから、大学別の繰上げデータまで。医学部入試で毎年不安になりやすい数字を、見やすいHTMLの表に整理しました。
        </p>
        <div class="kuriage-hero__actions">
          <a class="button button--red" href="/request-documents/">資料請求</a>
          <a class="button button--blue" href="/reservation/">個別相談</a>
        </div>
      </div>
    </section>

    <nav class="kuriage-nav" aria-label="繰上げ合格Q&Aの目次">
      <div class="content kuriage-nav__grid">
        <a href="#definition">
          <span>QUESTION 01</span>
          <strong>正規・補欠・繰上げ</strong>
        </a>
        <a href="#count">
          <span>QUESTION 02</span>
          <strong>どのくらい繰り上がるか</strong>
        </a>
        <a href="#school-data">
          <span>QUESTION 03</span>
          <strong>大学別データ</strong>
        </a>
      </div>
    </nav>

    <section id="definition" class="kuriage-section kuriage-section--definition">
      <div class="content">
        <div class="kuriage-question">
          <span class="kuriage-question__mark">Q</span>
          <div>
            <p class="kuriage-kicker">QUESTION 01</p>
            <h2>最終？正規？繰上げ合格って何？</h2>
          </div>
        </div>
        <div class="kuriage-answer">
          <p>
            医学部入試の合格者には、慣習として「正規合格者」と「繰上げ合格者」の2種類があります。繰上げ合格も正式な合格であり、入学後の扱いが別になるものではありません。
          </p>
          <p>
            一度の合格発表で入学者全員が確定することは多くありません。辞退者による欠員が出るため、大学は補欠者や追加合格候補者を段階的に繰り上げます。
          </p>
        </div>

        <div class="kuriage-definition-grid" aria-label="合格区分の整理">
          <article>
            <span>01</span>
            <h3>正規合格者</h3>
            <p>合格発表当日の発表時間に合格と判定された受験者。二次試験合格者と同義で使われることがあります。</p>
          </article>
          <article>
            <span>02</span>
            <h3>補欠者</h3>
            <p>欠員が生じたとき、繰上げ合格の対象になり得る受験者。大学によって番号・ランク・群の出し方が異なります。</p>
          </article>
          <article>
            <span>03</span>
            <h3>繰上げ合格者</h3>
            <p>正規合格者の辞退などにより、後から合格となった受験者。補欠合格者・追加合格者と呼ばれることもあります。</p>
          </article>
        </div>

        <div class="kuriage-caution-grid">
          <p>東京医科大学のように「補欠合格」「追加合格」「繰上げ合格」を明確に分ける大学もあります。</p>
          <p>大阪医科薬科大学のように、繰上げ候補者に対して3月に別途二次試験を実施する特殊な運用もあります。</p>
        </div>
      </div>
    </section>

    <section id="count" class="kuriage-section kuriage-section--count">
      <div class="content">
        <div class="kuriage-question">
          <span class="kuriage-question__mark">Q</span>
          <div>
            <p class="kuriage-kicker">QUESTION 02</p>
            <h2>何人くらいが繰り上がるの？</h2>
          </div>
        </div>
        <div class="kuriage-answer">
          <p>
            多い大学・年度では200人前後、少ない大学・年度では5人程度です。大学ごとの募集方式、辞退状況、補欠の公表方法によって大きく変わります。
          </p>
          <p>
            「繰上げ合格者数」「補欠合格者数」は、大学によって意味が揃っていません。表を見るときは、合格者数なのか補欠番号なのか、辞退者を含むのかを必ず確認しましょう。
          </p>
        </div>

        <div class="kuriage-example" aria-label="繰上げ合格者数の見方">
          <div>
            <p class="kuriage-example__label">計算例</p>
            <strong>最終合格者150人 - 正規合格者100人 = 繰上げ合格者50人</strong>
          </div>
          <p>
            ただし、この50人に入学辞退者が含まれない場合があります。大学が実際に連絡した人数は、公式発表の数字より多いこともあります。
          </p>
        </div>
      </div>
    </section>

    <section id="school-data" class="kuriage-section kuriage-section--data">
      <div class="content">
        <div class="kuriage-question">
          <span class="kuriage-question__mark">Q</span>
          <div>
            <p class="kuriage-kicker">QUESTION 03</p>
            <h2>各大学の繰上げ合格者数は？</h2>
          </div>
        </div>
        <div class="kuriage-answer">
          <p>
            調べがつく範囲で、私立医学部の繰上げ合格データを50音順にまとめました。画像ギャラリーではなく、検索・比較しやすいHTML表として再構成しています。
          </p>
          <p>
            「補欠番号」と「繰上げ合格者数」は別物です。数値の意味は大学・年度ごとに異なるため、各カードの注記も合わせて確認してください。
          </p>
        </div>

        <div class="kuriage-school-index" aria-label="大学別データの一覧">
          {waitlistSchools.map((school, index) => <a href={`#school-${index + 1}`}>{school.name}</a>)}
        </div>

        <div class="kuriage-school-grid">
          {
            waitlistSchools.map((school, index) => (
              <article
                id={`school-${index + 1}`}
                class:list={[
                  "kuriage-school-card",
                  `kuriage-school-card--tone-${(index % 4) + 1}`,
                  { "kuriage-school-card--wide": school.columns.length >= 4 },
                ]}
              >
                <header class="kuriage-school-card__header">
                  <p class="kuriage-school-card__eyebrow">{String(index + 1).padStart(2, "0")}</p>
                  <h3>{school.name}</h3>
                  <p>{school.latest}</p>
                </header>
                <div class="kuriage-table-wrap" tabindex="0">
                  <table class="kuriage-data-table">
                    <caption>{school.name}の繰上げ合格情報</caption>
                    <thead>
                      <tr>
                        <th scope="col">年度</th>
                        {school.columns.map((column) => <th scope="col">{column}</th>)}
                      </tr>
                    </thead>
                    <tbody>
                      {
                        school.rows.map((row) => (
                          <tr>
                            <th scope="row">{row.year}</th>
                            {school.columns.map((column, valueIndex) => <td data-label={column}>{row.values[valueIndex] ?? "-"}</td>)}
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>
                {school.notes.length > 0 && (
                  <ul class="kuriage-school-card__notes">
                    {school.notes.map((note) => <li>{note}</li>)}
                  </ul>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="kuriage-cta" aria-labelledby="kuriage-cta-title">
      <div class="content-narrow">
        <p class="kuriage-cta__eyebrow">NEXT STEP</p>
        <h2 id="kuriage-cta-title">繰上げを待つだけでなく、次の判断を早くする。</h2>
        <p>
          補欠番号や繰上げ状況は、志望順位、入学手続き、次年度への準備に直結します。数字だけで迷わず、現在地と選択肢を整理しましょう。
        </p>
        <div class="kuriage-cta__actions">
          <a class="button button--red" href="/request-documents/">資料請求</a>
          <a class="button button--blue" href="/reservation/">個別相談</a>
          <a class="button button--green" href="/top/information-shiritsu/">大学別情報</a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
