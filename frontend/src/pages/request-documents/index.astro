---
import SiteFooter from "../../components/site/SiteFooter.astro";
import PendingFormScript from "../../components/fixed/PendingFormScript.astro";
import SiteHeader from "../../components/site/SiteHeader.astro";
import { seo } from "../../data/home";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages.css";

const title = "資料請求 - 医学部予備校 レクサス E.C.";
const description =
  "資料請求 - レクサス教育センターに関する資料をご郵送します。パンフレット / 医学部情報本 / 出願・面接試験ガイドライン / 入学をご検討中の皆様へ";
const configuredEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT;
const endpoint = configuredEndpoint || "/form-submit";
const localFormAttrs = configuredEndpoint ? {} : { "data-local-form": "pending" };
---

<BaseLayout title={title} description={description} canonical="https://lexus-ec.com/request-documents/" ogImage={seo.ogImage}>
  <SiteHeader />
  <main class="minimal-form-page request-doc-page">
    <section class="request-doc-intro" aria-label="資料請求フォーム案内">
      <div class="logo-strip logo-strip--top" aria-hidden="true"></div>
      <p data-admin-editable="request.intro">必須事項を入力して<br />「送信ボタンを」押してください。</p>
    </section>

    <section class="google-form-lite" aria-label="資料請求フォーム">
      <form action={endpoint} method="post" class="google-form-lite__body" {...localFormAttrs}>
        <input type="hidden" name="formType" value="request-documents" />
        <input type="hidden" name="sourcePath" value="/request-documents/" />
        <input type="text" name="websiteUrl" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;" />

        <div class="google-form-lite__head">
          <h1 class="google-form-lite__title" data-admin-editable="request.form.title">資料請求フォーム</h1>
          <p data-admin-editable="request.form.lead">必須項目を入力してください。</p>
        </div>

        <p class="google-form-lite__required"><em>*</em> は必須項目です</p>

        <label class="google-question">
          <span>メールアドレス <em>*</em></span>
          <input type="email" name="email" required placeholder="メールアドレス" />
        </label>
        <label class="google-question">
          <span>お名前 <em>*</em></span>
          <input type="text" name="name" required />
        </label>
        <label class="google-question">
          <span>氏名ふりがな <em>*</em></span>
          <input type="text" name="kana" required placeholder="やまだ たろう" />
        </label>

        <div class="google-form-lite__extra-grid">
          <label class="google-question google-question--compact">
            <span>電話番号 <em>*</em></span>
            <input type="tel" name="tel" required />
          </label>
          <label class="google-question google-question--compact">
            <span>学年・状況 <em>*</em></span>
            <select name="studentType" required>
              <option value="">選択してください</option>
              <option>既卒生</option>
              <option>高3生</option>
              <option>高2生</option>
              <option>高1生</option>
              <option>中学生</option>
              <option>再受験生</option>
              <option>保護者</option>
            </select>
          </label>
          <label class="google-question google-question--compact">
            <span>郵便番号 <em>*</em></span>
            <input type="text" name="postalCode" required placeholder="150-0031" />
          </label>
          <label class="google-question google-question--compact">
            <span>送付先住所 <em>*</em></span>
            <textarea name="address" required rows="2"></textarea>
          </label>
        </div>

        <label class="google-question">
          <span>備考（任意）</span>
          <textarea name="remarks" rows="3" placeholder="ご質問・ご要望があればご記入ください"></textarea>
        </label>

        <label class="google-question google-question--compact google-question--checkbox">
          <span class="google-checkbox">
            <input type="checkbox" name="privacy" value="同意する" required />
            <span>個人情報の取り扱いに同意します。 <em>*</em></span>
          </span>
        </label>

        <button class="google-form-lite__submit" type="submit" data-admin-editable="request.submit">送信</button>
        <p class="form-submit-note" data-local-form-status hidden></p>
      </form>
    </section>

    <div class="logo-strip logo-strip--bottom" aria-hidden="true"></div>
  </main>
  {!configuredEndpoint && <PendingFormScript />}
  <SiteFooter />

  <script is:inline>
    // 郵便番号 → 住所の自動補完（zipcloud、失敗時は手入力に任せる）
    (() => {
      const zip = document.querySelector('.request-doc-page [name="postalCode"]');
      const addr = document.querySelector('.request-doc-page [name="address"]');
      if (!zip || !addr) return;
      let last = "";
      const lookup = async () => {
        const code = (zip.value || "").replace(/[^0-9]/g, "");
        if (code.length !== 7 || code === last) return;
        last = code;
        try {
          const res = await fetch("https://zipcloud.ibsnet.co.jp/api/search?zipcode=" + code);
          const data = await res.json();
          const r = data && data.results && data.results[0];
          if (!r) return;
          const base = (r.address1 || "") + (r.address2 || "") + (r.address3 || "");
          if (!base) return;
          const cur = addr.value.trim();
          if (!cur) addr.value = base;
          else if (!cur.startsWith(base)) addr.value = base + cur;
          // 続く番地入力のためカーソルを末尾へ
          addr.focus();
          addr.setSelectionRange(addr.value.length, addr.value.length);
        } catch (e) {
          /* ネットワーク不通時は手入力に任せる */
        }
      };
      zip.addEventListener("input", lookup);
      zip.addEventListener("blur", lookup);
    })();
  </script>
</BaseLayout>
