---
import { assets, navGroups } from "../../data/home";

const linkAttrs = (link: { target?: string; rel?: string }) => ({
  target: link.target,
  rel: link.rel ?? (link.target === "_blank" ? "noopener" : undefined),
});
---

<footer class="site-footer">
  <div class="content">
    <p class="site-footer__menu-title">ー MENU ー</p>
    <div class="footer-grid">
      {navGroups.map((group) => (
        <nav aria-label={group.label}>
          <p class="footer-grid__label">{group.label}</p>
          {group.links.map((link) => <a href={link.href} {...linkAttrs(link)}>{link.label}</a>)}
        </nav>
      ))}
      <address>
        <p class="footer-grid__label">CONTACT</p>
        <a href="mailto:info@lexus-ec.com">info@lexus-ec.com</a>
        <a href="tel:03-3477-1306">03-3477-1306</a>
        <p class="footer-grid__label">ACCESS</p>
        <a href="https://maps.app.goo.gl/Yo1p2wJuwUkgrNtPA">寮と一体の校舎「レクサスガーデン」</a>
      </address>
    </div>
  </div>
  <div class="footer-logo-band">
    <img class="footer-logo" src={assets.footerLogo} alt="鬼特訓する医学部予備校レクサスE.C.（レクサス教育センター）" width="1503" height="593" decoding="async" />
  </div>
  <div class="content site-footer__base">
    <small>© LEXUS Education Center</small>
    <a class="site-footer__legal" href="/%e7%89%b9%e5%ae%9a%e5%95%86%e5%8f%96%e5%bc%95%e6%b3%95%e3%81%ab%e5%9f%ba%e3%81%a5%e3%81%8f%e8%a1%a8%e8%a8%98/">特商法に基づく表記</a>
  </div>
</footer>
