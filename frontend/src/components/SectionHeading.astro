---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
  id?: string;
  editableId?: string;
}

const { label, title, subtitle, id, editableId } = Astro.props;
const titleLines = title.split("\n");
---

<header class="section-heading" id={id}>
  <img src="/assets/optimized/jewel-strip-800.webp" alt="" width="800" height="58" loading="lazy" decoding="async" />
  <p>{label}</p>
  <h2 data-admin-editable={editableId || undefined}>
    {titleLines.map((line, index) => (
      <>
        {index > 0 && <br />}
        {line}
      </>
    ))}
  </h2>
  {subtitle && <small>{subtitle}</small>}
</header>
