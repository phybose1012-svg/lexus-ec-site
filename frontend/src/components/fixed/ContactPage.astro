---
import { seo } from "../../data/home";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../site/SiteHeader.astro";
import SiteFooter from "../site/SiteFooter.astro";
import PendingFormScript from "./PendingFormScript.astro";

const title = "お問い合わせ - 医学部予備校 レクサス E.C.";
const description =
  "医学部予備校レクサス教育センターへのお問い合わせ・資料請求はこちら。パンフレットのご請求、個別入塾説明会、校舎・専用寮の見学、無料体験授業のお申し込みを一括で承ります。医学部受験に関するご質問もお気軽にどうぞ。";
const configuredEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT;
const endpoint = configuredEndpoint || "/form-submit";
const localFormAttrs = configuredEndpoint ? {} : { "data-local-form": "pending" };
const mascot = "/assets/legacy/wp-content/uploads/2025/02/新レクサスくん_お辞儀_cropped-979x1024.jpg";
const garden = "/assets/legacy/wp-content/uploads/2025/02/レクサスガーデン-1-04.jpg";
const lineUrl = "https://lin.ee/O4ik2EQ";
---

<BaseLayout title={title} description={description} canonical="https://lexus-ec.com/top/contact/" ogImage={seo.ogImage}>
  <SiteHeader />
  <main class="legacy-contact-page">
    <section class="legacy-contact-hero">
      <div class="legacy-contact-hero__copy">
        <p>CONTACT</p>
        <h1>お問い合わせ</h1>
        <p class="legacy-contact-hero__lead">
          体験授業、個別説明会、校舎・専用寮の見学、医学部受験のご相談まで、目的に合わせてお気軽にご連絡ください。
        </p>
        <ul class="legacy-contact-hero__points" aria-label="お問い合わせ内容">
          <li>体験授業</li>
          <li>個別説明会</li>
          <li>寮の見学</li>
          <li>受験相談</li>
        </ul>
      </div>
      <div class="legacy-contact-hero__mascot" aria-label="お問い合わせのご案内">
        <span>ご質問ください</span>
        <img src={mascot} alt="新レクサスくん_お辞儀_cropped 医学部合格 医学部受験情報 医学部予備校 レクサス教育センター" width="979" height="1024" loading="lazy" decoding="async" />
        <span>なんでも気軽に</span>
      </div>
    </section>

    <section class="legacy-contact-methods" aria-label="お問い合わせ方法">
      <article class="legacy-contact-phone">
        <p class="legacy-contact-card__label">お急ぎの方</p>
        <h2>電話で相談</h2>
        <p>受付時間内は、お電話が一番早くご案内できます。</p>
        <a href="tel:03-3477-1306">03-3477-1306</a>
      </article>

      <article class="legacy-contact-line">
        <p class="legacy-contact-card__label">LINEで相談</p>
        <h2>LINEでもお応えします</h2>
        <p>友だち追加後、説明会・体験授業・受験相談のご希望をそのまま送信できます。</p>
        <a href={lineUrl} target="_blank" rel="noopener noreferrer"><span class="legacy-line-button">LINEで友だち追加</span></a>
      </article>
    </section>

    <section class="legacy-contact-form-block" aria-labelledby="contact-form-heading">
      <p class="legacy-contact-section-label">FORM</p>
      <h2 id="contact-form-heading">お問い合わせフォーム</h2>
      <p class="legacy-contact-form-block__lead">内容を確認後、担当者よりご連絡いたします。</p>
      <form action={endpoint} method="post" class="legacy-contact-form" {...localFormAttrs}>
        <input type="hidden" name="formType" value="contact" />
        <input type="hidden" name="sourcePath" value="/top/contact/" />
        <input type="text" name="websiteUrl" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;" />
        <label>
          <span>お名前 <em>*</em></span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span>メールアドレス <em>*</em></span>
          <input type="email" name="email" required />
        </label>
        <label>
          <span>電話番号</span>
          <input type="tel" name="tel" />
        </label>
        <label>
          <span>学年・状況</span>
          <select name="studentType">
            <option value="">選択してください</option>
            <option>既卒生</option>
            <option>高3生</option>
            <option>高2生</option>
            <option>高1生</option>
            <option>中学生</option>
            <option>再受験生</option>
            <option>保護者</option>
          </select>
        </label>
        <label class="legacy-contact-form__wide">
          <span>ご相談内容 <em>*</em></span>
          <textarea name="message" rows="3" required></textarea>
        </label>
        <label class="legacy-contact-form__privacy">
          <input type="checkbox" name="privacy" value="同意する" required />
          <span>個人情報の取り扱いに同意します。 <em>*</em></span>
        </label>
        <button type="submit">問い合わせる</button>
        <p class="form-submit-note" data-local-form-status hidden></p>
      </form>
    </section>

    <section class="legacy-contact-garden">
      <div class="legacy-contact-garden__copy">
        <p class="legacy-contact-section-label">LEXUS GARDEN</p>
        <h2>校舎と一体の生徒専用寮もご案内できます</h2>
        <p>遠方からの通学、10ヶ月合宿プラン、校舎見学と合わせた内見もご相談ください。</p>
        <a href="/top/lexus-garden/">設備や費用を見る</a>
      </div>
      <img src={garden} alt="レクサスガーデン外観" width="1200" height="800" loading="lazy" decoding="async" />
    </section>
  </main>
  {!configuredEndpoint && <PendingFormScript />}
  <SiteFooter />
</BaseLayout>
