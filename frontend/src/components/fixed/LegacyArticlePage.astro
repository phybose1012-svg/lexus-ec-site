---
import SiteFooter from "../site/SiteFooter.astro";
import SiteHeader from "../site/SiteHeader.astro";
import { seo } from "../../data/home";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/pages.css";
import { extractLegacyContentByPath } from "../../lib/fixedPageSource";

interface Props {
  path: string;
  eyebrow?: string;
  /** If set, the article body starts at the first occurrence of this heading text
   *  (drops the legacy elementor intro: duplicate title / mascot / quick-link buttons). */
  fromHeading?: string;
  /** Optional title/description overrides. */
  title?: string;
  description?: string;
  /** Optional cleaner H1 for the hero (defaults to page.h1). */
  heading?: string;
  /** Medical-school directory pages: apply the .fixed-page--directory styling
   *  + 五十音 tab builder so the university link lists render as tabbed grids. */
  directory?: boolean;
}

const { path, eyebrow = "INFORMATION", fromHeading, title, description, heading, directory = false } = Astro.props;
const page = extractLegacyContentByPath(path);
if (!page) throw new Error(`LegacyArticlePage: no legacy content for ${path}`);

const logoStrip = "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png";
const guideImage = "/assets/legacy/wp-content/uploads/2025/11/PR用見本2026-1024x1024.jpg";

// NB: never string-slice contentHtml (it leaves unbalanced tags that close the
// container early and spill content full-width). The intro is cleaned in the DOM.
void fromHeading;
const body = page.contentHtml;

const bodyWrapClass =
  "fixed-page fixed-page--unstack legacy-article-section" + (directory ? " fixed-page--directory" : "");
---

<BaseLayout
  title={title ?? page.title}
  description={description ?? page.description}
  canonical={page.canonical}
  ogImage={seo.ogImage}
>
  <SiteHeader />
  <main class="legacy-article-page">
    <section class="legacy-article-hero">
      <img class="page-head__strip" src={logoStrip} alt="" width="800" height="58" decoding="async" />
      <p class="page-head__label">{eyebrow}</p>
      <h1 class="page-head__title">{heading ?? page.h1}</h1>
      <span class="page-head__rule" aria-hidden="true"></span>
    </section>

    <section class={bodyWrapClass}>
      <div class="content fixed-source legacy-article-body" set:html={body} />
    </section>

    <section class="access-guide legacy-guide">
      <div class="content access-guide__grid">
        <img src={guideImage} alt="医学部合格読本 2026" width="800" height="800" loading="lazy" decoding="async" />
        <div>
          <h3>資料請求した方へプレゼント</h3>
          <h2>レクサスのプロ講師と、 レクサスの卒業生が、共同で作りました。</h2>
          <p>医学部入試の情報と、レクサスの学習環境を確認したい方は資料請求または個別相談をご利用ください。</p>
          <div class="fixed-hero__actions">
            <a class="button button--red" href="/request-documents/">資料請求</a>
            <a class="button button--blue" href="/reservation/">個別相談</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <SiteFooter />

  <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const root = document.querySelector(".legacy-article-body");
        if (!root) return;
        // The premium hero already shows the page title. Clean the legacy intro:
        // (1) drop any heading that merely repeats the title (e.g. "…（全国版）"),
        // (2) then drop everything before the first real section heading
        //     (mascot, quick-link buttons, decorative pinwheels, intro copy).
        const norm = (s) => (s || "")
          .replace(/[Ａ-Ｚａ-ｚ０-９]/g, (c) => String.fromCharCode(c.charCodeAt(0) - 0xFEE0))
          .replace(/＆/g, "&")
          .replace(/\s+/g, "")
          .trim();
        const heroTitle = norm(document.querySelector(".page-head__title")?.textContent);
        if (heroTitle) {
          Array.from(root.querySelectorAll("h1, h2, h3")).forEach((h) => {
            const t = norm(h.textContent);
            if (!t.startsWith(heroTitle) || t.length > heroTitle.length + 6) return;
            const el = h.closest(".elementor-widget") || h;
            el.remove();
          });
        }
        const firstH2 = root.querySelector("h2");
        if (firstH2) {
          Array.from(root.querySelectorAll("*")).forEach((n) => {
            if (n === firstH2) return;
            const pos = firstH2.compareDocumentPosition(n);
            const precedes = pos & Node.DOCUMENT_POSITION_PRECEDING;
            const isAncestor = pos & Node.DOCUMENT_POSITION_CONTAINS;
            if (precedes && !isAncestor && n.parentElement) n.remove();
          });
        }

        // Remove legacy footer chrome — the page appends polished 資料請求 +
        // related-links sections, so drop the raw duplicates from the content.
        const isDir = !!root.closest(".fixed-page--directory");
        const BTN_RE = /(講師紹介|合格体験記|理念と沿革|資料請求|個別相談|個別説明会|お問い?合せ|お問い合わせ)/;
        root.querySelectorAll(".elementor-widget-button, .elementor-button").forEach((w) => {
          if (!BTN_RE.test(norm(w.textContent))) return;
          const con = w.closest(".elementor-element.e-con");
          const target = con && !con.querySelector("h1, h2, h3, img, .elementor-nav-menu, .elementor-widget-text-editor, iframe") ? con : w;
          if (target && target.parentElement) target.remove();
        });
        const SEC_RE = /(資料請求した方へプレゼント|共同で作りました)/;
        Array.from(root.querySelectorAll("h1, h2, h3")).forEach((h) => {
          if (!SEC_RE.test(norm(h.textContent))) return;
          let sec = h;
          while (sec.parentElement && sec.parentElement !== root && !sec.parentElement.classList.contains("page-content")) {
            if (sec.parentElement.querySelectorAll("h2, h3").length > 1) break;
            sec = sec.parentElement;
          }
          if (sec.parentElement) sec.remove();
        });

        // Section colour-coding + (directory) a consistent header per H2 section:
        // logo-strip divider + a centred black English label.
        {
          const LOGO = "/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png";
          const LABELS = [
            [/共通テスト|ボーダー|足切り/, "PICK UP"],
            [/二次|傾向|難易度|合格ライン/, "ANALYSIS"],
            [/大学基本情報|基本情報/, "BASIC"],
            [/更新/, "NEWS"],
            [/専用寮|GARDEN|ガーデン/, "DORMITORY"],
            [/面接|志望理由/, "INTERVIEW"],
            [/ホンネ|医大生|現役/, "REAL VOICE"],
            [/入試問題|傾向と対策/, "TREND"],
          ];
          const labelFor = (t) => { for (const [re, l] of LABELS) if (re.test(t)) return l; return "INFORMATION"; };
          const seen = new Set();
          let i = 0;
          Array.from(root.querySelectorAll("h2")).forEach((h) => {
            let sec = h;
            while (
              sec.parentElement &&
              sec.parentElement !== root &&
              !sec.parentElement.classList.contains("page-content") &&
              sec.parentElement.querySelectorAll("h2").length <= 1
            ) {
              sec = sec.parentElement;
            }
            if (seen.has(sec) || sec === root) return;
            seen.add(sec);
            sec.classList.add("lap-sec", i % 2 ? "lap-sec--b" : "lap-sec--a");
            if (isDir) {
              // Drop the inconsistent legacy black chips; we add a uniform one.
              sec.querySelectorAll(".elementor-widget-heading:not(.e-transform) p.elementor-heading-title").forEach((c) => {
                if ((c.textContent || "").trim().length > 18) return;
                (c.closest(".elementor-widget-heading") || c).remove();
              });
              const head = document.createElement("div");
              head.className = "lap-sechead";
              if (i > 0) {
                const strip = document.createElement("img");
                strip.className = "lap-sechead__strip";
                strip.src = LOGO;
                strip.alt = "";
                strip.setAttribute("aria-hidden", "true");
                head.appendChild(strip);
              }
              const chip = document.createElement("p");
              chip.className = "lap-sechead__label";
              chip.textContent = labelFor(norm(h.textContent));
              head.appendChild(chip);
              sec.insertBefore(head, sec.firstChild);
            }
            i++;
          });
        }

        // Directory pages only: build the 五十音 tabs from the university lists.
        if (!isDir) return;
        const ROW_RE = /^[ァ-ヶ・ー]+行$/;
        const findLabel = (w) => {
          let node = w;
          while (node && node !== root) {
            let prev = node.previousElementSibling;
            while (prev) {
              const te = prev.matches(".elementor-widget-text-editor") ? prev : prev.querySelector(".elementor-widget-text-editor");
              const el = te || prev;
              const t = (el.textContent || "").trim();
              if (t && t.length <= 16) return { label: t.replace(/の大学$/, ""), el };
              prev = prev.previousElementSibling;
            }
            node = node.parentElement;
          }
          return { label: "", el: null };
        };
        const menuItems = (nav) => Array.from(nav.querySelectorAll(".elementor-nav-menu--main a")).map((a) => (a.textContent || "").trim()).filter(Boolean);
        const nameToRow = {};
        root.querySelectorAll(".elementor-widget-nav-menu").forEach((nav) => {
          if (!nav.querySelector(".elementor-nav-menu--main")) return;
          const { label } = findLabel(nav);
          if (ROW_RE.test(label)) menuItems(nav).forEach((n) => { if (!(n in nameToRow)) nameToRow[n] = label; });
        });
        const rowEntries = Object.entries(nameToRow).sort((a, b) => b[0].length - a[0].length);
        const inferRow = (text) => {
          if (nameToRow[text]) return nameToRow[text];
          for (const [name, row] of rowEntries) if (text.includes(name)) return row;
          return "";
        };
        const resolveRow = (nav, rawLabel) => {
          if (ROW_RE.test(rawLabel)) return rawLabel;
          const counts = {};
          let best = "", bestN = 0;
          menuItems(nav).forEach((n) => {
            const r = inferRow(n);
            if (!r) return;
            counts[r] = (counts[r] || 0) + 1;
            if (counts[r] > bestN) { bestN = counts[r]; best = r; }
          });
          return best;
        };
        const flow = Array.from(root.querySelectorAll("h2, .elementor-widget-nav-menu"));
        const sections = new Map();
        let current = "__top__";
        flow.forEach((el) => {
          if (el.tagName === "H2") { current = el; return; }
          if (!el.querySelector(".elementor-nav-menu--main")) return;
          const { label: rawLabel, el: labelEl } = findLabel(el);
          const row = resolveRow(el, rawLabel);
          if (!row) return;
          const ownRow = ROW_RE.test(rawLabel);
          if (!sections.has(current)) sections.set(current, []);
          sections.get(current).push({ widget: el, label: row, labelEl: ownRow ? labelEl : null });
        });
        sections.forEach((items) => {
          if (items.length < 2) return;
          if (new Set(items.map((g) => g.label)).size < 2) return;
          const longText = items.some((g) => menuItems(g.widget).some((n) => n.length > 12));
          const anchor = items[0].widget.closest(".elementor-element.e-con") || items[0].widget;
          const bar = document.createElement("div");
          bar.className = "dir-tabs";
          bar.setAttribute("role", "tablist");
          const panelWrap = document.createElement("div");
          panelWrap.className = "dir-tab-panels";
          items.forEach((it, i) => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "dir-tab" + (i === 0 ? " is-active" : "");
            btn.textContent = it.label;
            btn.setAttribute("role", "tab");
            btn.setAttribute("aria-selected", i === 0 ? "true" : "false");
            const panel = document.createElement("div");
            panel.className = "dir-tab-panel" + (longText ? " dir-tab-panel--list" : "");
            if (i !== 0) panel.hidden = true;
            if (it.labelEl) it.labelEl.remove();
            panel.appendChild(it.widget);
            panelWrap.appendChild(panel);
            btn.addEventListener("click", () => {
              bar.querySelectorAll(".dir-tab").forEach((b) => {
                b.classList.remove("is-active");
                b.setAttribute("aria-selected", "false");
              });
              btn.classList.add("is-active");
              btn.setAttribute("aria-selected", "true");
              panelWrap.querySelectorAll(".dir-tab-panel").forEach((p) => { p.hidden = true; });
              panel.hidden = false;
            });
            bar.appendChild(btn);
          });
          anchor.parentElement.insertBefore(bar, anchor);
          anchor.parentElement.insertBefore(panelWrap, anchor);
        });
      });
    </script>
</BaseLayout>
