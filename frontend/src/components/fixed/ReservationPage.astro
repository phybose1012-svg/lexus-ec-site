---
import { seo } from "../../data/home";
import { curriculumPlannerStorageKey } from "../../data/customMadeCurriculum";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../site/SiteHeader.astro";
import SiteFooter from "../site/SiteFooter.astro";
import PendingFormScript from "./PendingFormScript.astro";

interface Props {
  canonical: string;
  sourcePath: string;
}

const { canonical, sourcePath } = Astro.props;
const title = "個別説明会予約 - 医学部予備校 レクサス E.C.";
const description =
  "レクサス教育センター - プロの講師が分かりやすくご説明します。 - レクサスのシステム説明- 進路相談 - 学習相談 - 気になることをお気軽にご相談ください。体験授業、特待生コースの選抜テストのお申込みも承ります。 - 医学部予備校 - 専用寮あり";
const configuredEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT;
const endpoint = configuredEndpoint || "/form-submit";
const localFormAttrs = configuredEndpoint ? {} : { "data-local-form": "pending" };
const mascot = "/assets/legacy/wp-content/uploads/2025/02/新レクサスくん-指さし-2_20240826143701-899x1024.png";
const studentOptions = ["高校1年", "高校2年", "高校3年", "1浪目", "2浪目", "3浪以上", "再受験生", "大学生", "社会人", "その他"];
const countOptions = ["1名", "2名", "3名", "4名", "5名以上"];
const timeOptions = ["9:30 ～ 11:00", "11:30 ～ 13:00", "13:30 ～ 15:00", "15:30 ～ 17:00", "17:30 ～ 19:00", "19:30 ～ 21:00"];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={seo.ogImage}>
  <SiteHeader />
  <main class="legacy-reservation-page">
    <section class="reservation-lead" aria-label="無料面談のご予約">
      <div class="reservation-lead__copy">
        <img class="page-head__strip" src="/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png" alt="" width="800" height="58" decoding="async" />
        <p class="page-head__label">RESERVATION</p>
        <h1 class="reservation-lead__title page-head__title" data-admin-editable="reservation.title">無料面談のご予約</h1>
        <span class="page-head__rule" aria-hidden="true"></span>
        <p class="reservation-lead__body" data-admin-editable="reservation.lead">
          体験授業や入学をご検討の方は、<br />
          まず無料面談をご予約下さい。<br />
          詳しくご説明いたします。
        </p>
        <ul class="reservation-lead__tags" aria-label="ご相談内容">
          <li>オンライン可</li>
          <li>渋谷校舎で相談</li>
          <li>寮の内見も相談可</li>
        </ul>
      </div>
      <div class="reservation-mascot-row" aria-label="予約のご案内">
        <p class="reservation-speech reservation-speech--left" data-admin-editable="reservation.mascot.left">お気軽にどうぞ</p>
        <img src={mascot} alt="レクサスくん(マスコットキャラクター)" width="899" height="1024" loading="lazy" decoding="async" />
        <p class="reservation-speech reservation-speech--right" data-admin-editable="reservation.mascot.right">毎日実施中</p>
      </div>
      <p class="reservation-lead__notice" data-admin-editable="reservation.notice">
        必須事項を入力して<br />
        「予約する」ボタンを押して下さい。
      </p>
    </section>

    <section class="reservation-form-wrap" id="reservation-form" aria-label="個別説明会予約フォーム">
      <p class="reservation-form-handoff" data-curriculum-handoff-status hidden>
        作成した仮カリキュラムを備考欄へ引き継ぎました。内容は予約前に編集できます。
      </p>
      <form action={endpoint} method="post" class="legacy-reservation-form" {...localFormAttrs}>
        <input type="hidden" name="formType" value="reservation" />
        <input type="hidden" name="sourcePath" value={sourcePath} />
        <input type="text" name="websiteUrl" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;" />

        <label class="legacy-reservation-field">
          <span>参加者（代表者）の氏名 <em>*</em></span>
          <input type="text" name="name" required placeholder="田中　小太郎" />
        </label>
        <label class="legacy-reservation-field">
          <span>よみがな <em>*</em></span>
          <input type="text" name="kana" required placeholder="たなか　こたろう" />
        </label>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>現在どれが当てはまりますか？ <em>*</em></legend>
          {studentOptions.map((option) => (
            <label><input type="radio" name="studentType" value={option} required />{option}</label>
          ))}
        </fieldset>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>ご希望の面談方式は？</legend>
          <label><input type="checkbox" name="style" value="オンライン" />オンライン</label>
          <label><input type="checkbox" name="style" value="対面" />対面(渋谷の校舎で)</label>
        </fieldset>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>何名でご参加しますか？ <em>*</em></legend>
          {countOptions.map((option) => (
            <label><input type="radio" name="participants" value={option} required />{option}</label>
          ))}
        </fieldset>
        <label class="legacy-reservation-field">
          <span>ご連絡先(メールアドレス) <em>*</em></span>
          <input type="email" name="email" required placeholder="予約内容の確認メールをお送りします。" />
        </label>
        <label class="legacy-reservation-field">
          <span>ご連絡先(電話番号) <em>*</em></span>
          <input type="tel" name="tel" required placeholder="メール連絡で問題が生じた場合に限り、お電話で予約確認をいたします。" />
        </label>
        <label class="legacy-reservation-field">
          <span>ご希望の日程は？(第一希望) <em>*</em></span>
          <input type="date" name="preferredDate1" required />
        </label>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>ご希望の時間帯は？(第一希望) <em>*</em></legend>
          {timeOptions.map((option) => (
            <label><input type="radio" name="preferredTime1" value={option} required />{option}</label>
          ))}
        </fieldset>
        <label class="legacy-reservation-field">
          <span>ご希望の日程は？(第二希望) <em>*</em></span>
          <input type="date" name="preferredDate2" required />
        </label>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>ご希望の時間帯は？(第二希望) <em>*</em></legend>
          {timeOptions.map((option) => (
            <label><input type="radio" name="preferredTime2" value={option} required />{option}</label>
          ))}
        </fieldset>
        <fieldset class="legacy-reservation-field legacy-reservation-field--radio">
          <legend>寮の内見を希望しますか？※対面の方のみご回答ください。</legend>
          <label><input type="checkbox" name="gardenVisit" value="はい" />はい</label>
          <label><input type="checkbox" name="gardenVisit" value="いいえ" />いいえ</label>
          <label><input type="checkbox" name="gardenVisit" value="検討中" />検討中</label>
        </fieldset>
        <label class="legacy-reservation-field">
          <span>備考・ご相談内容</span>
          <textarea name="message" rows="4" placeholder="「こんな事を聞きたい！」など、ご要望があればご記入ください(空欄でもOKです)"></textarea>
        </label>

        <button class="legacy-reservation-submit" type="submit" data-admin-editable="reservation.submit">予約する</button>
        <p class="form-submit-note" data-local-form-status hidden></p>
      </form>
    </section>

    <section class="reservation-phone" aria-label="電話予約">
      <p data-admin-editable="reservation.phone.label">【お電話でもご予約承ります】</p>
      <a href="tel:03-3477-1306">03-3477-1306</a>
      <p data-admin-editable="reservation.phone.hours">受付時間：10時00分～21時00分</p>
    </section>

    <nav class="legacy-pill-nav" aria-label="関連ページ">
      <a class="legacy-pill-nav__blue" href="/top/teacher/">講師紹介</a>
      <a class="legacy-pill-nav__green" href="/top/voice/">合格体験記</a>
      <a class="legacy-pill-nav__red" href="/top/history/">理念と沿革</a>
    </nav>

    <div class="reservation-reject-modal" id="reservation-reject-modal" role="alertdialog" aria-modal="true" aria-labelledby="reservation-reject-title" hidden>
      <div class="reservation-reject-modal__card">
        <h2 id="reservation-reject-title">ご予約について</h2>
        <p>このフォームは医学部受験生やその保護者様のためのフォームです。それ以外の方からのお問合せはご遠慮いただいております。</p>
        <p class="reservation-reject-modal__sub">
          医学部受験に関するご予約でこの表示が出た場合は、お手数ですがお電話（<a href="tel:0334771306">03-3477-1306</a>）にてご連絡ください。
        </p>
        <button type="button" class="reservation-reject-modal__close">閉じる</button>
      </div>
    </div>
  </main>
  {!configuredEndpoint && <PendingFormScript />}
  <SiteFooter />

  <style>
    .reservation-reject-modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: grid;
      place-items: center;
      padding: 20px;
      background: rgba(20, 16, 10, 0.55);
    }

    /* display:grid が hidden 属性(UAのdisplay:none)に勝ってしまうため明示する */
    .reservation-reject-modal[hidden] {
      display: none;
    }

    .reservation-reject-modal__card {
      max-width: 460px;
      background: #fff;
      border-radius: 18px;
      padding: 30px 26px 26px;
      text-align: center;
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.25);
    }

    .reservation-reject-modal__card h2 {
      margin: 0 0 14px;
      font-size: 1.1rem;
      color: #1e1a18;
    }

    .reservation-reject-modal__card p {
      margin: 0 0 12px;
      line-height: 1.9;
      font-size: 0.92rem;
      text-align: left;
    }

    .reservation-reject-modal__sub {
      color: #6b6255;
      font-size: 0.82rem;
    }

    .reservation-reject-modal__sub a {
      color: #b91c1c;
      font-weight: 700;
    }

    .reservation-reject-modal__close {
      margin-top: 8px;
      border: 0;
      border-radius: 999px;
      background: #1a1a1a;
      color: #fff;
      font-weight: 700;
      padding: 11px 40px;
      cursor: pointer;
    }

    .reservation-form-handoff {
      max-width: 760px;
      margin: 0 auto 20px;
      border: 1px solid rgba(11, 91, 37, 0.28);
      border-radius: 8px;
      background: #eef8ef;
      padding: 12px 16px;
      color: #0b5b25;
      font-weight: 800;
      line-height: 1.7;
      text-align: left;
    }
  </style>

  <script is:inline define:vars={{ curriculumPlannerStorageKey }}>
    (() => {
      if (!window.URLSearchParams || !window.sessionStorage) return;
      const params = new URLSearchParams(window.location.search);
      if (params.get("from") !== "curriculum-planner") return;

      let payload;
      try {
        payload = JSON.parse(window.sessionStorage.getItem(curriculumPlannerStorageKey) || "null");
      } catch {
        return;
      }
      if (!payload || payload.version !== 1 || typeof payload.summary !== "string") return;
      if (!payload.summary || payload.summary.length > 6000) return;

      const form = document.querySelector(".legacy-reservation-form");
      const message = form && form.querySelector('textarea[name="message"]');
      const status = document.querySelector("[data-curriculum-handoff-status]");
      if (!message) return;

      const consultationRequest = "詳しい説明や中期的、長期的な計画についても聞いてみたいです。";
      if (!message.value.trim()) {
        message.value = `${payload.summary}\n\n${consultationRequest}`;
        message.rows = 14;
      }
      if (status) status.hidden = false;
    })();
  </script>

  <script is:inline>
    // 送信をいったんfetchで審査に回し、営業・いたずら判定なら受け付けずモーダルを出す。
    (() => {
      const form = document.querySelector(".legacy-reservation-form");
      const modal = document.getElementById("reservation-reject-modal");
      if (!form || !modal || form.dataset.localForm === "pending") return;
      modal.querySelector(".reservation-reject-modal__close").addEventListener("click", () => {
        modal.hidden = true;
      });
      let submitting = false;
      form.addEventListener("submit", async (event) => {
        if (submitting) return; // フォールバックのネイティブ送信はそのまま通す
        event.preventDefault();
        const button = form.querySelector('button[type="submit"]');
        const original = button.textContent;
        button.disabled = true;
        button.textContent = "送信中…";
        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: new URLSearchParams(new FormData(form)),
            headers: { "X-Form-Fetch": "1" },
          });
          if (response.status === 403 && response.headers.get("X-Form-Rejected")) {
            button.disabled = false;
            button.textContent = original;
            modal.hidden = false;
            return;
          }
          const html = await response.text();
          document.open();
          document.write(html);
          document.close();
        } catch (error) {
          // ネットワーク断などfetchが失敗したときはネイティブ送信にフォールバック
          submitting = true;
          button.disabled = false;
          button.textContent = original;
          form.submit();
        }
      });
    })();
  </script>
</BaseLayout>
