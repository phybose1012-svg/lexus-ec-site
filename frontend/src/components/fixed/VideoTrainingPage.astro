---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { videoTrainingPages, type VideoTrainingPageData } from "../../data/videoTrainingPages";
import "../../styles/video-training.css";

interface Props {
  page: VideoTrainingPageData;
}

const { page } = Astro.props;
const videoCount = page.sections.reduce((total, section) => total + section.videos.length, 0);
const seriesPages = Object.values(videoTrainingPages);
---

<SiteLayout title={page.title} description={page.description} canonical={page.canonical} ogImage={page.ogImage}>
  <main class={`video-training video-training--${page.slug}`}>
    <section class="vt-hero" aria-labelledby="vt-title">
      <div class="vt-hero__inner">
        <div class="vt-hero__copy">
          <img
            class="vt-logo-strip"
            src="/assets/legacy/wp-content/uploads/2024/11/背景ロゴだらけメニュー透明3-1024x74.png"
            alt=""
            width="800"
            height="58"
            fetchpriority="high"
            decoding="async"
          />
          <p class="vt-eyebrow">{page.eyebrow}</p>
          <p class="vt-label">{page.label}</p>
          <h1 id="vt-title">{page.heading}</h1>
          <p class="vt-lead">{page.lead}</p>
          <div class="vt-hero__actions">
            <a class="button button--red" href="#video-list">動画一覧を見る</a>
            <a class="button button--blue" href="/reservation/">個別相談する</a>
          </div>
        </div>

        <figure class="vt-hero__visual">
          <img src={page.heroImage} alt={page.heroAlt} width="1024" height="576" fetchpriority="high" decoding="async" />
          {page.characterImage && (
            <img class="vt-character" src={page.characterImage} alt={page.characterAlt || ""} width="536" height="797" loading="lazy" decoding="async" />
          )}
        </figure>
      </div>
    </section>

    <section class="vt-summary" aria-label="教材の概要">
      <div class="vt-summary__inner">
        <article>
          <span>THEME</span>
          <strong>{page.theme}</strong>
        </article>
        <article>
          <span>VOLUME</span>
          <strong>{page.format}</strong>
        </article>
        <article>
          <span>GOAL</span>
          <strong>{page.outcome}</strong>
        </article>
      </div>
    </section>

    <nav class="vt-series" aria-labelledby="vt-series-title">
      <div class="vt-series__inner">
        <div class="vt-series__head">
          <p class="vt-section-kicker">VIDEO SERIES</p>
          <h2 id="vt-series-title">関連する動画教材</h2>
        </div>
        <div class="vt-series__grid">
          {seriesPages.map((seriesPage) => {
            const isCurrent = seriesPage.slug === page.slug;
            return (
              <a class:list={["vt-series-card", { "is-current": isCurrent }]} href={`/${seriesPage.slug}/`} aria-current={isCurrent ? "page" : undefined}>
                <span class="vt-series-card__status">{isCurrent ? "表示中" : "移動する"}</span>
                <span class="vt-series-card__label">{seriesPage.label}</span>
                <strong>{seriesPage.theme}</strong>
                <small>{seriesPage.format} / {seriesPage.outcome}</small>
              </a>
            );
          })}
        </div>
      </div>
    </nav>

    <section class="vt-intro" aria-labelledby="vt-intro-title">
      <div class="vt-intro__inner">
        <p class="vt-section-kicker">TRAINING POLICY</p>
        <h2 id="vt-intro-title">{page.introTitle}</h2>
        <p>{page.introBody}</p>
        <ul class="vt-use-list">
          <li>動画で考え方を確認</li>
          <li>手元で同じ問題を再現</li>
          <li>詰まった箇所を質問で解消</li>
        </ul>
      </div>
    </section>

    <section class="vt-library" id="video-list" aria-labelledby="vt-library-title">
      <div class="vt-library__head">
        <p class="vt-section-kicker">VIDEO LIBRARY</p>
        <h2 id="vt-library-title">動画教材一覧</h2>
        <p>{videoCount}本の動画を、単元ごとに整理しました。再生ボタンを押した動画だけを読み込む軽量仕様です。</p>
      </div>

      {page.sections.map((section) => (
        <section class="vt-video-section" aria-labelledby={`${section.id}-title`}>
          <div class="vt-video-section__head">
            <span>{section.label}</span>
            <div>
              <h3 id={`${section.id}-title`}>{section.title}</h3>
              <p>{section.description}</p>
            </div>
          </div>
          <div class="vt-video-grid">
            {section.videos.map((video, index) => {
              const ordinal = String(index + 1).padStart(2, "0");
              const watchUrl = `https://www.youtube.com/watch?v=${video.youtubeId}`;
              const thumbnailUrl = `/assets/video-thumbnails/${video.youtubeId}.jpg`;
              return (
                <article class="vt-video-card">
                  <div class="vt-video-card__media" data-youtube-player>
                    <img
                      class="vt-video-card__thumb"
                      src={thumbnailUrl}
                      alt={`${video.title}の問題サムネイル`}
                      width="480"
                      height="360"
                      loading="lazy"
                      decoding="async"
                      data-thumbnail-fallback={thumbnailUrl}
                    />
                    <span class="vt-video-card__ordinal">{ordinal}</span>
                    <button
                      class="vt-video-card__play"
                      type="button"
                      data-youtube-id={video.youtubeId}
                      data-youtube-title={video.title}
                      aria-label={`${video.title} を再生する`}
                    >
                      <span class="vt-video-card__play-icon" aria-hidden="true"></span>
                      <span class="vt-video-card__play-text">再生</span>
                    </button>
                    <button
                      class="vt-video-card__zoom"
                      type="button"
                      data-problem-modal-trigger
                      data-problem-src={thumbnailUrl}
                      data-problem-fallback={thumbnailUrl}
                      data-problem-title={video.title}
                      aria-label={`${video.title} の問題を拡大表示する`}
                    >
                      問題を拡大
                    </button>
                  </div>
                  <div class="vt-video-card__body">
                    <p class="vt-video-card__category">{video.category || section.title}</p>
                    <h4>{video.title}</h4>
                    <p>{video.note || "動画で考え方を確認し、手元で同じ手順を再現してください。"}</p>
                    <a href={watchUrl} target="_blank" rel="noopener noreferrer">YouTubeで開く</a>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </section>

    <section class="vt-cta" aria-labelledby="vt-cta-title">
      <div>
        <p class="vt-section-kicker">NEXT STEP</p>
        <h2 id="vt-cta-title">動画で詰まったところは、そのままにしない。</h2>
        <p>理解できた箇所と、手が止まった箇所を整理できれば、次に伸ばすべき課題が見えます。個別相談では現在地から必要な学習を具体化します。</p>
      </div>
      <div class="vt-cta__actions">
        <a class="button button--red" href="/request-documents/">資料請求</a>
        <a class="button button--blue" href="/reservation/">個別相談</a>
      </div>
    </section>
  </main>

  <dialog class="vt-problem-dialog" data-problem-dialog aria-label="問題サムネイル拡大表示">
    <div class="vt-problem-dialog__panel">
      <div class="vt-problem-dialog__bar">
        <p data-problem-dialog-title>問題</p>
        <button class="vt-problem-dialog__close" type="button" data-problem-dialog-close aria-label="問題サムネイルを閉じる">
          <span aria-hidden="true">&times;</span>
          <strong>閉じる</strong>
        </button>
      </div>
      <div class="vt-problem-dialog__viewer">
        <button class="vt-problem-dialog__nav vt-problem-dialog__nav--prev" type="button" data-problem-dialog-prev aria-label="前の問題">
          <span aria-hidden="true">&lsaquo;</span>
        </button>
        <img data-problem-dialog-image alt="" width="1280" height="720" decoding="async" />
        <button class="vt-problem-dialog__nav vt-problem-dialog__nav--next" type="button" data-problem-dialog-next aria-label="次の問題">
          <span aria-hidden="true">&rsaquo;</span>
        </button>
      </div>
      <div class="vt-problem-dialog__footer">
        <p>サムネイル画像を拡大表示しています。動画は各カードの再生ボタンから確認できます。</p>
        <span data-problem-dialog-count></span>
      </div>
    </div>
  </dialog>

  <script is:inline>
    (() => {
      const installImageFallback = (image) => {
        if (!(image instanceof HTMLImageElement)) return;
        image.addEventListener("error", () => {
          const fallback = image.dataset.problemFallback || image.dataset.thumbnailFallback;
          if (fallback && image.src !== fallback) image.src = fallback;
        });
      };

      document.querySelectorAll("[data-thumbnail-fallback]").forEach(installImageFallback);

      const players = document.querySelectorAll("[data-youtube-player]");
      players.forEach((player) => {
        const button = player.querySelector("[data-youtube-id]");
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", () => {
          const id = button.dataset.youtubeId;
          if (!id) return;
          const iframe = document.createElement("iframe");
          iframe.title = button.dataset.youtubeTitle || "動画";
          iframe.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}?autoplay=1&rel=0`;
          iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
          iframe.allowFullscreen = true;
          iframe.loading = "lazy";
          player.classList.add("is-playing");
          player.replaceChildren(iframe);
        }, { once: true });
      });

      const dialog = document.querySelector("[data-problem-dialog]");
      if (!(dialog instanceof HTMLDialogElement) || typeof dialog.showModal !== "function") return;

      const image = dialog.querySelector("[data-problem-dialog-image]");
      const title = dialog.querySelector("[data-problem-dialog-title]");
      const count = dialog.querySelector("[data-problem-dialog-count]");
      const closeButton = dialog.querySelector("[data-problem-dialog-close]");
      const prevButton = dialog.querySelector("[data-problem-dialog-prev]");
      const nextButton = dialog.querySelector("[data-problem-dialog-next]");
      const triggers = [...document.querySelectorAll("[data-problem-modal-trigger]")].filter((trigger) => trigger instanceof HTMLButtonElement);

      if (
        !(image instanceof HTMLImageElement) ||
        !(title instanceof HTMLElement) ||
        !(count instanceof HTMLElement) ||
        !(closeButton instanceof HTMLButtonElement) ||
        !(prevButton instanceof HTMLButtonElement) ||
        !(nextButton instanceof HTMLButtonElement) ||
        !triggers.length
      ) return;

      installImageFallback(image);

      let currentIndex = 0;

      const setProblem = (index) => {
        currentIndex = (index + triggers.length) % triggers.length;
        const trigger = triggers[currentIndex];
        const problemTitle = trigger.dataset.problemTitle || "問題";
        const src = trigger.dataset.problemSrc || trigger.dataset.problemFallback || "";
        const fallback = trigger.dataset.problemFallback || "";
        image.dataset.problemFallback = fallback;
        image.src = src;
        image.alt = `${problemTitle}の問題サムネイル`;
        title.textContent = problemTitle;
        count.textContent = `${currentIndex + 1} / ${triggers.length}`;
      };

      triggers.forEach((trigger, index) => {
        trigger.addEventListener("click", () => {
          setProblem(index);
          dialog.showModal();
          closeButton.focus();
        });
      });

      prevButton.addEventListener("click", () => {
        setProblem(currentIndex - 1);
      });

      nextButton.addEventListener("click", () => {
        setProblem(currentIndex + 1);
      });

      closeButton.addEventListener("click", () => {
        dialog.close();
      });

      dialog.addEventListener("click", (event) => {
        if (event.target === dialog) dialog.close();
      });

      dialog.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setProblem(currentIndex - 1);
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          setProblem(currentIndex + 1);
        }
      });
    })();
  </script>
</SiteLayout>
